@{
    ViewData["Title"] = "NSIA Prize for Innovation";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NSIA Prize for Innovation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal: #0e86ab; --green: #08703a; --lime: #83c240;
            --teal-dark: #0a6b8a; --green-dark: #065a2f;
            --off-white: #f4f2ec; --cream: #faf8f3;
            --ink: #0d1a12; --muted: #5a6b60;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--ink); overflow-x: hidden; }

        /* ══ NAV ══ */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 4rem;
            background: rgba(250,248,243,0.95); backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(14,134,171,0.12);
        }
        .nav-brand { display: flex; align-items: center; }
        .nav-logo img { width: 160px; height: 40px; display: block; }
        .nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
        .nav-links a { font-size: .82rem; font-weight: 500; color: var(--ink); text-decoration: none; opacity: .75; transition: opacity .2s; }
        .nav-links a:hover { opacity: 1; color: var(--teal); }
        .nav-cta { background: var(--green); color: white !important; padding: .6rem 1.5rem; border-radius: 4px; font-size: .82rem; font-weight: 600; opacity: 1 !important; transition: background .2s; }
        .nav-cta:hover { background: var(--green-dark); }
        .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
        .nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform .3s, opacity .3s; }
        .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-hamburger.open span:nth-child(2) { opacity: 0; }
        .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
        .mobile-menu { display: none; position: fixed; inset: 0; z-index: 150; background: var(--ink); flex-direction: column; align-items: center; justify-content: center; gap: 2rem; }
        .mobile-menu.open { display: flex; }
        .mobile-menu a { font-size: 1.4rem; font-family: 'Cormorant Garamond', serif; font-weight: 600; color: white; text-decoration: none; }
        .mobile-menu a:hover { color: var(--lime); }
        .mobile-menu .m-cta { background: var(--green); color: white; padding: .85rem 2.5rem; border-radius: 4px; font-size: .9rem; font-family: 'DM Sans', sans-serif; font-weight: 600; margin-top: .5rem; }
        .mobile-menu-close { position: absolute; top: 1.25rem; right: 1.5rem; background: none; border: none; cursor: pointer; color: white; font-size: 1.75rem; line-height: 1; }

        /* ══ HERO ══ */
        .hero { min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr; }
        .hero-left {
            background: var(--ink); 
            @* background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)),
            url("https://i.pinimg.com/736x/9c/3f/7f/9c3f7f9ebe0a9cd4ec7d4b8aa6060e1e.jpg"); *@
            padding: 10rem 4rem 4rem;
            position: relative; display: flex; flex-direction: column; justify-content: center;
        }
        .hero-left::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(14,134,171,0.25) 0%, transparent 65%),
                        radial-gradient(ellipse at 80% 20%, rgba(8,112,58,0.2) 0%, transparent 55%);
        }
        .hero-left > * { position: relative; z-index: 1; }
        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: .5rem;
            background: rgba(131,194,64,0.15); border: 1px solid rgba(131,194,64,0.3);
            padding: .35rem .9rem; border-radius: 100px;
            font-size: .98rem; font-weight: 800; color: var(--lime);
            letter-spacing: .1em; text-transform: uppercase; margin-bottom: 2rem; width: fit-content;
        }
        .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--lime); display: inline-block; animation: pulse 2s ease-in-out infinite; }
        @@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }
        .hero-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem,4.5vw,5.5rem); font-weight: 700; line-height: 1; color: white; margin-bottom: 1.5rem; }
        .hero-title .accent { color: var(--lime); font-style: italic; }
        .hero-sub { font-size: 1rem; line-height: 1.75; color: rgba(255,255,255,0.6); max-width: 440px; margin-bottom: 3rem; font-weight: 300; }
        .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
        .btn-primary { background: var(--lime); color: var(--ink); padding: .9rem 2rem; border-radius: 4px; font-size: .88rem; font-weight: 700; text-decoration: none; letter-spacing: .04em; text-transform: uppercase; transition: transform .2s, box-shadow .2s; display: inline-flex; align-items: center; gap: .5rem; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(131,194,64,0.35); }
        .btn-secondary { background: transparent; color: white; padding: .9rem 2rem; border-radius: 4px; font-size: .88rem; font-weight: 500; text-decoration: none; border: 1px solid rgba(255,255,255,0.25); transition: border-color .2s, background .2s; }
        .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.05); }
        .hero-stats { display: flex; gap: 2.5rem; margin-top: 4rem; padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.1); flex-wrap: wrap; }
        .stat-value { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 700; color: var(--lime); line-height: 1; }
        .stat-label { font-size: .72rem; color: rgba(255,255,255,0.45); letter-spacing: .08em; text-transform: uppercase; margin-top: .25rem; }

        /* ══ HERO RIGHT ══ */
        .hero-right {
            background: var(--off-white); padding: 10rem 4rem 4rem;
            display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;
        }
        .hero-right::after { content: 'NPI'; position: absolute; top: 5rem; right: 3rem; font-family: 'Cormorant Garamond', serif; font-size: 12rem; font-weight: 700; color: rgba(14,134,171,0.06); line-height: 1; pointer-events: none; }
        .timeline-label { font-size: .72rem; font-weight: 600; color: var(--teal); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 1.25rem; }
        .phase-track { display: flex; flex-direction: column; position: relative; }
        .phase-track::before { content: ''; position: absolute; left: 15px; top: 16px; bottom: 16px; width: 2px; background: linear-gradient(to bottom, var(--teal), var(--lime)); }
        .phase-item { display: flex; align-items: flex-start; gap: 1.25rem; padding: 1rem 0; position: relative; }
        .phase-dot { width: 30px; height: 30px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: .7rem; font-weight: 700; z-index: 1; }
        .phase-dot.active { background: var(--teal); color: white; }
        .phase-dot.upcoming { background: var(--off-white); border: 2px solid var(--lime); color: var(--lime); }
        .phase-dot.future { background: var(--off-white); border: 2px solid #ccc; color: #aaa; }
        .phase-name { font-weight: 600; font-size: .88rem; margin-bottom: .15rem; }
        .phase-desc { font-size: .76rem; color: var(--muted); line-height: 1.5; }

        /* ══ PARTNERS CARD ══ */
        .partners-card {
            margin-top: 1.75rem; background: white; border-radius: 12px;
            border: 1px solid rgba(14,134,171,0.12);
            box-shadow: 0 4px 20px rgba(0,0,0,0.06); overflow: hidden;
        }
        .partners-card-header {
            padding: .85rem 1.25rem;
            background: rgba(14,134,171,0.04);
            border-bottom: 1px solid rgba(14,134,171,0.1);
            display: flex; align-items: center; justify-content: space-between;
        }
        .partners-card-title { font-size: .7rem; font-weight: 600; color: var(--teal); letter-spacing: .1em; text-transform: uppercase; }
        .partners-total-badge {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem; font-weight: 700; color: var(--ink);
        }
        .partners-total-badge span { font-size: .65rem; font-family: 'DM Sans', sans-serif; font-weight: 400; color: var(--muted); margin-right: 3px; }
        .partners-list { padding: .5rem 0; }
        .partner-row {
            display: flex; align-items: center; gap: .85rem;
            padding: .7rem 1.25rem;
            border-bottom: 1px solid rgba(0,0,0,0.04);
            transition: background .15s;
        }
        .partner-row:last-child { border-bottom: none; }
        .partner-row:hover { background: rgba(0,0,0,0.015); }
        .p-icon {
            width: 30px; height: 30px; border-radius: 7px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .p-icon svg { width: 14px; height: 14px; stroke-width: 1.75; fill: none; }
        .p-icon.nsia { background: rgba(14,134,171,0.1); }
        .p-icon.nsia svg { stroke: var(--teal); }
        .p-icon.cascador { background: rgba(8,112,58,0.1); }
        .p-icon.cascador svg { stroke: var(--green); }
        .p-icon.pvac { background: rgba(220,38,38,0.08); }
        .p-icon.pvac svg { stroke: #dc2626; }
        .p-icon.training { background: rgba(131,194,64,0.1); }
        .p-icon.training svg { stroke: #4a7c10; }
        .p-name { font-size: .8rem; font-weight: 600; color: var(--ink); line-height: 1.2; }
        .p-desc { font-size: .68rem; color: var(--muted); }
        .p-info { flex: 1; min-width: 0; }
        .p-amount {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.05rem; font-weight: 700; flex-shrink: 0; text-align: right;
        }
        .p-amount.nsia-c { color: var(--teal); }
        .p-amount.cascador-c { color: var(--green); }
        .p-amount.pvac-c { color: #dc2626; }
        .p-amount.training-c {
            font-family: 'DM Sans', sans-serif; font-size: .68rem; font-weight: 600;
            color: #4a7c10; background: rgba(131,194,64,0.12);
            border: 1px solid rgba(131,194,64,0.3);
            padding: .2rem .55rem; border-radius: 100px;
        }

        /* ══ SECTIONS ══ */
        section { padding: 7rem 4rem; }
        .section-label { font-size: 2rem; font-weight: 600; color: var(--teal); letter-spacing: .12em; text-transform: uppercase; margin-bottom: 1rem; display: flex; align-items: center; gap: .6rem; }
        .section-label::before { content: ''; display: block; width: 24px; height: 2px; background: var(--teal); }
        .section-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem,3.5vw,3.4rem); font-weight: 700; line-height: 1.1; max-width: 640px; }

        /* ══ ABOUT ══ */
        .about { background: white; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
        .about-text .section-heading { margin-bottom: 1.5rem; }
        .about-text p { font-size: .95rem; line-height: 1.85; color: var(--muted); margin-bottom: 1.25rem; }
        .about-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2.5rem; }
        .pillar { padding: 1.25rem; background: var(--cream); border-left: 3px solid transparent; border-radius: 0; }
        .pillar.p1 { border-left-color: var(--teal); } .pillar.p2 { border-left-color: var(--green); }
        .pillar.p3 { border-left-color: var(--lime); } .pillar.p4 { border-left-color: var(--teal-dark); }
        .pillar-name { font-weight: 600; font-size: .85rem; margin-bottom: .25rem; }
        .pillar-desc { font-size: .75rem; color: var(--muted); line-height: 1.5; }
        .funds-grid { display: flex; flex-direction: column; gap: 1rem; }
        .fund-card { padding: 1.5rem; border-radius: 10px; display: flex; align-items: flex-start; gap: 1.1rem; }
        .fund-card.f1 { background: rgba(14,134,171,0.06); border: 1px solid rgba(14,134,171,0.15); }
        .fund-card.f2 { background: rgba(8,112,58,0.06); border: 1px solid rgba(8,112,58,0.15); }
        .fund-card.f3 { background: rgba(131,194,64,0.06); border: 1px solid rgba(131,194,64,0.15); }
        .fund-icon { width: 40px; height: 40px; border-radius: 9px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
        .f1 .fund-icon { background: rgba(14,134,171,0.12); } .f2 .fund-icon { background: rgba(8,112,58,0.12); } .f3 .fund-icon { background: rgba(131,194,64,0.12); }
        .fund-name { font-weight: 600; font-size: .88rem; margin-bottom: .3rem; }
        .fund-desc { font-size: .76rem; color: var(--muted); line-height: 1.55; }

        /* ══ NPI SECTION ══ */
        .npi-section { background: var(--ink); position: relative; overflow: hidden; }
        .npi-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 30%, rgba(14,134,171,0.2) 0%, transparent 60%), radial-gradient(ellipse at 20% 80%, rgba(8,112,58,0.15) 0%, transparent 55%); }
        .npi-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; }

        /* Programme intro — text above sectors */
        .programme-intro {
            display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; margin-bottom: 4rem;
        }
        .programme-intro-left {}
        .programme-intro-left .section-label { justify-content: flex-start; }
        .programme-intro-left .section-label::before { background: rgba(255,255,255,0.4); }
        .programme-intro-left .section-label { color: rgba(255,255,255,0.5); }
        .programme-intro-left .section-heading { color: white; }
        .programme-intro-right { padding-top: .5rem; }
        .programme-intro-right p { font-size: .95rem; color: rgba(255,255,255,0.55); line-height: 1.85; font-weight: 300; margin-bottom: 1.25rem; }
        .programme-intro-right p:last-child { margin-bottom: 0; }

        /* Sectors */
        .sectors-wrap { margin-bottom: 4rem; }
        .sectors-label { font-size: .98rem; font-weight: 600; color: rgba(255,255,255,0.4); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 1rem; }
        .sectors-grid {
            display: grid; grid-template-columns: repeat(3,1fr); gap: 1px;
            background: rgba(255,255,255,0.06); border-radius: 12px; overflow: hidden;
        }
        .sector-item { padding: 2rem 1.75rem; background: rgba(255,255,255,0.03); transition: background .25s; display: flex; flex-direction: column; align-items: flex-start; gap: .75rem; }
        .sector-item:hover { background: rgba(14,134,171,0.12); }
        .sector-icon { font-size: 1.75rem; }
        .sector-name { font-weight: 600; font-size: .95rem; color: white; }
        .sector-desc { font-size: .78rem; color: rgba(255,255,255,0.45); line-height: 1.55; }

        /* Benefits */
        .npi-benefits { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
        .benefit-card { padding: 2rem; border-radius: 10px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); transition: border-color .25s, transform .25s; }
        .benefit-card:hover { border-color: rgba(131,194,64,0.3); transform: translateY(-3px); }
        .benefit-icon { width: 46px; height: 46px; border-radius: 10px; margin-bottom: 1.1rem; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
        .benefit-card:nth-child(1) .benefit-icon { background: rgba(14,134,171,0.15); }
        .benefit-card:nth-child(2) .benefit-icon { background: rgba(8,112,58,0.15); }
        .benefit-card:nth-child(3) .benefit-icon { background: rgba(131,194,64,0.1); }
        .benefit-title { font-weight: 600; color: white; margin-bottom: .4rem; font-size: .92rem; }
        .benefit-desc { font-size: .78rem; color: rgba(255,255,255,0.45); line-height: 1.65; }

        /* ══ ELIGIBILITY ══ */
        .eligibility { background: var(--off-white); display: grid; grid-template-columns: 1fr 1.2fr; gap: 6rem; align-items: start; }
        .elig-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
        .elig-item { display: flex; align-items: flex-start; gap: 1rem; padding: 1.25rem; background: white; border-radius: 8px; border: 1px solid rgba(0,0,0,0.06); transition: box-shadow .2s; }
        .elig-item:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
        .elig-check { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; background: rgba(8,112,58,0.12); display: flex; align-items: center; justify-content: center; }
        .elig-check svg { width: 12px; height: 12px; stroke: var(--green); stroke-width: 2.5; fill: none; }
        .elig-text { font-size: .85rem; color: var(--ink); line-height: 1.55; }
        .steps-list { display: flex; flex-direction: column; gap: 0; margin-top: 2rem; position: relative; }
        .steps-list::before { content: ''; position: absolute; left: 20px; top: 24px; bottom: 24px; width: 2px; background: linear-gradient(to bottom, var(--teal), var(--green), var(--lime)); }
        .step { display: flex; gap: 1.5rem; padding: 1.5rem 0; position: relative; }
        .step-num { width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0; background: white; border: 2px solid var(--teal); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 1.1rem; color: var(--teal); z-index: 1; }
        .step-title { font-weight: 600; font-size: .92rem; margin-bottom: .3rem; }
        .step-desc { font-size: .8rem; color: var(--muted); line-height: 1.6; }

        /* ══ CTA ══ */
        .cta-banner { background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 40%, var(--green-dark) 100%); padding: 6rem 4rem; text-align: center; position: relative; overflow: hidden; }
        .cta-banner::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(131,194,64,0.2) 0%, transparent 60%); }
        .cta-banner > * { position: relative; z-index: 1; }
        .cta-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem,4vw,3.8rem); font-weight: 700; color: white; margin-bottom: 1rem; line-height: 1.1; }
        .cta-sub { font-size: 1rem; color: rgba(255,255,255,0.7); margin-bottom: 2.5rem; max-width: 520px; margin-left: auto; margin-right: auto; }
        .cta-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
        .btn-light { background: white; color: var(--green-dark); padding: 1rem 2.5rem; border-radius: 4px; font-size: .9rem; font-weight: 700; text-decoration: none; letter-spacing: .04em; text-transform: uppercase; transition: transform .2s, box-shadow .2s; display: inline-block; }
        .btn-light:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
        .btn-outline-light { background: transparent; color: white; padding: 1rem 2.5rem; border-radius: 4px; font-size: .9rem; font-weight: 500; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.5); transition: border-color .2s, background .2s; display: inline-block; }
        .btn-outline-light:hover { border-color: white; background: rgba(255,255,255,0.08); }

        /* ══ FOOTER ══ */
        footer { background: var(--ink); color: white; padding: 4rem 4rem 2.5rem; display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 4rem; }
        .footer-logo { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.25rem; }
        @* .footer-logo-icon { width: 38px; height: 38px; border-radius: 7px; background: linear-gradient(135deg, var(--teal), var(--green)); display: flex; align-items: center; justify-content: center; } *@
        .footer-logo-icon img { width: 160px; height: 40px; fill: white; }
        .footer-org { font-size: .8rem; font-weight: 700; color: white; letter-spacing: .05em; }
        .footer-tagline { font-size: .75rem; color: rgba(255,255,255,0.4); line-height: 1.6; max-width: 280px; margin-bottom: 1.5rem; }
        .footer-badge { display: inline-block; padding: .3rem .75rem; border-radius: 100px; font-size: .65rem; font-weight: 600; letter-spacing: .08em; background: rgba(131,194,64,0.12); border: 1px solid rgba(131,194,64,0.25); color: var(--lime); }
        .footer-col-title { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 1.25rem; }
        .footer-links { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
        .footer-links a { font-size: .8rem; color: rgba(255,255,255,0.55); text-decoration: none; transition: color .2s; }
        .footer-links a:hover { color: var(--lime); }
        .footer-bottom { grid-column: 1/-1; padding-top: 2rem; margin-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
        .footer-bottom p { font-size: .72rem; color: rgba(255,255,255,0.3); }

        /* ══ ANIMATIONS ══ */
        .fade-up { opacity: 0; transform: translateY(30px); transition: opacity .7s ease, transform .7s ease; }
        .fade-up.visible { opacity: 1; transform: translateY(0); }

        /* ══ RESPONSIVE — TABLET ══ */
        @@media (max-width: 1024px) {
            nav { padding: 1rem 2rem; }
            .nav-links.desktop-only { display: none; }
            .nav-hamburger { display: flex; }
            .hero { grid-template-columns: 1fr; }
            .hero-left { padding: 8rem 2.5rem 4rem; }
            .hero-right { padding: 4rem 2.5rem; }
            .hero-right::after { display: none; }
            section { padding: 5rem 2.5rem; }
            .about { grid-template-columns: 1fr; gap: 3rem; }
            .eligibility { grid-template-columns: 1fr; gap: 3rem; }
            .programme-intro { grid-template-columns: 1fr; gap: 1.5rem; }
            .sectors-grid { grid-template-columns: repeat(3,1fr); }
            .npi-benefits { grid-template-columns: 1fr 1fr; }
            footer { grid-template-columns: 1fr 1fr; gap: 2.5rem; padding: 3rem 2.5rem 2rem; }
        }

        /* ══ RESPONSIVE — MOBILE ══ */
        @@media (max-width: 640px) {
            nav { padding: .9rem 1.25rem; }
            .nav-logo img { width: 120px; }
            .hero-left { padding: 7rem 1.25rem 3rem; }
            .hero-right { padding: 3rem 1.25rem; }
            .hero-title { font-size: clamp(2.2rem,8vw,3rem); }
            .hero-sub { font-size: .9rem; margin-bottom: 2rem; }
            .hero-actions { flex-direction: column; }
            .hero-actions a { text-align: center; justify-content: center; }
            .hero-stats { gap: 1.5rem; margin-top: 2.5rem; }
            .stat-value { font-size: 1.8rem; }
            section { padding: 4rem 1.25rem; }
            .section-heading { font-size: clamp(1.6rem,6vw,2.4rem); }
            .about-pillars { grid-template-columns: 1fr; }
            .sectors-grid { grid-template-columns: 1fr; }
            .sector-item { padding: 1.5rem 1.25rem; flex-direction: row; align-items: center; gap: 1rem; }
            .npi-benefits { grid-template-columns: 1fr; gap: 1rem; }
            .cta-banner { padding: 4rem 1.25rem; }
            .cta-actions { flex-direction: column; align-items: center; }
            .btn-light, .btn-outline-light { width: 100%; text-align: center; }
            footer { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1.25rem 2rem; }
            .footer-bottom { flex-direction: column; text-align: center; }
            .phase-item { gap: 1rem; padding: .9rem 0; }
            .partners-card { margin-top: 1.5rem; }
        }

        @@media (max-width: 400px) {
            .hero-left { padding: 6rem 1rem 2.5rem; }
            .hero-right { padding: 2.5rem 1rem; }
            section { padding: 3.5rem 1rem; }
            nav { padding: .8rem 1rem; }
        }
    </style>
</head>
<body>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
    <button class="mobile-menu-close" id="menuClose">&times;</button>
    <a href="#about" onclick="closeMenu()">About NSIA</a>
    <a href="#programme" onclick="closeMenu()">The Programme</a>
    <a href="#eligibility" onclick="closeMenu()">Eligibility</a>
    <a href="/Account/Register" class="m-cta" onclick="closeMenu()">Apply Now</a>
</div>

<!-- NAV -->
<nav>
