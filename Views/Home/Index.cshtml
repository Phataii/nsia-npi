@{
    ViewData["Title"] = "NSIA Prize for Innovation";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NSIA Prize for Innovation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal:       #21a1b8;
            --teal-dark:  #1a9990;
            --teal-deep:  #0d7a73;
            --teal-light: #f2f8fa;
            --teal-pale:  #F0FAF9;
            --green:      #7BC144;
            --green-dark: #5a9130;
            --ink:        #1C2B2A;
            --muted:      #4A6260;
            --border:     rgba(45,184,176,0.2);
            --white:      #FFFFFF;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--ink); overflow-x: hidden; }

        /* ══ NAV ══ */
        nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 4rem;
            background: rgba(255,255,255,0.97); backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
        }
        .nav-brand { display: flex; align-items: center; }
        .nav-logo img { width: 160px; height: 40px; display: block; }
        .nav-links { display: flex; align-items: center; gap: 2rem; list-style: none; }
        .nav-links a { font-size: .82rem; font-weight: 500; color: var(--ink); text-decoration: none; opacity: .7; transition: opacity .2s, color .2s; }
        .nav-links a:hover { opacity: 1; color: var(--teal); }
        .nav-cta {
            background: var(--teal); color: white !important;
            padding: .6rem 1.75rem; border-radius: 100px;
            font-size: .82rem; font-weight: 600; opacity: 1 !important;
            transition: background .2s, transform .2s;
        }
        .nav-cta:hover { background: var(--teal-dark); transform: translateY(-1px); }
        .nav-hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
        .nav-hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform .3s, opacity .3s; }
        .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .nav-hamburger.open span:nth-child(2) { opacity: 0; }
        .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
        .mobile-menu { display: none; position: fixed; inset: 0; z-index: 150; background: var(--teal-deep); flex-direction: column; align-items: center; justify-content: center; gap: 2rem; }
        .mobile-menu.open { display: flex; }
        .mobile-menu a { font-size: 1.4rem; font-family: 'Cormorant Garamond', serif; font-weight: 600; color: white; text-decoration: none; }
        .mobile-menu a:hover { color: var(--green); }
        .mobile-menu .m-cta { background: white; color: var(--teal-deep); padding: .85rem 2.5rem; border-radius: 100px; font-size: .9rem; font-family: 'DM Sans', sans-serif; font-weight: 600; margin-top: .5rem; }
        .mobile-menu-close { position: absolute; top: 1.25rem; right: 1.5rem; background: none; border: none; cursor: pointer; color: white; font-size: 1.75rem; line-height: 1; }

        /* ══ HERO ══ */
        .hero {
            min-height: 100vh;
            background: var(--teal-light);
            position: relative; overflow: hidden;
            display: flex; flex-direction: column; justify-content: center;
            padding: 10rem 4rem 5rem;
        }
        .hero::before {
            content: ''; position: absolute; inset: 0;
        }
        .hero::after {
            content: 'NPI 4.0';
            position: absolute; right: -2rem; bottom: -3rem;
            font-family: 'Cormorant Garamond', serif;
            font-size: 22rem; font-weight: 700; line-height: 1;
            color: rgba(255,255,255,0.06); pointer-events: none; white-space: nowrap;
        }
        .hero > * { position: relative; z-index: 1; }
        .hero-inner { max-width: 1300px; margin: 0 auto; width: 100%; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 5rem; align-items: center; }

        .hero-eyebrow {
            display: inline-flex; align-items: center; gap: .5rem;
            background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
            padding: .35rem .9rem; border-radius: 100px;
            font-size: .72rem; font-weight: 600; color: var(--ink);
            letter-spacing: .1em; text-transform: uppercase; margin-bottom: 2rem; width: fit-content;
        }
        .hero-eyebrow::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--teal); display: inline-block; animation: pulse 2s ease-in-out infinite; }
        @@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(.8)} }

        .hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(3rem, 5.5vw, 7rem);
            font-weight: 700; line-height: .95; color: white; margin-bottom: 1.75rem;
        }
        .hero-title .t-green { color: var(--green); }
        .hero-title .t-blue { color: var(--teal); }

        .hero-sub { font-size: 1.05rem; line-height: 1.8; color: var(--ink); max-width: 500px; margin-bottom: 2.5rem; font-weight: 300; }
        .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

        .btn-white {
            background: var(--teal); color: white;
            padding: .9rem 2rem; border-radius: 100px;
            font-size: .88rem; font-weight: 700; text-decoration: none;
            transition: transform .2s, box-shadow .2s;
            display: inline-flex; align-items: center; gap: .5rem;
        }
        .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.2); }
        .btn-white svg { width: 16px; height: 16px; stroke: white; stroke-width: 2.5; fill: none; }

        .btn-ghost {
            background: rgba(255,255,255,0.1); color: black;
            padding: .9rem 2rem; border-radius: 100px;
            font-size: .88rem; font-weight: 500; text-decoration: none;
            border: 1.5px solid rgba(28, 14, 14);
            transition: border-color .2s, background .2s;
        }
        .btn-ghost:hover { border-color: rgb(28, 14, 14); background: rgba(255,255,255,0.1); }

        .hero-stats {
            display: flex; gap: 2.5rem; margin-top: 3.5rem;
            padding-top: 2.5rem; border-top: 1px solid rgba(255,255,255,0.2); flex-wrap: wrap;
        }
        .stat-value { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; font-weight: 700; color: var(--ink); line-height: 1; }
        .stat-label { font-size: .72rem; color: var(--ink); letter-spacing: .08em; text-transform: uppercase; margin-top: .25rem; }

        /* HERO RIGHT CARD */
        .hero-card {
            background: white; border-radius: 20px;
            box-shadow: 0 24px 60px rgba(13,122,115,0.25);
            overflow: hidden;
        }
        .hero-card-header {
            background: var(--teal-deep); padding: 1.25rem 1.5rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        .hero-card-label { font-size: .7rem; font-weight: 600; color: rgba(255,255,255,0.6); letter-spacing: .1em; text-transform: uppercase; }
        .hero-card-badge {
            background: var(--green); color: white;
            font-size: .65rem; font-weight: 700; padding: .2rem .6rem;
            border-radius: 100px; letter-spacing: .06em; text-transform: uppercase;
        }

        .phase-track { display: flex; flex-direction: column; position: relative; padding: 1.25rem 1.5rem; }
        .phase-track::before { content: ''; position: absolute; left: 29px; top: 32px; bottom: 32px; width: 2px; background: linear-gradient(to bottom, var(--teal), var(--green)); }
        .phase-item { display: flex; align-items: flex-start; gap: 1.1rem; padding: .8rem 0; position: relative; }
        .phase-dot { width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: .68rem; font-weight: 700; z-index: 1; }
        .phase-dot.active { background: var(--teal); color: white; }
        .phase-dot.upcoming { background: white; border: 2px solid var(--teal); color: var(--teal); }
        .phase-dot.future { background: white; border: 2px solid #d0dede; color: #aaa; }
        .phase-name { font-weight: 600; font-size: .84rem; color: var(--ink); margin-bottom: .1rem; }
        .phase-desc { font-size: .73rem; color: var(--muted); line-height: 1.5; }

        .partners-strip {
            background: var(--teal-pale); border-top: 1px solid var(--border);
            padding: 1rem 1.5rem;
        }
        .partners-strip-label { font-size: .65rem; font-weight: 600; color: var(--teal); letter-spacing: .1em; text-transform: uppercase; margin-bottom: .75rem; }
        .partners-rows { display: flex; flex-direction: column; gap: 0; }
        .p-row { display: flex; align-items: center; gap: .75rem; padding: .5rem 0; border-bottom: 1px solid rgba(45,184,176,0.1); }
        .p-row:last-child { border-bottom: none; }
        .p-dot { width: 26px; height: 26px; border-radius: 6px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
        .p-dot svg { width: 12px; height: 12px; stroke-width: 1.75; fill: none; }
        .p-dot.t { background: rgba(45,184,176,0.12); }
        .p-dot.t svg { stroke: var(--teal); }
        .p-dot.g { background: rgba(123,193,68,0.12); }
        .p-dot.g svg { stroke: var(--green-dark); }
        .p-dot.r { background: rgba(220,38,38,0.08); }
        .p-dot.r svg { stroke: #dc2626; }
        .p-dot.s { background: rgba(45,184,176,0.08); }
        .p-dot.s svg { stroke: var(--teal-dark); }
        .p-row-name { font-size: .76rem; font-weight: 600; color: var(--ink); flex: 1; }
        .p-row-desc { font-size: .65rem; color: var(--muted); }
        .p-row-amount { font-family: 'Cormorant Garamond', serif; font-size: .95rem; font-weight: 700; color: var(--teal); flex-shrink: 0; }
        .p-row-amount.g { color: var(--green-dark); }
        .p-row-amount.r { color: #dc2626; }
        .p-row-amount.pill {
            font-family: 'DM Sans', sans-serif; font-size: .62rem; font-weight: 600;
            color: var(--green-dark); background: rgba(123,193,68,0.12);
            border: 1px solid rgba(123,193,68,0.25);
            padding: .18rem .5rem; border-radius: 100px;
        }
        .partners-total {
            display: flex; justify-content: space-between; align-items: center;
            padding-top: .65rem; margin-top: .35rem;
            border-top: 1.5px solid rgba(45,184,176,0.15);
        }
        .partners-total span { font-size: .68rem; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; }
        .partners-total strong { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 700; color: var(--teal); }

        /* ══ DIVIDER BAND ══ */
        .band {
            background: var(--teal-light); padding: 2rem 4rem;
            display: flex; align-items: center; justify-content: center; gap: 4rem;
            flex-wrap: wrap;
        }
        .band-item { display: flex; align-items: center; gap: .75rem; }
        .band-icon { width: 36px; height: 36px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .band-icon svg { width: 16px; height: 16px; stroke: white; stroke-width: 2; fill: none; }
        .band-text { font-size: .82rem; font-weight: 500; color: var(--ink); }

        /* ══ SECTIONS ══ */
        section { padding: 7rem 4rem; }
        .section-label {
            font-size: .72rem; font-weight: 600; color: var(--teal);
            letter-spacing: .12em; text-transform: uppercase; margin-bottom: 1rem;
            display: flex; align-items: center; gap: .6rem;
        }
        .section-label::before { content: ''; display: block; width: 24px; height: 2px; background: var(--teal); }
        .section-heading { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem,3.5vw,3.4rem); font-weight: 700; line-height: 1.1; max-width: 640px; color: var(--ink); }

        /* ══ ABOUT ══ */
        .about { background: white; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
        .about-text .section-heading { margin-bottom: 1.5rem; }
        .about-text p { font-size: .95rem; line-height: 1.85; color: var(--muted); margin-bottom: 1.25rem; }
        .about-pillars { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 2.5rem; }
        .pillar { padding: 1.25rem; background: var(--teal-pale); border-left: 3px solid transparent; }
        .pillar.p1 { border-left-color: var(--teal); }
        .pillar.p2 { border-left-color: var(--green); }
        .pillar.p3 { border-left-color: var(--teal-dark); }
        .pillar.p4 { border-left-color: var(--green-dark); }
        .pillar-name { font-weight: 600; font-size: .85rem; margin-bottom: .25rem; color: var(--ink); }
        .pillar-desc { font-size: .75rem; color: var(--muted); line-height: 1.5; }
        .funds-grid { display: flex; flex-direction: column; gap: 1rem; }
        .fund-card { padding: 1.5rem; border-radius: 10px; display: flex; align-items: flex-start; gap: 1.1rem; }
        .fund-card.f1 { background: rgba(45,184,176,0.06); border: 1px solid rgba(45,184,176,0.15); }
        .fund-card.f2 { background: rgba(123,193,68,0.06); border: 1px solid rgba(123,193,68,0.15); }
        .fund-card.f3 { background: rgba(45,184,176,0.04); border: 1px solid rgba(45,184,176,0.1); }
        .fund-icon { width: 40px; height: 40px; border-radius: 9px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
        .f1 .fund-icon { background: rgba(45,184,176,0.12); }
        .f2 .fund-icon { background: rgba(123,193,68,0.12); }
        .f3 .fund-icon { background: rgba(45,184,176,0.1); }
        .fund-name { font-weight: 600; font-size: .88rem; color: var(--ink); margin-bottom: .3rem; }
        .fund-desc { font-size: .76rem; color: var(--muted); line-height: 1.55; }

        /* ══ NPI SECTION ══ */
        .npi-section { background: var(--teal-light); position: relative; overflow: hidden; }
        .npi-section::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(ellipse at 90% 10%, rgba(45,184,176,0.3) 0%, transparent 50%);
        }
        .npi-inner { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; }

        .programme-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; margin-bottom: 4rem; }
        .programme-intro-right p { font-size: .95rem; color: var(--muted); line-height: 1.85; margin-bottom: 1.25rem; }
        .programme-intro-right p:last-child { margin-bottom: 0; }

        .sectors-wrap { margin-bottom: 4rem; }
        .sectors-label { font-size: .7rem; font-weight: 600; color: var(--teal); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 1rem; }
        .sectors-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
        .sector-item {
            padding: 2rem 1.75rem; background: white;
            border-radius: 12px; border: 1px solid var(--border);
            display: flex; flex-direction: column; align-items: flex-start; gap: .75rem;
            transition: box-shadow .25s, transform .25s, border-color .25s;
        }
        .sector-item:hover { box-shadow: 0 8px 30px rgba(45,184,176,0.15); transform: translateY(-3px); border-color: var(--teal); }
        .sector-icon { font-size: 2rem; }
        .sector-name { font-weight: 600; font-size: .95rem; color: var(--ink); }
        .sector-desc { font-size: .78rem; color: var(--muted); line-height: 1.55; }

        .npi-benefits { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
        .benefit-card {
            padding: 2rem; border-radius: 12px;
            background: white; border: 1px solid var(--border);
            transition: box-shadow .25s, transform .25s;
        }
        .benefit-card:hover { box-shadow: 0 8px 30px rgba(45,184,176,0.15); transform: translateY(-3px); }
        .benefit-icon { width: 46px; height: 46px; border-radius: 10px; margin-bottom: 1.1rem; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
        .benefit-card:nth-child(1) .benefit-icon { background: rgba(45,184,176,0.12); }
        .benefit-card:nth-child(2) .benefit-icon { background: rgba(123,193,68,0.12); }
        .benefit-card:nth-child(3) .benefit-icon { background: rgba(45,184,176,0.1); }
        .benefit-title { font-weight: 600; color: var(--ink); margin-bottom: .4rem; font-size: .92rem; }
        .benefit-desc { font-size: .78rem; color: var(--muted); line-height: 1.65; }

        /* ══ ELIGIBILITY ══ */
        .eligibility { background: white; display: grid; grid-template-columns: 1fr 1.2fr; gap: 6rem; align-items: start; }
        .elig-list { display: flex; flex-direction: column; gap: 1rem; margin-top: 2rem; }
        .elig-item {
            display: flex; align-items: flex-start; gap: 1rem;
            padding: 1.1rem 1.25rem; background: var(--teal-pale); border-radius: 8px;
            border: 1px solid var(--border); transition: border-color .2s;
        }
        .elig-item:hover { border-color: var(--teal); }
        .elig-check { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; background: var(--teal); display: flex; align-items: center; justify-content: center; }
        .elig-check svg { width: 11px; height: 11px; stroke: white; stroke-width: 2.5; fill: none; }
        .elig-text { font-size: .85rem; color: var(--ink); line-height: 1.55; }
        .steps-list { display: flex; flex-direction: column; gap: 0; margin-top: 2rem; position: relative; }
        .steps-list::before { content: ''; position: absolute; left: 20px; top: 24px; bottom: 24px; width: 2px; background: linear-gradient(to bottom, var(--teal), var(--green)); }
        .step { display: flex; gap: 1.5rem; padding: 1.5rem 0; position: relative; }
        .step-num { width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0; background: var(--teal); display: flex; align-items: center; justify-content: center; font-family: 'Cormorant Garamond', serif; font-weight: 700; font-size: 1.1rem; color: white; z-index: 1; }
        .step-title { font-weight: 600; font-size: .92rem; margin-bottom: .3rem; color: var(--ink); }
        .step-desc { font-size: .8rem; color: var(--muted); line-height: 1.6; }

        /* ══ CTA ══ */
        .cta-banner {
            background: var(--teal-light);
            padding: 6rem 4rem; text-align: center; position: relative; overflow: hidden;
        }
        .cta-banner::before {
            content: ''; position: absolute; inset: 0;
            
        }
        .cta-banner > * { position: relative; z-index: 1; }
        .cta-title { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem,4vw,3.8rem); font-weight: 700; color: var(--ink); margin-bottom: 1rem; line-height: 1.1; }
        .cta-sub { font-size: 1rem; color: var(--ink); margin-bottom: 2.5rem; max-width: 520px; margin-left: auto; margin-right: auto; line-height: 1.7; }
        .cta-actions { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
        .btn-white-solid {
            background: white; color: var(--teal);
            padding: 1rem 2.5rem; border-radius: 100px;
            font-size: .9rem; font-weight: 700; text-decoration: none;
            transition: transform .2s, box-shadow .2s; display: inline-block;
        }
        .btn-white-solid:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.2); }
        .btn-outline-white {
            background: rgba(255,255,255,0.1); color: black;
            padding: 1rem 2.5rem; border-radius: 100px;
            font-size: .9rem; font-weight: 500; text-decoration: none;
            border: 1.5px solid rgba(28, 14, 14);
            transition: border-color .2s, background .2s; display: inline-block;
        }
        .btn-outline-white:hover { border-color: rgba(28, 14, 14); background: rgba(255,255,255,0.1); }

        /* ══ FOOTER ══ */
        footer {
            background: transparent; color: var(--ink);
            padding: 4rem 4rem 2.5rem;
            display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 4rem;
        }
        .footer-logo { margin-bottom: 1.25rem; }
        .footer-logo img { width: 160px; height: 40px; }
        .footer-tagline { font-size: .75rem; color: color: var(--ink); line-height: 1.6; max-width: 280px; margin-bottom: 1.5rem; }
        .footer-badge { display: inline-block; padding: .3rem .75rem; border-radius: 100px; font-size: .65rem; font-weight: 600; letter-spacing: .08em; background: rgba(45,184,176,0.15); border: 1px solid rgba(45,184,176,0.3); color: var(--teal); }
        .footer-col-title { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--ink); margin-bottom: 1.25rem; }
        .footer-links { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
        .footer-links a { font-size: .8rem; color: var(--ink); text-decoration: none; transition: color .2s; }
        .footer-links a:hover { color: var(--ink); }
        .footer-bottom { grid-column: 1/-1; padding-top: 2rem; margin-top: 1rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
        .footer-bottom p { font-size: .72rem; color: var(--ink); }

        /* ══ ANIMATIONS ══ */
        .fade-up { opacity: 0; transform: translateY(30px); transition: opacity .7s ease, transform .7s ease; }
        .fade-up.visible { opacity: 1; transform: translateY(0); }

        /* ══ TABLET ══ */
        @@media (max-width: 1024px) {
            nav { padding: 1rem 2rem; }
            .nav-links.desktop-only { display: none; }
            .nav-hamburger { display: flex; }
            .hero { padding: 8rem 2.5rem 4rem; }
            .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
            .hero::after { display: none; }
            .band { padding: 1.5rem 2.5rem; gap: 2rem; }
            section { padding: 5rem 2.5rem; }
            .about { grid-template-columns: 1fr; gap: 3rem; }
            .eligibility { grid-template-columns: 1fr; gap: 3rem; }
            .programme-intro { grid-template-columns: 1fr; gap: 1.5rem; }
            .sectors-grid { grid-template-columns: repeat(3,1fr); }
            .npi-benefits { grid-template-columns: 1fr 1fr; }
            footer { grid-template-columns: 1fr 1fr; gap: 2.5rem; padding: 3rem 2.5rem 2rem; }
        }

        /* ══ MOBILE ══ */
        @@media (max-width: 640px) {
            nav { padding: .9rem 1.25rem; }
            .nav-logo img { width: 120px; }
            .hero { padding: 7rem 1.25rem 3rem; }
            .hero-title { font-size: clamp(2.5rem,10vw,3.5rem); }
            .hero-sub { font-size: .9rem; }
            .hero-actions { flex-direction: column; }
            .hero-actions a { text-align: center; justify-content: center; }
            .hero-stats { gap: 1.5rem; margin-top: 2rem; }
            .stat-value { font-size: 2rem; }
            .band { padding: 1.25rem; flex-direction: column; gap: 1rem; align-items: flex-start; }
            section { padding: 4rem 1.25rem; }
            .section-heading { font-size: clamp(1.6rem,6vw,2.4rem); }
            .about-pillars { grid-template-columns: 1fr; }
            .sectors-grid { grid-template-columns: 1fr; }
            .npi-benefits { grid-template-columns: 1fr; gap: 1rem; }
            .cta-banner { padding: 4rem 1.25rem; }
            .cta-actions { flex-direction: column; align-items: center; }
            .btn-white-solid, .btn-outline-white { width: 100%; text-align: center; }
            footer { grid-template-columns: 1fr; gap: 2rem; padding: 3rem 1.25rem 2rem; }
            .footer-bottom { flex-direction: column; text-align: center; }
        }
        @@media (max-width: 400px) {
            .hero { padding: 6rem 1rem 2.5rem; }
            section { padding: 3.5rem 1rem; }
            nav { padding: .8rem 1rem; }
        }
    </style>
</head>
