<!-- ABOUT NSIA -->
<section class="about fade-up" id="about">
    <div class="about-text">
        <div class="section-label">About NSIA</div>
        <h2 class="section-heading">Nigeria's Sovereign Wealth Fund Manager</h2>
        <p>The Nigeria Sovereign Investment Authority (NSIA) is an independent investment institution of the Federation, established by Act of the National Assembly in May 2011. It manages Nigeria's sovereign wealth fund — investing surplus oil revenues for the long-term benefit of all Nigerians.</p>
        <p>With over $2.4 billion in assets under management, NSIA is the third largest sovereign wealth fund in Sub-Saharan Africa, operating three ring-fenced funds each serving a distinct national mandate.</p>
        <div class="about-pillars">
            <div class="pillar p1"><div class="pillar-name">Financial Sustainability</div><div class="pillar-desc">Maximising risk-adjusted returns on invested assets</div></div>
            <div class="pillar p2"><div class="pillar-name">Independence</div><div class="pillar-desc">Impartial, merit-based investment decisions</div></div>
            <div class="pillar p3"><div class="pillar-name">Transparency</div><div class="pillar-desc">Consistent financial reporting and public accountability</div></div>
            <div class="pillar p4"><div class="pillar-name">National Impact</div><div class="pillar-desc">Driving socioeconomic outcomes across key sectors</div></div>
        </div>
    </div>
    <div class="about-visual">
        <div class="funds-grid">
            <div class="fund-card f1"><div class="fund-icon">🏦</div><div><div class="fund-name">Stabilisation Fund</div><div class="fund-desc">Provides budget support and fiscal buffers during periods of economic stress, ensuring government services remain uninterrupted.</div></div></div>
            <div class="fund-card f2"><div class="fund-icon">🌱</div><div><div class="fund-name">Future Generations Fund</div><div class="fund-desc">An intergenerational savings vehicle investing in long-term assets so future Nigerians benefit from today's oil wealth.</div></div></div>
            <div class="fund-card f3"><div class="fund-icon">🏗️</div><div><div class="fund-name">Nigeria Infrastructure Fund</div><div class="fund-desc">Finances critical infrastructure — from toll roads and power projects to healthcare centres — that attract investment and create jobs.</div></div></div>
        </div>
    </div>
</section>

<!-- NPI PROGRAMME -->
<section class="npi-section" id="programme">
    <div class="npi-inner">

        <!-- Intro text — left/right layout -->
        <div class="programme-intro fade-up">
            <div class="programme-intro-left">
                <div class="section-label">The Programme</div>
                <h2 class="section-heading">NSIA Prize for Innovation</h2>
            </div>
            <div class="programme-intro-right">
                <p>A multi-year programme designed to fund, mentor, and accelerate early-stage Nigerian digital innovations — from first idea to global-ready startup.</p>
                <p>We back bold innovators solving real problems in three critical sectors. If your solution drives measurable impact in healthcare, agriculture, or climate and ESG, this programme is for you.</p>
            </div>
        </div>

        <!-- Sectors -->
        <div class="sectors-wrap fade-up">
            <div class="sectors-label">Focus sectors</div>
            <div class="sectors-grid" id="sectors">
                <div class="sector-item">
                    <div class="sector-icon">💊</div>
                    <div class="sector-name">Healthcare</div>
                    <div class="sector-desc">Digital diagnostics, telemedicine, health insurance access and patient outcomes</div>
                </div>
                <div class="sector-item">
                    <div class="sector-icon">🌾</div>
                    <div class="sector-name">Agriculture</div>
                    <div class="sector-desc">AgriTech, supply chains, smallholder finance and food security solutions</div>
                </div>
                <div class="sector-item">
                    <div class="sector-icon">🌱</div>
                    <div class="sector-name">Climate &amp; ESG Solutions</div>
                    <div class="sector-desc">Clean energy, carbon reduction, sustainable finance and environmental impact</div>
                </div>
            </div>
        </div>

        <!-- Benefits -->
        <div class="npi-benefits fade-up">
            <div class="benefit-card">
                <div class="benefit-icon">💰</div>
                <div class="benefit-title">Cash &amp; Equity Prizes</div>
                <div class="benefit-desc">Winners share a prize pool of over $280,000 through cash awards, equity investment, and partner prizes from Cascador and PVAC.</div>
            </div>
            <div class="benefit-card">
                <div class="benefit-icon">🧭</div>
                <div class="benefit-title">Mentorship &amp; Training</div>
                <div class="benefit-desc">Access seasoned mentors from Nigeria's top business and tech ecosystems, plus a fully sponsored training programme at a leading partner institution.</div>
            </div>
            <div class="benefit-card">
                <div class="benefit-icon">🌐</div>
                <div class="benefit-title">Platform &amp; Visibility</div>
                <div class="benefit-desc">NPI provides a credible national platform to showcase your innovation and connect with investors, partners, and industry leaders across Nigeria.</div>
            </div>
        </div>

    </div>
</section>

<!-- ELIGIBILITY -->
<section class="eligibility fade-up" id="eligibility">
    <div>
        <div class="section-label">Who Can Apply</div>
        <h2 class="section-heading">Eligibility Criteria</h2>
        <div class="elig-list">
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Nigerian-owned or Nigerian-registered startup or early-stage company</div></div>
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Technology-enabled digital solution with demonstrable social or economic impact</div></div>
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Solution must address Healthcare, Agriculture, or Climate &amp; ESG</div></div>
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Early-stage — must not have received more than Series A funding</div></div>
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Scalable model with potential for national or continental reach</div></div>
            <div class="elig-item"><div class="elig-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div><div class="elig-text">Founder(s) must be available for the full duration of the programme</div></div>
        </div>
    </div>
    <div class="how-it-works">
        <div class="section-label">How It Works</div>
        <h2 class="section-heading">Your Path to the Prize</h2>
        <div class="steps-list">
            <div class="step"><div class="step-num">1</div><div class="step-body"><div class="step-title">Register &amp; Submit Application</div><div class="step-desc">Complete your online application with your innovation brief, business model, and impact statement.</div></div></div>
            <div class="step"><div class="step-num">2</div><div class="step-body"><div class="step-title">Initial Screening</div><div class="step-desc">Applications are reviewed by an expert panel. Top 100 startups advance to the accelerator phase.</div></div></div>
            <div class="step"><div class="step-num">3</div><div class="step-body"><div class="step-title">Accelerator Bootcamp</div><div class="step-desc">Intensive physical bootcamp with mentors, training sessions, and networking opportunities.</div></div></div>
            <div class="step"><div class="step-num">4</div><div class="step-body"><div class="step-title">Demo Day Finals</div><div class="step-desc">Top 10 finalists pitch to a panel of judges from business and innovation ecosystems in Abuja.</div></div></div>
            <div class="step"><div class="step-num">5</div><div class="step-body"><div class="step-title">Win &amp; Scale</div><div class="step-desc">Winners receive cash prizes, equity investment, and a fully sponsored training programme.</div></div></div>
        </div>
    </div>
</section>

<!-- CTA -->
<div class="cta-banner fade-up" id="apply">
