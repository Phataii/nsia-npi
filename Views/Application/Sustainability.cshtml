@{
    ViewData["Title"] = "Sustainability — NSIA Prize for Innovation";
    Layout = null;

    var applicantName = ViewBag.ApplicantName as string ?? "";
    var completedStep = (int)(ViewBag.CompletedStep ?? 7);
    var initials = string.Join("", applicantName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries)
        .Take(2)
        .Select(w => w[0]));

    var businessReplicability = ViewData["BusinessReplicability"]?.ToString() ?? "";
    var sustainabilityIntegration = ViewData["SustainabilityIntegration"]?.ToString() ?? "";
    var energyWasteReduction = ViewData["EnergyWasteReduction"]?.ToString() ?? "";
    var sustainabilityTechnology = ViewData["SustainabilityTechnology"]?.ToString() ?? "";
    var scalingWithSustainability = ViewData["ScalingWithSustainability"]?.ToString() ?? "";
    var climateChangeApproach = ViewData["ClimateChangeApproach"]?.ToString() ?? "";
    var digitalAccessibility = ViewData["DigitalAccessibility"]?.ToString() ?? "";
    var sdgAlignment = ViewData["SdgAlignment"]?.ToString() ?? "";

    var savedSdgs = sdgAlignment
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(s => s.Trim())
        .ToList();

    var sdgList = new[] {
        "SDG 1 — No Poverty",
        "SDG 2 — Zero Hunger",
        "SDG 3 — Good Health and Well-being",
        "SDG 4 — Quality Education",
        "SDG 5 — Gender Equality",
        "SDG 6 — Clean Water and Sanitation",
        "SDG 7 — Affordable and Clean Energy",
        "SDG 8 — Decent Work and Economic Growth",
        "SDG 9 — Industry, Innovation and Infrastructure",
        "SDG 10 — Reduced Inequalities",
        "SDG 11 — Sustainable Cities and Communities",
        "SDG 12 — Responsible Consumption and Production",
        "SDG 13 — Climate Action",
        "SDG 14 — Life Below Water",
        "SDG 15 — Life on Land",
        "SDG 16 — Peace, Justice and Strong Institutions",
        "SDG 17 — Partnerships for the Goals",
    };

    var steps = new[] {
        new { Num = 1, Name = "Pre-Checklist", Action = "PreChecklist" },
        new { Num = 2, Name = "Personal Info", Action = "PersonalInfo" },
        new { Num = 3, Name = "Company Info", Action = "CompanyInfo" },
        new { Num = 4, Name = "Team Info", Action = "TeamInfo" },
        new { Num = 5, Name = "Product & Growth", Action = "ProductInfo" },
        new { Num = 6, Name = "Commercial I", Action = "Commercial1" },
        new { Num = 7, Name = "Commercial II", Action = "Commercial2" },
        new { Num = 8, Name = "Sustainability", Action = "Sustainability" },
        new { Num = 9, Name = "Impact", Action = "Impact" },
        new { Num = 10, Name = "Additional Info", Action = "Additional" },
    };

    string StepStatus(int num)
    {
        if (num <= completedStep) return "completed";
        if (num == completedStep + 1) return "active";
        return "locked";
    }

    bool IsSelected(string saved, string val) => saved == val;

    string SafeId(string prefix, string value, int max = 12)
    {
        var cleaned = value
            .Replace(" ", "-")
            .Replace("/", "-")
            .Replace("%", "")
            .Replace("+", "p")
            .Replace("<", "lt")
            .Replace(">", "gt")
            .Replace("&", "and")
            .Replace(",", "")
            .Replace("₦", "n")
            .Replace("—", "-")
            .Replace("–", "-")
            .ToLower();

        if (cleaned.Length > max)
        {
            cleaned = cleaned.Substring(0, max);
        }

        return prefix + cleaned;
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" sizes="16x16"
          href="https://web.archive.org/web/20250328161536im_/http://nsia-ip.com/assets/images/favicons/favicon-16x16.png" />
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --teal-pale: #F0FAF9;
                --green: #7BC144;
                --green-dark: #5a9130;
                --ink: #1C2B2A;
                --cream: #F5F9F8;
                --off: #EEF4F3;
                --muted: #4A6260;
                --border: rgba(45, 184, 176, 0.2);
                --nav-h: 62px;
                --step-h: 56px;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--off);
                color: var(--ink);
                min-height: 100vh;
            }

            .top-nav {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 200;
                height: var(--nav-h);
                background: white;
                display: flex;
                align-items: center;
                padding: 0 2rem;
                justify-content: space-between;
            }

            .top-nav::after {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(ellipse at 30% 50%, rgba(255, 255, 255, 0.08) 0%, transparent 60%);
            }

            .nav-brand {
                display: flex;
                align-items: center;
                position: relative;
                z-index: 1;
            }

            .nav-brand img {
                height: 32px;
                width: auto;
            }

            .nav-right {
                display: flex;
                align-items: center;
                gap: 1.25rem;
                position: relative;
                z-index: 1;
            }

            .nav-deadline {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 11px;
                color: var(--ink);
            }

            .nav-deadline svg {
                width: 13px;
                height: 13px;
                stroke: var(--ink);
                stroke-width: 1.75;
                fill: none;
            }

            .deadline-val {
                color: var(--ink);
                font-weight: 600;
            }

            .nav-user {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .user-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: var(--ink);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .user-name {
                font-size: 12px;
                color: var(--ink);
            }

            .nav-logout {
                font-size: 11px;
                color: var(--ink);
                text-decoration: none;
                padding: .3rem .7rem;
                border: 1px solid var(--green-dark);
                border-radius: 100px;
                transition: all .2s;
                white-space: nowrap;
            }

            .nav-logout:hover {
                color: white;
                border-color: var(--teal-dark);
                background: var(--ink);
            }

            .hamburger {
                display: none;
                flex-direction: column;
                gap: 4px;
                background: none;
                border: none;
                cursor: pointer;
                padding: 4px;
                position: relative;
                z-index: 1;
            }

            .hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--ink);
                border-radius: 2px;
                transition: transform .3s, opacity .3s;
            }

            .hamburger.open span:nth-child(1) {
                transform: translateY(6px) rotate(45deg);
            }

            .hamburger.open span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.open span:nth-child(3) {
                transform: translateY(-6px) rotate(-45deg);
            }

            .step-bar {
                position: fixed;
                top: var(--nav-h);
                left: 0;
                right: 0;
                z-index: 190;
                height: var(--step-h);
                background: white;
                border-bottom: 1px solid var(--green);
                display: flex;
                align-items: stretch;
                overflow: hidden;
            }

            .step-item {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                padding: 0 .35rem;
                text-decoration: none;
                color: var(--green);
                border-right: 1px solid var(--green);
                position: relative;
                transition: background .2s;
                min-width: 0;
            }

            .step-item:last-child {
                border-right: none;
            }

            .step-item::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: transparent;
                transition: background .2s;
            }

            .step-item:hover {
                background: var(--teal-pale);
            }

            .step-item.completed .step-num {
                background: var(--green);
                border-color: var(--green);
                color: white;
            }

            .step-item.completed .step-num svg {
                display: block;
            }

            .step-item.completed .step-num span {
                display: none;
            }

            .step-item.completed .step-name {
                color: var(--green);
            }

            .step-item.completed::after {
                background: var(--green);
            }

            .step-item.active {
                background: var(--teal-pale);
            }

            .step-item.active .step-num {
                background: var(--green);
                border-color: var(--green);
                color: white;
            }

            .step-item.active .step-name {
                color: var(--green);
                font-weight: 500;
            }

            .step-item.active::after {
                background: var(--green);
            }

            .step-num {
                width: 20px;
                height: 20px;
                border-radius: 50%;
                flex-shrink: 0;
                border: 1.5px solid rgba(0, 0, 0, 0.15);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 9px;
                font-weight: 500;
                color: var(--muted);
            }

            .step-num svg {
                width: 9px;
                height: 9px;
                stroke: white;
                stroke-width: 3;
                fill: none;
                display: none;
            }

            .step-name {
                font-size: 10.5px;
                color: var(--muted);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            /* ── DRAWER ── */
            .drawer-overlay {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 150;
                background: var(--teal-light);
                opacity: 0;
                transition: opacity .3s;
            }

            .drawer-overlay.open {
                opacity: 1;
            }

            .side-drawer {
                position: fixed;
                top: 0;
                left: -280px;
                bottom: 0;
                z-index: 160;
                width: 280px;
                background: var(--teal-light);
                display: flex;
                flex-direction: column;
                transition: left .3s cubic-bezier(0.4, 0, 0.2, 1);
                overflow-y: auto;
            }

            .side-drawer.open {
                left: 0;
            }

            .drawer-header {
                padding: 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            }

            .drawer-header img {
                height: 30px;
                width: auto;
                filter: brightness(0) invert(1);
            }

            .drawer-user {
                padding: 1rem 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .drawer-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: var(--teal);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .drawer-uname {
                font-size: 13px;
                font-weight: 500;
                color: var(--ink);
            }

            .drawer-uemail {
                font-size: 11px;
                color: var(--ink);
            }

            .drawer-steps {
                padding: .75rem 0;
                flex: 1;
            }

            .drawer-step-label {
                font-size: 10px;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .1em;
                text-transform: uppercase;
                padding: .5rem 1.25rem .25rem;
                display: block;
            }

            .drawer-item {
                display: flex;
                align-items: center;
                gap: .9rem;
                padding: .75rem 1.25rem;
                text-decoration: none;
                color: var(--ink);
                transition: background .2s, color .2s;
                position: relative;
            }

            .drawer-item:hover {
                background: rgba(255, 255, 255, 0.04);
                color: var(--teal-dark);
            }

            .drawer-item.active {
                background: rgba(45, 184, 176, 0.15);
                color: var(--ink);
            }

            .drawer-item.active::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 3px;
                background: var(--teal);
                border-radius: 0 2px 2px 0;
            }

            .drawer-item-num {
                width: 24px;
                height: 24px;
                border-radius: 50%;
                flex-shrink: 0;
                border: 1.5px solid rgba(255, 255, 255, 0.15);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                font-weight: 500;
            }

            .drawer-item.completed .drawer-item-num {
                background: var(--teal);
                border-color: var(--teal);
            }

            .drawer-item.active .drawer-item-num {
                background: var(--teal);
                border-color: var(--teal);
            }

            .drawer-item-num svg {
                width: 10px;
                height: 10px;
                stroke: white;
                stroke-width: 3;
                fill: none;
                display: none;
            }

            .drawer-item.completed .drawer-item-num svg {
                display: block;
            }

            .drawer-item.completed .drawer-item-num span {
                display: none;
            }

            .drawer-item-name {
                font-size: 13px;
            }

            .drawer-item-status {
                font-size: 10px;
                color: var(--ink);
            }

            .drawer-item.completed .drawer-item-status {
                color: var(--teal);
            }

            .drawer-item.active .drawer-item-status {
                color: rgba(45, 184, 176, 0.8);
            }

            .drawer-footer {
                padding: 1rem 1.25rem;
                border-top: 1px solid rgba(255, 255, 255, 0.08);
            }

            .drawer-logout {
                display: flex;
                align-items: center;
                gap: .6rem;
                font-size: 12px;
                color: var(--ink);
                text-decoration: none;
                transition: color .2s;
            }

            .drawer-logout svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            .drawer-logout:hover {
                color: var(--muted);
            }

            .main {
                padding-top: calc(var(--nav-h) + var(--step-h));
                min-height: 100vh;
            }

            .content {
                max-width: 760px;
                margin: 0 auto;
                padding: 2.5rem 2rem 4rem;
            }

            .page-header {
                margin-bottom: 2rem;
            }

            .breadcrumb {
                display: flex;
                align-items: center;
                gap: .4rem;
                font-size: 11px;
                color: var(--muted);
                margin-bottom: .75rem;
                flex-wrap: wrap;
            }

            .breadcrumb a {
                color: var(--teal);
                text-decoration: none;
            }

            .breadcrumb a:hover {
                text-decoration: underline;
            }

            .breadcrumb svg {
                width: 10px;
                height: 10px;
                stroke: var(--muted);
                stroke-width: 2;
                fill: none;
            }

            .page-title {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                font-size: 2rem;
                font-weight: 700;
                color: var(--ink);
                line-height: 1.1;
                margin-bottom: .35rem;
            }

            .page-sub {
                font-size: .84rem;
                color: var(--muted);
                line-height: 1.65;
            }

            .step-mini {
                display: flex;
                align-items: center;
                gap: .75rem;
                background: white;
                border-radius: 8px;
                border: 1px solid var(--border);
                padding: .85rem 1.25rem;
                margin-bottom: 2rem;
            }

            .step-mini-dot {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                flex-shrink: 0;
                background: var(--teal);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 600;
            }

            .step-mini-label {
                font-size: 10px;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: .07em;
            }

            .step-mini-name {
                font-size: .85rem;
                font-weight: 500;
                color: var(--ink);
            }

            .step-mini-spacer {
                flex: 1;
            }

            .step-mini-progress {
                font-size: 11px;
                color: var(--muted);
                white-space: nowrap;
            }

            .step-mini-bar {
                width: 120px;
                height: 4px;
                background: var(--off);
                border-radius: 10px;
                overflow: hidden;
                flex-shrink: 0;
            }

            .step-mini-fill {
                height: 100%;
                background: linear-gradient(to right, var(--teal), var(--green));
                border-radius: 10px;
                width: 80%;
            }

            .form-card {
                background: white;
                border-radius: 12px;
                border: 1px solid var(--border);
                overflow: hidden;
                margin-bottom: 1.25rem;
            }

            .form-card-header {
                padding: 1.1rem 1.75rem;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .form-card-icon {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background: var(--teal-light);
            }

            .form-card-icon svg {
                width: 17px;
                height: 17px;
                stroke: var(--teal);
                stroke-width: 1.75;
                fill: none;
            }

            .form-card-title {
                font-size: .92rem;
                font-weight: 500;
                color: var(--ink);
                margin-bottom: 2px;
            }

            .form-card-desc {
                font-size: .74rem;
                color: var(--muted);
                line-height: 1.4;
            }

            .form-card-body {
                padding: 1.75rem;
                display: flex;
                flex-direction: column;
                gap: 1.35rem;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: .38rem;
            }

            label.field-label {
                font-size: .75rem;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .02em;
            }

            .label-req {
                color: #e53e3e;
                margin-left: 2px;
            }

            .label-opt {
                font-size: .68rem;
                color: var(--muted);
                font-weight: 400;
                margin-left: 4px;
            }

            .radio-options {
                display: flex;
                flex-direction: column;
                gap: .6rem;
            }

            .radio-options.cols-2 {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .65rem;
                align-items: stretch;
            }

            .r-option {
                position: relative;
                height: 100%;
            }

            .r-option input[type="radio"] {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }

            .r-label {
                display: flex;
                align-items: flex-start;
                gap: .75rem;
                padding: .8rem 1.1rem;
                border-radius: 8px;
                border: 1.5px solid var(--border);
                background: white;
                cursor: pointer;
                transition: border-color .2s, background .2s;
                user-select: none;
                min-height: 72px;
                height: 100%;
            }

            .r-label:hover {
                border-color: var(--teal);
                background: var(--teal-pale);
            }

            .r-option input:checked+.r-label {
                border-color: var(--teal);
                background: var(--teal-light);
            }

            .r-radio {
                width: 18px;
                height: 18px;
                border-radius: 50%;
                flex-shrink: 0;
                border: 1.5px solid rgba(0, 0, 0, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all .2s;
                margin-top: 1px;
            }

            .r-option input:checked+.r-label .r-radio {
                border-color: var(--teal);
                background: var(--teal);
            }

            .r-dot {
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: white;
                opacity: 0;
                transform: scale(0);
                transition: all .15s;
            }

            .r-option input:checked+.r-label .r-dot {
                opacity: 1;
                transform: scale(1);
            }

            .r-text {
                font-size: .82rem;
                color: var(--ink);
                flex: 1;
                line-height: 1.45;
            }

            .r-option input:checked+.r-label .r-text {
                color: var(--teal-deep);
                font-weight: 500;
            }

            .sdg-grid {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .6rem;
                align-items: stretch;
            }

            .sdg-option {
                position: relative;
                height: 100%;
            }

            .sdg-option input[type="checkbox"] {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }

            .sdg-label {
                display: flex;
                align-items: center;
                gap: .65rem;
                padding: .65rem .9rem;
                border-radius: 8px;
                border: 1.5px solid var(--border);
                background: white;
                cursor: pointer;
                transition: border-color .2s, background .2s;
                user-select: none;
                min-height: 64px;
                height: 100%;
            }

            .sdg-label:hover {
                border-color: var(--teal);
                background: var(--teal-pale);
            }

            .sdg-option input:checked+.sdg-label {
                border-color: var(--teal);
                background: var(--teal-light);
            }

            .sdg-box {
                width: 16px;
                height: 16px;
                border-radius: 3px;
                flex-shrink: 0;
                border: 1.5px solid rgba(0, 0, 0, 0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all .15s;
            }

            .sdg-option input:checked+.sdg-label .sdg-box {
                background: var(--teal);
                border-color: var(--teal);
            }

            .sdg-box svg {
                width: 9px;
                height: 9px;
                stroke: white;
                stroke-width: 3;
                fill: none;
                opacity: 0;
            }

            .sdg-option input:checked+.sdg-label .sdg-box svg {
                opacity: 1;
            }

            .sdg-text {
                font-size: .76rem;
                color: var(--ink);
                line-height: 1.3;
            }

            .sdg-option input:checked+.sdg-label .sdg-text {
                color: var(--teal-deep);
                font-weight: 500;
            }

            .field-error {
                font-size: .71rem;
                color: #b91c1c;
                display: none;
                margin-top: .2rem;
            }

            .form-group.invalid .field-error {
                display: block;
            }

            .form-group.invalid .r-label {
                border-color: #f87171;
            }

            .form-group.invalid .sdg-label {
                border-color: #f87171;
            }

            .form-actions {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                flex-wrap: wrap;
                margin-top: 1.25rem;
            }

            .actions-left {
                display: flex;
                align-items: center;
                gap: .75rem;
            }

            .btn-back {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: .72rem 1.3rem;
                border-radius: 100px;
                border: 1px solid var(--border);
                background: white;
                font-size: .84rem;
                color: var(--muted);
                text-decoration: none;
                font-family: 'DM Sans', sans-serif;
                transition: all .2s;
            }

            .btn-back:hover {
                border-color: var(--teal);
                color: var(--teal);
            }

            .btn-back svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            .btn-save {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: .72rem 1.5rem;
                border-radius: 100px;
                background: white;
                border: 1px solid var(--teal);
                font-size: .84rem;
                font-weight: 500;
                color: var(--teal);
                cursor: pointer;
                font-family: 'DM Sans', sans-serif;
                transition: all .2s;
            }

            .btn-save:hover {
                background: var(--teal-pale);
            }

            .btn-save svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            .btn-next {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: .76rem 1.75rem;
                border-radius: 100px;
                background: var(--teal);
                color: white;
                border: none;
                font-size: .88rem;
                font-weight: 500;
                cursor: pointer;
                font-family: 'DM Sans', sans-serif;
                transition: background .2s, transform .15s;
            }

            .btn-next:hover {
                background: var(--teal-d);
                transform: translateY(-1px);
            }

            .btn-next:active {
                transform: scale(0.98);
            }

            .btn-next svg {
                width: 15px;
                height: 15px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            .toast {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                z-index: 300;
                background: var(--ink);
                color: white;
                padding: .75rem 1.25rem;
                border-radius: 100px;
                font-size: .8rem;
                display: flex;
                align-items: center;
                gap: .6rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
                transform: translateY(20px);
                opacity: 0;
                transition: transform .3s, opacity .3s;
                pointer-events: none;
            }

            .toast.show {
                transform: translateY(0);
                opacity: 1;
            }

            .toast svg {
                width: 14px;
                height: 14px;
                stroke: var(--green);
                stroke-width: 2;
                fill: none;
                flex-shrink: 0;
            }

            @@media (max-width: 900px) {
                .step-bar {
                    display: none;
                }

                .top-nav {
                    padding: 0 1.25rem;
                }

                .hamburger {
                    display: flex;
                }

                .nav-deadline,
                .user-name,
                .nav-logout {
                    display: none;
                }

                .main {
                    padding-top: var(--nav-h);
                }

                .content {
                    padding: 1.5rem 1rem 3rem;
                }

                .step-mini-bar,
                .step-mini-progress {
                    display: none;
                }

                .radio-options.cols-2 {
                    grid-template-columns: 1fr;
                }

                .sdg-grid {
                    grid-template-columns: 1fr;
                }
            }

            @@media (max-width: 560px) {
                .page-title {
                    font-size: 1.65rem;
                }

                .form-card-body {
                    padding: 1.25rem;
                }

                .form-actions {
                    flex-direction: column;
                    align-items: stretch;
                }

                .actions-left {
                    justify-content: space-between;
                }

                .btn-next {
                    justify-content: center;
                    padding: 1rem;
                }

                .toast {
                    left: 1rem;
                    right: 1rem;
                    bottom: 1rem;
                    justify-content: center;
                }
            }
    </style>
</head>

<body>
    <nav class="top-nav">
        <div class="nav-brand"><a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
        <div class="nav-right">
            <div class="nav-deadline">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
                Deadline: <span class="deadline-val">30 June 2026</span>
            </div>
            <div class="nav-user">
                <div class="user-avatar">@initials</div>
                <span class="user-name">@applicantName</span>
            </div>
            <a asp-action="Logout" asp-controller="Account" class="nav-logout">Sign out</a>
            <button class="hamburger" id="hamburger" aria-label="Open menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <div class="step-bar">
        @foreach (var s in steps)
        {
            var st = StepStatus(s.Num);
            <a asp-action="@s.Action" asp-controller="Application" class="step-item @st" title="@s.Name">
                <div class="step-num">
                    <svg viewBox="0 0 12 12">
                        <polyline points="2,6 5,9 10,3" />
                    </svg>
                    <span>@s.Num</span>
                </div>
                <span class="step-name">@s.Name</span>
            </a>
        }
    </div>

    <div class="drawer-overlay" id="drawerOverlay"></div>
    <aside class="side-drawer" id="sideDrawer">
        <div class="drawer-header"><a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
        <div class="drawer-user">
            <div class="drawer-avatar">@initials</div>
            <div>
                <div class="drawer-uname">@applicantName</div>
                <div class="drawer-uemail">NPI 4.0 Applicant</div>
            </div>
        </div>
        <div class="drawer-steps">
            <span class="drawer-step-label">Application Steps</span>
            @foreach (var s in steps)
            {
                var st = StepStatus(s.Num);
                var label = st == "completed" ? "Completed" : st == "active" ? "In progress" : "Locked";
                <a asp-action="@s.Action" asp-controller="Application" class="drawer-item @st"
                   style="@(st == "locked" ? "pointer-events:none;opacity:.4" : null)">
                    <div class="drawer-item-num">
                        <svg viewBox="0 0 12 12">
                            <polyline points="2,6 5,9 10,3" />
                        </svg>
                        <span>@s.Num</span>
                    </div>
                    <div>
                        <div class="drawer-item-name">@s.Name</div>
                        <div class="drawer-item-status">@label</div>
                    </div>
                </a>
            }
        </div>
        <div class="drawer-footer">
            <a asp-action="Logout" asp-controller="Account" class="drawer-logout">
                <svg viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sign out
            </a>
        </div>
    </aside>

    <main class="main">
        <div class="content">
            <div class="page-header">
                <div class="breadcrumb">
                    <a asp-action="Dashboard" asp-controller="Application">Dashboard</a>
                    <svg viewBox="0 0 24 24">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                    <span>Sustainability</span>
                </div>
                <h1 class="page-title">Sustainability</h1>
                <p class="page-sub">Tell us how your business integrates sustainability, addresses climate change, and
                    aligns with the UN Sustainable Development Goals.</p>
                </div>

                <div class="step-mini">
                    <div class="step-mini-dot">8</div>
                    <div>
                        <div class="step-mini-label">Step 8 of 10</div>
                        <div class="step-mini-name">Sustainability</div>
                    </div>
                    <div class="step-mini-spacer"></div>
                    <span class="step-mini-progress">Step 8 of 10</span>
                    <div class="step-mini-bar">
                        <div class="step-mini-fill"></div>
                    </div>
                </div>

                <form asp-action="SaveSustainability" asp-controller="Application" method="post" id="sustainForm"
                      novalidate>
                    @Html.AntiForgeryToken()

                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon">
                                <svg viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" />
                                    <path d="M12 8v4l3 3" />
                                </svg>
                            </div>
                            <div>
                                <div class="form-card-title">SDG Alignment</div>
                                <div class="form-card-desc">Which UN Sustainable Development Goals does your business
                                    address?</div>
                                </div>
                            </div>
                            <div class="form-card-body">
                                <div class="form-group" id="grp-sdg">
                                    <label class="field-label">
                                        Does your business align with the UN Sustainable Development Goals (SDGs)? If so, which
                                        ones?
                                        <span class="label-req">*</span>
                                        <span class="label-opt">(select all that apply)</span>
                                    </label>
                                    <div class="sdg-grid">
                                        @foreach (var sdg in sdgList)
                                        {
                                            var id = SafeId("sdg-", sdg);
                                            <div class="sdg-option">
                                                <input type="checkbox" id="@id" name="SdgAlignment" value="@sdg"
                                                       checked="@(savedSdgs.Contains(sdg))" />
                                                <label class="sdg-label" for="@id">
                                                    <div class="sdg-box"><svg viewBox="0 0 12 12">
                                                        <polyline points="2,6 5,9 10,3" />
                                                    </svg></div>
                                                    <span class="sdg-text">@sdg</span>
                                                </label>
                                            </div>
                                        }
                                    </div>
                                    <div class="field-error">Please select at least one SDG.</div>
                                </div>
                            </div>
                        </div>

                        <div class="form-card">
                            <div class="form-card-header">
                                <div class="form-card-icon">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="form-card-title">Sustainability Practices</div>
                                    <div class="form-card-desc">How sustainability is embedded into your operations and
                                        products.</div>
                                    </div>
                                </div>
                                <div class="form-card-body">
                                    <div class="form-group" id="grp-replicability">
                                        <label class="field-label">Can your business model be replicated in new regions? <span
                                            class="label-req">*</span></label>
                                            <div class="radio-options cols-2">
                                                @foreach (var val in new[] {
                                "Already scaled to 5+ regions",
                                "Designed for easy replication",
                                "Needs adaptation",
                                "Not replicable"
                            })
                                                {
                                                    var id = SafeId("br-", val);
                                                    <div class="r-option">
                                                        <input type="radio" id="@id" name="BusinessReplicability" value="@val"
                                                               checked="@(IsSelected(businessReplicability, val))" />
                                                        <label class="r-label" for="@id">
                                                            <div class="r-radio">
                                                                <div class="r-dot"></div>
                                                            </div>
                                                            <span class="r-text">@val</span>
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                            <div class="field-error">Please select an option.</div>
                                        </div>

                                        <div class="form-group" id="grp-integration">
                                            <label class="field-label">How does your business integrate sustainability into its
                                                operations, products, or services? <span class="label-req">*</span></label>
                                                <div class="radio-options cols-2">
                                                    @foreach (var val in new[] {
                                "Eco-friendly materials & waste reduction",
                                "Sustainable sourcing & ethical partnerships",
                                "Energy-efficient processes & technology",
                                "None"
                            })
                                                    {
                                                        var id = SafeId("si-", val);
                                                        <div class="r-option">
                                                            <input type="radio" id="@id" name="SustainabilityIntegration" value="@val"
                                                                   checked="@(IsSelected(sustainabilityIntegration, val))" />
                                                            <label class="r-label" for="@id">
                                                                <div class="r-radio">
                                                                    <div class="r-dot"></div>
                                                                </div>
                                                                <span class="r-text">@val</span>
                                                            </label>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="field-error">Please select an option.</div>
                                            </div>

                                            <div class="form-group" id="grp-energywaste">
                                                <label class="field-label">What measures do you take to minimize energy consumption and
                                                    reduce waste? <span class="label-req">*</span></label>
                                                    <div class="radio-options cols-2">
                                                        @foreach (var val in new[] {
                                "Optimized supply chain & resource management",
                                "Use of renewable energy sources",
                                "Waste recycling & upcycling initiatives",
                                "None"
                            })
                                                        {
                                                            var id = SafeId("ew-", val);
                                                            <div class="r-option">
                                                                <input type="radio" id="@id" name="EnergyWasteReduction" value="@val"
                                                                       checked="@(IsSelected(energyWasteReduction, val))" />
                                                                <label class="r-label" for="@id">
                                                                    <div class="r-radio">
                                                                        <div class="r-dot"></div>
                                                                    </div>
                                                                    <span class="r-text">@val</span>
                                                                </label>
                                                            </div>
                                                        }
                                                    </div>
                                                    <div class="field-error">Please select an option.</div>
                                                </div>

                                                <div class="form-group" id="grp-sustaintech">
                                                    <label class="field-label">What innovations or emerging technologies are you leveraging to
                                                        enhance sustainability? <span class="label-req">*</span></label>
                                                        <div class="radio-options cols-2">
                                                            @foreach (var val in new[] {
                                "Renewable Energy & Smart grids",
                                "Biodegradable solutions",
                                "Waste-to-energy & circular economy solutions",
                                "None"
                            })
                                                            {
                                                                var id = SafeId("st-", val);
                                                                <div class="r-option">
                                                                    <input type="radio" id="@id" name="SustainabilityTechnology" value="@val"
                                                                           checked="@(IsSelected(sustainabilityTechnology, val))" />
                                                                    <label class="r-label" for="@id">
                                                                        <div class="r-radio">
                                                                            <div class="r-dot"></div>
                                                                        </div>
                                                                        <span class="r-text">@val</span>
                                                                    </label>
                                                                </div>
                                                            }
                                                        </div>
                                                        <div class="field-error">Please select an option.</div>
                                                    </div>

                                                    <div class="form-group" id="grp-scalingsustain">
                                                        <label class="field-label">What strategies do you have in place to scale your business while
                                                            maintaining quality and sustainability? <span class="label-req">*</span></label>
                                                            <div class="radio-options cols-2">
                                                                @foreach (var val in new[] {
                                "Collaborations & Partnerships",
                                "Quality control & Continuous training",
                                "Automated processes & smart technology",
                                "None"
                            })
                                                                {
                                                                    var id = SafeId("ss-", val);
                                                                    <div class="r-option">
                                                                        <input type="radio" id="@id" name="ScalingWithSustainability" value="@val"
                                                                               checked="@(IsSelected(scalingWithSustainability, val))" />
                                                                        <label class="r-label" for="@id">
                                                                            <div class="r-radio">
                                                                                <div class="r-dot"></div>
                                                                            </div>
                                                                            <span class="r-text">@val</span>
                                                                        </label>
                                                                    </div>
                                                                }
                                                            </div>
                                                            <div class="field-error">Please select an option.</div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="form-card">
                                                    <div class="form-card-header">
                                                        <div class="form-card-icon">
                                                            <svg viewBox="0 0 24 24">
                                                                <path
                                                                d="M12 2a10 10 0 0 1 10 10c0 5.52-4.48 10-10 10S2 17.52 2 12c0-2.76 1.12-5.26 2.93-7.07" />
                                                                <path d="M12 6v6l4 2" />
                                                            </svg>
                                                        </div>
                                                        <div>
                                                            <div class="form-card-title">Climate &amp; Digital Access</div>
                                                            <div class="form-card-desc">How your business responds to climate challenges and promotes
                                                                digital inclusion.</div>
                                                            </div>
                                                        </div>
                                                        <div class="form-card-body">
                                                            <div class="form-group" id="grp-climate">
                                                                <label class="field-label">How does your business address the challenges of climate change?
                                                                    <span class="label-req">*</span></label>
                                                                    <div class="radio-options cols-2">
                                                                        @foreach (var val in new[] {
                                "Community education & advocacy",
                                "Sustainable sourcing & eco-friendly materials",
                                "Climate-smart technology & innovations",
                                "None"
                            })
                                                                        {
                                                                            var id = SafeId("cc-", val);
                                                                            <div class="r-option">
                                                                                <input type="radio" id="@id" name="ClimateChangeApproach" value="@val"
                                                                                       checked="@(IsSelected(climateChangeApproach, val))" />
                                                                                <label class="r-label" for="@id">
                                                                                    <div class="r-radio">
                                                                                        <div class="r-dot"></div>
                                                                                    </div>
                                                                                    <span class="r-text">@val</span>
                                                                                </label>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                    <div class="field-error">Please select an option.</div>
                                                                </div>

                                                                <div class="form-group" id="grp-digitalaccess">
                                                                    <label class="field-label">What steps are you taking to ensure digital accessibility for
                                                                        underprivileged communities? <span class="label-req">*</span></label>
                                                                        <div class="radio-options cols-2">
                                                                            @foreach (var val in new[] {
                                "Partnerships for subsidized tech & internet",
                                "Training & digital literacy initiatives",
                                "Low-cost or free digital access programs",
                                "Mobile-friendly & offline solutions"
                            })
                                                                            {
                                                                                var id = SafeId("da-", val);
                                                                                <div class="r-option">
                                                                                    <input type="radio" id="@id" name="DigitalAccessibility" value="@val"
                                                                                           checked="@(IsSelected(digitalAccessibility, val))" />
                                                                                    <label class="r-label" for="@id">
                                                                                        <div class="r-radio">
                                                                                            <div class="r-dot"></div>
                                                                                        </div>
                                                                                        <span class="r-text">@val</span>
                                                                                    </label>
                                                                                </div>
                                                                            }
                                                                        </div>
                                                                        <div class="field-error">Please select an option.</div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <div class="form-actions">
                                                                <div class="actions-left">
                                                                    <a asp-action="Commercial2" asp-controller="Application" class="btn-back">
                                                                        <svg viewBox="0 0 24 24">
                                                                            <path d="M19 12H5M12 5l-7 7 7 7" />
                                                                        </svg>
                                                                        Back
                                                                    </a>
                                                                    <button type="button" class="btn-save" id="saveBtn">
                                                                        <svg viewBox="0 0 24 24">
                                                                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" />
                                                                            <polyline points="17 21 17 13 7 13 7 21" />
                                                                            <polyline points="7 3 7 8 15 8" />
                                                                        </svg>
                                                                        Save draft
                                                                    </button>
                                                                </div>
                                                                <button type="submit" class="btn-next" id="nextBtn">
                                                                    Save &amp; Continue
                                                                    <svg viewBox="0 0 24 24">
                                                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                                                    </svg>
                                                                </button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </main>

                                                <div class="toast" id="toast">
                                                    <svg viewBox="0 0 24 24">
                                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                                        <polyline points="22 4 12 14.01 9 11.01" />
                                                    </svg>
                                                    <span id="toastMsg">Draft saved</span>
                                                </div>

                                                <script>
                                                        const hamburger = document.getElementById('hamburger');
                                                        const sideDrawer = document.getElementById('sideDrawer');
                                                        const drawerOverlay = document.getElementById('drawerOverlay');
                                                        const openDrawer = () => { sideDrawer.classList.add('open'); drawerOverlay.style.display = 'block'; setTimeout(() => drawerOverlay.classList.add('open'), 10); hamburger.classList.add('open'); document.body.style.overflow = 'hidden'; };
                                                        const closeDrawer = () => { sideDrawer.classList.remove('open'); drawerOverlay.classList.remove('open'); setTimeout(() => drawerOverlay.style.display = '', 300); hamburger.classList.remove('open'); document.body.style.overflow = ''; };
                                                        hamburger.addEventListener('click', () => sideDrawer.classList.contains('open') ? closeDrawer() : openDrawer());
                                                        drawerOverlay.addEventListener('click', closeDrawer);

                                                        function setInvalid(id) { document.getElementById(id)?.classList.add('invalid'); }
                                                        function clearInvalid(id) { document.getElementById(id)?.classList.remove('invalid'); }

                                                        const radioGroups = {
                                                            BusinessReplicability: 'grp-replicability',
                                                            SustainabilityIntegration: 'grp-integration',
                                                            EnergyWasteReduction: 'grp-energywaste',
                                                            SustainabilityTechnology: 'grp-sustaintech',
                                                            ScalingWithSustainability: 'grp-scalingsustain',
                                                            ClimateChangeApproach: 'grp-climate',
                                                            DigitalAccessibility: 'grp-digitalaccess'
                                                        };

                                                        Object.keys(radioGroups).forEach(name => {
                                                            document.querySelectorAll(`input[name="${name}"]`).forEach(r =>
                                                                r.addEventListener('change', () => clearInvalid(radioGroups[name]))
                                                            );
                                                        });

                                                        document.querySelectorAll('input[name="SdgAlignment"]').forEach(c =>
                                                            c.addEventListener('change', () => clearInvalid('grp-sdg'))
                                                        );

                                                        function validate() {
                                                            let ok = true;

                                                            if (!document.querySelector('input[name="SdgAlignment"]:checked')) {
                                                                setInvalid('grp-sdg');
                                                                ok = false;
                                                            }

                                                            Object.entries(radioGroups).forEach(([name, grp]) => {
                                                                if (!document.querySelector(`input[name="${name}"]:checked`)) {
                                                                    setInvalid(grp);
                                                                    ok = false;
                                                                }
                                                            });

                                                            if (!ok) {
                                                                document.querySelector('.invalid')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                                            }

                                                            return ok;
                                                        }

                                                        function showToast(msg, isError) {
                                                            const t = document.getElementById('toast');
                                                            t.querySelector('svg').style.stroke = isError ? '#f87171' : 'var(--green)';
                                                            document.getElementById('toastMsg').textContent = msg;
                                                            t.classList.add('show');
                                                            setTimeout(() => t.classList.remove('show'), 3000);
                                                        }

                                                        document.getElementById('saveBtn').addEventListener('click', async () => {
                                                            const btn = document.getElementById('saveBtn');
                                                            btn.textContent = 'Saving...';
                                                            btn.disabled = true;
                                                            try {
                                                                const fd = new FormData(document.getElementById('sustainForm'));
                                                                const res = await fetch('/Application/SaveSustainabilityDraft', { method: 'POST', body: fd });
                                                                showToast(res.ok ? 'Draft saved' : 'Could not save', !res.ok);
                                                            } catch {
                                                                showToast('Could not save', true);
                                                            } finally {
                                                                btn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save draft';
                                                                btn.disabled = false;
                                                            }
                                                        });

                                                        document.getElementById('sustainForm').addEventListener('submit', function (e) {
                                                            if (!validate()) {
                                                                e.preventDefault();
                                                                return;
                                                            }
                                                            const btn = document.getElementById('nextBtn');
                                                            btn.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Saving...';
                                                            btn.disabled = true;
                                                        });
                                                </script>
                                            </body>

                                        </html>
