@{
    ViewData["Title"] = "Additional Information — NSIA Prize for Innovation";
    Layout = null;

    var applicantName = ViewBag.ApplicantName as string ?? "";
    var completedStep = (int)(ViewBag.CompletedStep ?? 9);
    var initials = string.Join("", applicantName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w =>
w[0]));

    var steps = new[] {
        new { Num = 1, Name = "Pre-Checklist", Action = "PreChecklist" },
        new { Num = 2, Name = "Personal Info", Action = "PersonalInfo" },
        new { Num = 3, Name = "Company Info", Action = "CompanyInfo" },
        new { Num = 4, Name = "Team Info", Action = "TeamInfo" },
        new { Num = 5, Name = "Product & Growth", Action = "ProductInfo" },
        new { Num = 6, Name = "Commercial I", Action = "Commercial1" },
        new { Num = 7, Name = "Commercial II", Action = "Commercial2" },
        new { Num = 8, Name = "Sustainability", Action = "Sustainability" },
        new { Num = 9, Name = "Impact", Action = "Impact" },
        new { Num = 10, Name = "Additional", Action = "Additional" },
    };

    string StepStatus(int num)
    {
        if (num <= completedStep) return "completed";
        if (num == completedStep + 1) return "active";
        return "locked";
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --teal-pale: #F0FAF9;
                --green: #7BC144;
                --green-dark: #5a9130;
                --ink: #1C2B2A;
                --cream: #F5F9F8;
                --off: #EEF4F3;
                --muted: #4A6260;
                --border: rgba(45, 184, 176, 0.2);
                --nav-h: 62px;
                --step-h: 56px;
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--off);
                color: var(--ink);
                min-height: 100vh;
            }

            .top-nav {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 200;
                height: var(--nav-h);
                background: white;
                display: flex;
                align-items: center;
                padding: 0 2rem;
                justify-content: space-between;
            }

            .top-nav::after {
                content: '';
                position: absolute;
                inset: 0;
                pointer-events: none;
                background: radial-gradient(ellipse at 30% 50%, rgba(255, 255, 255, 0.08) 0%, transparent 60%);
            }

            .nav-brand {
                display: flex;
                align-items: center;
                position: relative;
                z-index: 1;
            }

            .nav-brand img {
                height: 32px;
                width: auto;
            }

            .nav-right {
                display: flex;
                align-items: center;
                gap: 1.25rem;
                position: relative;
                z-index: 1;
            }

            .nav-deadline {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 11px;
                color: var(--ink);
            }

            .nav-deadline svg {
                width: 13px;
                height: 13px;
                stroke: var(--ink);
                stroke-width: 1.75;
                fill: none;
            }

            .deadline-val {
                color: var(--ink);
                font-weight: 600;
            }

            .nav-user {
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .user-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                background: var(--ink);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .user-name {
                font-size: 12px;
                color: var(--ink);
            }

            .nav-logout {
                font-size: 11px;
                color: var(--ink);
                text-decoration: none;
                padding: .3rem .7rem;
                border: 1px solid var(--green-dark);
                border-radius: 100px;
                transition: all .2s;
                white-space: nowrap;
            }

            .nav-logout:hover {
                color: white;
                border-color: var(--teal-dark);
                background: var(--ink);
            }

            .hamburger {
                display: none;
                flex-direction: column;
                gap: 4px;
                background: none;
                border: none;
                cursor: pointer;
                padding: 4px;
                position: relative;
                z-index: 1;
            }

            .hamburger span {
                display: block;
                width: 22px;
                height: 2px;
                background: var(--ink);
                border-radius: 2px;
                transition: transform .3s, opacity .3s;
            }

            .hamburger.open span:nth-child(1) {
                transform: translateY(6px) rotate(45deg);
            }

            .hamburger.open span:nth-child(2) {
                opacity: 0;
            }

            .hamburger.open span:nth-child(3) {
                transform: translateY(-6px) rotate(-45deg);
            }

            .step-bar {
                position: fixed;
                top: var(--nav-h);
                left: 0;
                right: 0;
                z-index: 190;
                height: var(--step-h);
                background: white;
                border-bottom: 1px solid var(--green);
                display: flex;
                align-items: stretch;
                overflow: hidden;
            }

            .step-item {
                flex: 1;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                padding: 0 .35rem;
                text-decoration: none;
                color: var(--green);
                border-right: 1px solid var(--green);
                position: relative;
                transition: background .2s;
                min-width: 0;
            }

            .step-item:last-child {
                border-right: none;
            }

            .step-item::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 2px;
                background: transparent;
                transition: background .2s;
            }

            .step-item:hover {
                background: var(--teal-pale);
            }

            .step-item.completed .step-num {
                background: var(--green);
                border-color: var(--green);
                color: white;
            }

            .step-item.completed .step-num svg {
                display: block;
            }

            .step-item.completed .step-num span {
                display: none;
            }

            .step-item.completed .step-name {
                color: var(--green);
            }

            .step-item.completed::after {
                background: var(--green);
            }

            .step-item.active {
                background: var(--teal-pale);
            }

            .step-item.active .step-num {
                background: var(--green);
                border-color: var(--green);
                color: white;
            }

            .step-item.active .step-name {
                color: var(--green);
                font-weight: 500;
            }

            .step-item.active::after {
                background: var(--green);
            }

            .step-num {
                width: 20px;
                height: 20px;
                border-radius: 50%;
                flex-shrink: 0;
                border: 1.5px solid rgba(0, 0, 0, 0.15);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 9px;
                font-weight: 500;
                color: var(--muted);
            }

            .step-num svg {
                width: 9px;
                height: 9px;
                stroke: white;
                stroke-width: 3;
                fill: none;
                display: none;
            }

            .step-name {
                font-size: 10.5px;
                color: var(--muted);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            /* ── DRAWER ── */
            .drawer-overlay {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 150;
                background: var(--teal-light);
                opacity: 0;
                transition: opacity .3s;
            }

            .drawer-overlay.open {
                opacity: 1;
            }

            .side-drawer {
                position: fixed;
                top: 0;
                left: -280px;
                bottom: 0;
                z-index: 160;
                width: 280px;
                background: var(--teal-light);
                display: flex;
                flex-direction: column;
                transition: left .3s cubic-bezier(0.4, 0, 0.2, 1);
                overflow-y: auto;
            }

            .side-drawer.open {
                left: 0;
            }

            .drawer-header {
                padding: 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            }

            .drawer-header img {
                height: 30px;
                width: auto;
                filter: brightness(0) invert(1);
            }

            .drawer-user {
                padding: 1rem 1.25rem;
                border-bottom: 1px solid rgba(255, 255, 255, 0.08);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .drawer-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: var(--teal);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 12px;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
            }

            .drawer-uname {
                font-size: 13px;
                font-weight: 500;
                color: var(--ink);
            }

            .drawer-uemail {
                font-size: 11px;
                color: var(--ink);
            }

            .drawer-steps {
                padding: .75rem 0;
                flex: 1;
            }

            .drawer-step-label {
                font-size: 10px;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .1em;
                text-transform: uppercase;
                padding: .5rem 1.25rem .25rem;
                display: block;
            }

            .drawer-item {
                display: flex;
                align-items: center;
                gap: .9rem;
                padding: .75rem 1.25rem;
                text-decoration: none;
                color: var(--ink);
                transition: background .2s, color .2s;
                position: relative;
            }

            .drawer-item:hover {
                background: rgba(255, 255, 255, 0.04);
                color: var(--teal-dark);
            }

            .drawer-item.active {
                background: rgba(45, 184, 176, 0.15);
                color: var(--ink);
            }

            .drawer-item.active::before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                bottom: 0;
                width: 3px;
                background: var(--teal);
                border-radius: 0 2px 2px 0;
            }

            .drawer-item-num {
                width: 24px;
                height: 24px;
                border-radius: 50%;
                flex-shrink: 0;
                border: 1.5px solid rgba(255, 255, 255, 0.15);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 10px;
                font-weight: 500;
            }

            .drawer-item.completed .drawer-item-num {
                background: var(--teal);
                border-color: var(--teal);
            }

            .drawer-item.active .drawer-item-num {
                background: var(--teal);
                border-color: var(--teal);
            }

            .drawer-item-num svg {
                width: 10px;
                height: 10px;
                stroke: white;
                stroke-width: 3;
                fill: none;
                display: none;
            }

            .drawer-item.completed .drawer-item-num svg {
                display: block;
            }

            .drawer-item.completed .drawer-item-num span {
                display: none;
            }

            .drawer-item-name {
                font-size: 13px;
            }

            .drawer-item-status {
                font-size: 10px;
                color: var(--ink);
            }

            .drawer-item.completed .drawer-item-status {
                color: var(--teal);
            }

            .drawer-item.active .drawer-item-status {
                color: rgba(45, 184, 176, 0.8);
            }

            .drawer-footer {
                padding: 1rem 1.25rem;
                border-top: 1px solid rgba(255, 255, 255, 0.08);
            }

            .drawer-logout {
                display: flex;
                align-items: center;
                gap: .6rem;
                font-size: 12px;
                color: var(--ink);
                text-decoration: none;
                transition: color .2s;
            }

            .drawer-logout svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            .drawer-logout:hover {
                color: var(--muted);
            }

            .main {
                padding-top: calc(var(--nav-h) + var(--step-h));
                min-height: 100vh;
            }

            .content {
                max-width: 760px;
                margin: 0 auto;
                padding: 2.5rem 2rem 4rem;
            }

            .page-header {
                margin-bottom: 2rem;
            }

            .breadcrumb {
                display: flex;
                align-items: center;
                gap: .4rem;
                font-size: 11px;
                color: var(--muted);
                margin-bottom: .75rem;
                flex-wrap: wrap;
            }

            .breadcrumb a {
                color: var(--teal);
                text-decoration: none;
            }

            .breadcrumb a:hover {
                text-decoration: underline;
            }

            .breadcrumb svg {
                width: 10px;
                height: 10px;
                stroke: var(--muted);
                stroke-width: 2;
                fill: none;
            }

            .page-title {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                font-size: 2rem;
                font-weight: 700;
                color: var(--ink);
                line-height: 1.1;
                margin-bottom: .35rem;
            }

            .page-sub {
                font-size: .84rem;
                color: var(--muted);
                line-height: 1.65;
            }

            .step-mini {
                display: flex;
                align-items: center;
                gap: .75rem;
                background: white;
                border-radius: 8px;
                border: 1px solid var(--border);
                padding: .85rem 1.25rem;
                margin-bottom: 2rem;
            }

            .step-mini-dot {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                flex-shrink: 0;
                background: var(--teal);
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 600;
            }

            .step-mini-label {
                font-size: 10px;
                color: var(--muted);
                text-transform: uppercase;
                letter-spacing: .07em;
            }

            .step-mini-name {
                font-size: .85rem;
                font-weight: 500;
                color: var(--ink);
            }

            .step-mini-spacer {
                flex: 1;
            }

            .step-mini-progress {
                font-size: 11px;
                color: var(--muted);
                white-space: nowrap;
            }

            .step-mini-bar {
                width: 120px;
                height: 4px;
                background: var(--off);
                border-radius: 10px;
                overflow: hidden;
                flex-shrink: 0;
            }

            .step-mini-fill {
                height: 100%;
                background: linear-gradient(to right, var(--teal), var(--green));
                border-radius: 10px;
                width: 100%;
            }

            .form-card {
                background: white;
                border-radius: 12px;
                border: 1px solid var(--border);
                overflow: hidden;
                margin-bottom: 1.25rem;
            }

            .form-card-header {
                padding: 1.1rem 1.75rem;
                border-bottom: 1px solid var(--border);
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            .form-card-icon {
                width: 36px;
                height: 36px;
                border-radius: 8px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background: var(--teal-light);
            }

            .form-card-icon svg {
                width: 17px;
                height: 17px;
                stroke: var(--teal);
                stroke-width: 1.75;
                fill: none;
            }

            .form-card-title {
                font-size: .92rem;
                font-weight: 500;
                color: var(--ink);
                margin-bottom: 2px;
            }

            .form-card-title .req {
                color: #e53e3e;
                margin-left: 2px;
            }

            .form-card-desc {
                font-size: .74rem;
                color: var(--muted);
                line-height: 1.4;
            }

            .form-card-body {
                padding: 1.75rem;
                display: flex;
                flex-direction: column;
                gap: 1.35rem;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: .38rem;
            }

            label.field-label {
                font-size: .75rem;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .02em;
            }

            .label-opt {
                font-size: .68rem;
                color: var(--muted);
                font-weight: 400;
                margin-left: 4px;
            }

            textarea {
                width: 100%;
                padding: .85rem 1rem;
                border: 1px solid var(--border);
                border-radius: 7px;
                font-size: .85rem;
                font-family: 'DM Sans', sans-serif;
                background: white;
                color: var(--ink);
                outline: none;
                resize: vertical;
                min-height: 120px;
                line-height: 1.7;
                transition: border-color .2s, box-shadow .2s;
            }

            textarea:focus {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(45, 184, 176, 0.12);
            }

            textarea::placeholder {
                color: #aab5af;
            }

            .char-count {
                font-size: .68rem;
                color: var(--muted);
                text-align: right;
                margin-top: .25rem;
            }

            .upload-zone {
                border: 2px dashed rgba(45, 184, 176, 0.35);
                border-radius: 10px;
                padding: 2rem;
                text-align: center;
                background: var(--teal-pale);
                cursor: pointer;
                transition: border-color .2s, background .2s;
                position: relative;
            }

            .upload-zone:hover,
            .upload-zone.drag {
                border-color: var(--teal);
                background: var(--teal-light);
            }

            .upload-zone input[type="file"] {
                position: absolute;
                inset: 0;
                opacity: 0;
                cursor: pointer;
                width: 100%;
                height: 100%;
            }

            .upload-zone.error {
                border-color: #f87171;
                background: #fff5f5;
            }

            .upload-error {
                font-size: .71rem;
                color: #b91c1c;
                display: none;
                margin-top: .4rem;
            }

            .upload-error.show {
                display: block;
            }

            .upload-icon {
                width: 44px;
                height: 44px;
                border-radius: 10px;
                background: rgba(45, 184, 176, 0.12);
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 1rem;
            }

            .upload-icon svg {
                width: 20px;
                height: 20px;
                stroke: var(--teal);
                stroke-width: 1.75;
                fill: none;
            }

            .upload-title {
                font-size: .88rem;
                font-weight: 500;
                color: var(--ink);
                margin-bottom: .25rem;
            }

            .upload-sub {
                font-size: .75rem;
                color: var(--muted);
            }

            .doc-type-bar {
                display: flex;
                gap: .75rem;
                flex-wrap: wrap;
                margin-top: .75rem;
            }

            .doc-type-btn {
                padding: .35rem .85rem;
                border-radius: 100px;
                font-size: .76rem;
                font-weight: 500;
                border: 1.5px solid var(--border);
                background: white;
                cursor: pointer;
                color: var(--muted);
                font-family: 'DM Sans', sans-serif;
                transition: all .2s;
            }

            .doc-type-btn.active,
            .doc-type-btn:hover {
                background: var(--teal);
                border-color: var(--teal);
                color: white;
            }

            .file-list {
                display: flex;
                flex-direction: column;
                gap: .75rem;
                margin-top: .5rem;
            }

            .file-item {
                display: flex;
                align-items: center;
                gap: .9rem;
                padding: .85rem 1.1rem;
                background: var(--teal-pale);
                border: 1px solid var(--border);
                border-radius: 8px;
            }

            .file-icon {
                width: 34px;
                height: 34px;
                border-radius: 7px;
                flex-shrink: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                background: var(--teal-light);
            }

            .file-icon svg {
                width: 15px;
                height: 15px;
                stroke: var(--teal);
                stroke-width: 1.75;
                fill: none;
            }

            .file-info {
                flex: 1;
                min-width: 0;
            }

            .file-name {
                font-size: .82rem;
                font-weight: 500;
                color: var(--ink);
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .file-meta {
                font-size: .7rem;
                color: var(--muted);
                margin-top: 1px;
            }

            .file-remove {
                background: none;
                border: none;
                cursor: pointer;
                color: #dc2626;
                padding: 4px;
                display: flex;
                opacity: .7;
                transition: opacity .2s;
                flex-shrink: 0;
            }

            .file-remove:hover {
                opacity: 1;
            }

            .file-remove svg {
                width: 15px;
                height: 15px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            .submit-warning {
                background: rgba(245, 158, 11, 0.08);
                border: 1px solid rgba(245, 158, 11, 0.3);
                border-radius: 10px;
                padding: 1.25rem 1.5rem;
                display: flex;
                align-items: flex-start;
                gap: .9rem;
                margin-bottom: 1.25rem;
            }

            .submit-warning svg {
                width: 18px;
                height: 18px;
                stroke: #d97706;
                stroke-width: 1.75;
                fill: none;
                flex-shrink: 0;
                margin-top: 1px;
            }

            .submit-warning-text {
                font-size: .82rem;
                color: #92400e;
                line-height: 1.65;
            }

            .submit-warning-text strong {
                color: #78350f;
                font-weight: 600;
            }

            .checklist {
                display: flex;
                flex-direction: column;
                gap: .65rem;
                margin-top: 1.25rem;
            }

            .check-item {
                display: flex;
                align-items: center;
                gap: .75rem;
                font-size: .83rem;
                color: var(--ink);
            }

            .check-item svg {
                width: 16px;
                height: 16px;
                stroke: var(--teal);
                stroke-width: 2.5;
                fill: none;
                flex-shrink: 0;
            }

            .terms-row {
                display: flex;
                align-items: flex-start;
                gap: .75rem;
                padding: .85rem 1.1rem;
                border-radius: 8px;
                border: 1.5px solid var(--border);
                background: white;
                transition: border-color .2s;
            }

            .terms-row:has(input:checked) {
                border-color: var(--teal);
                background: var(--teal-pale);
            }

            .terms-row input[type="checkbox"] {
                width: 17px;
                height: 17px;
                accent-color: var(--teal);
                flex-shrink: 0;
                margin-top: 1px;
                cursor: pointer;
            }

            .terms-row input[type="checkbox"]:disabled {
                cursor: not-allowed;
                opacity: .55;
            }

            .terms-row label {
                font-size: .82rem;
                color: var(--ink);
                line-height: 1.55;
                cursor: pointer;
            }

            .form-group.invalid .terms-row {
                border-color: #f87171;
            }

            .field-error {
                font-size: .71rem;
                color: #b91c1c;
                display: none;
                margin-top: .2rem;
            }

            .form-group.invalid .field-error {
                display: block;
            }

            .policy-link-btn {
                background: none;
                border: none;
                padding: 0;
                margin: 0 0 0 4px;
                color: var(--teal);
                font: inherit;
                font-weight: 500;
                cursor: pointer;
                text-decoration: underline;
            }

            .policy-status {
                display: inline-block;
                margin-left: 8px;
                font-size: .72rem;
                color: var(--muted);
            }

            .policy-status.done {
                color: var(--teal-deep);
                font-weight: 500;
            }

            .policy-modal {
                position: fixed;
                inset: 0;
                z-index: 500;
                display: none;
            }

            .policy-modal.open {
                display: block;
            }

            .policy-modal-backdrop {
                position: absolute;
                inset: 0;
                background: rgba(0, 0, 0, .55);
            }

            .policy-modal-dialog {
                position: relative;
                width: min(900px, calc(100vw - 2rem));
                height: min(85vh, 760px);
                margin: 4vh auto 0;
                background: white;
                border-radius: 12px;
                overflow: hidden;
                display: flex;
                flex-direction: column;
                box-shadow: 0 12px 40px rgba(0, 0, 0, .22);
            }

            .policy-modal-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 1rem 1.25rem;
                border-bottom: 1px solid var(--border);
            }

            .policy-modal-header h3 {
                font-size: .95rem;
                font-weight: 600;
                color: var(--ink);
            }

            .policy-close {
                border: none;
                background: none;
                font-size: 1.4rem;
                line-height: 1;
                cursor: pointer;
                color: var(--muted);
            }

            .policy-modal-body {
                flex: 1;
                background: #f7f7f7;
            }

            .policy-frame {
                width: 100%;
                height: 100%;
                border: 0;
                background: white;
            }

            .policy-modal-footer {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                padding: 1rem 1.25rem;
                border-top: 1px solid var(--border);
            }

            .policy-countdown {
                font-size: .82rem;
                color: var(--muted);
            }

            .form-actions {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 1rem;
                flex-wrap: wrap;
                margin-top: 1.25rem;
            }

            .actions-left {
                display: flex;
                align-items: center;
                gap: .75rem;
            }

            .btn-back {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: .72rem 1.3rem;
                border-radius: 100px;
                border: 1px solid var(--border);
                background: white;
                font-size: .84rem;
                color: var(--muted);
                text-decoration: none;
                font-family: 'DM Sans', sans-serif;
                transition: all .2s;
            }

            .btn-back:hover {
                border-color: var(--teal);
                color: var(--teal);
            }

            .btn-back svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            .btn-save {
                display: inline-flex;
                align-items: center;
                gap: 7px;
                padding: .72rem 1.5rem;
                border-radius: 100px;
                background: white;
                border: 1px solid var(--teal);
                font-size: .84rem;
                font-weight: 500;
                color: var(--teal);
                cursor: pointer;
                font-family: 'DM Sans', sans-serif;
                transition: all .2s;
            }

            .btn-save:hover {
                background: var(--teal-pale);
            }

            .btn-save svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            .btn-submit {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                padding: .85rem 2.25rem;
                border-radius: 100px;
                background: linear-gradient(135deg, var(--teal), var(--teal-d));
                color: white;
                border: none;
                font-size: .92rem;
                font-weight: 600;
                cursor: pointer;
                font-family: 'DM Sans', sans-serif;
                transition: transform .2s, box-shadow .2s;
                box-shadow: 0 4px 16px rgba(45, 184, 176, 0.3);
            }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(45, 184, 176, 0.4);
            }

            .btn-submit:active {
                transform: scale(0.98);
            }

            .btn-submit svg {
                width: 16px;
                height: 16px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            .toast {
                position: fixed;
                bottom: 2rem;
                right: 2rem;
                z-index: 300;
                background: var(--ink);
                color: white;
                padding: .75rem 1.25rem;
                border-radius: 100px;
                font-size: .8rem;
                display: flex;
                align-items: center;
                gap: .6rem;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
                transform: translateY(20px);
                opacity: 0;
                transition: transform .3s, opacity .3s;
                pointer-events: none;
            }

            .toast.show {
                transform: translateY(0);
                opacity: 1;
            }

            .toast svg {
                width: 14px;
                height: 14px;
                stroke: var(--green);
                stroke-width: 2;
                fill: none;
                flex-shrink: 0;
            }

            @@media (max-width: 900px) {
                .step-bar {
                    display: none;
                }

                .top-nav {
                    padding: 0 1.25rem;
                }

                .hamburger {
                    display: flex;
                }

                .nav-deadline,
                .user-name,
                .nav-logout {
                    display: none;
                }

                .main {
                    padding-top: var(--nav-h);
                }

                .content {
                    padding: 1.5rem 1rem 3rem;
                }

                .step-mini-bar,
                .step-mini-progress {
                    display: none;
                }
            }

            @@media (max-width: 560px) {
                .page-title {
                    font-size: 1.65rem;
                }

                .form-card-body {
                    padding: 1.25rem;
                }

                .form-actions {
                    flex-direction: column;
                    align-items: stretch;
                }

                .actions-left {
                    justify-content: space-between;
                }

                .btn-submit {
                    justify-content: center;
                    padding: 1rem;
                }

                .toast {
                    left: 1rem;
                    right: 1rem;
                    bottom: 1rem;
                    justify-content: center;
                }

                .policy-modal-footer {
                    flex-direction: column;
                    align-items: stretch;
                }
            }
    </style>
</head>

<body>
    <nav class="top-nav">
        <div class="nav-brand"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
        <div class="nav-right">
            <div class="nav-deadline">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
                Deadline: <span class="deadline-val">30 June 2026</span>
            </div>
            <div class="nav-user">
                <div class="user-avatar">@initials</div>
                <span class="user-name">@applicantName</span>
            </div>
            <a asp-action="Logout" asp-controller="Account" class="nav-logout">Sign out</a>
            <button class="hamburger" id="hamburger" aria-label="Open menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </nav>

    <div class="step-bar">
        @foreach (var s in steps)
        {
            var st = StepStatus(s.Num);
            <a asp-action="@s.Action" asp-controller="Application" class="step-item @st" title="@s.Name">
                <div class="step-num">
                    <svg viewBox="0 0 12 12">
                        <polyline points="2,6 5,9 10,3" />
                    </svg>
                    <span>@s.Num</span>
                </div>
                <span class="step-name">@s.Name</span>
            </a>
        }
    </div>

    <div class="drawer-overlay" id="drawerOverlay"></div>
    <aside class="side-drawer" id="sideDrawer">
        <div class="drawer-header"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
        <div class="drawer-user">
            <div class="drawer-avatar">@initials</div>
            <div>
                <div class="drawer-uname">@applicantName</div>
                <div class="drawer-uemail">NPI 4.0 Applicant</div>
            </div>
        </div>
        <div class="drawer-steps">
            <span class="drawer-step-label">Application Steps</span>
            @foreach (var s in steps)
            {
                var st = StepStatus(s.Num);
                var label = st == "completed" ? "Completed" : st == "active" ? "In progress" : "Locked";
                <a asp-action="@s.Action" asp-controller="Application" class="drawer-item @st"
                   style="@(st == "locked" ? "pointer-events:none;opacity:.4" : null)">
                    <div class="drawer-item-num">
                        <svg viewBox="0 0 12 12">
                            <polyline points="2,6 5,9 10,3" />
                        </svg>
                        <span>@s.Num</span>
                    </div>
                    <div>
                        <div class="drawer-item-name">@s.Name</div>
                        <div class="drawer-item-status">@label</div>
                    </div>
                </a>
            }
        </div>
        <div class="drawer-footer">
            <a asp-action="Logout" asp-controller="Account" class="drawer-logout">
                <svg viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Sign out
            </a>
        </div>
    </aside>

    <main class="main">
        <div class="content">
            <div class="page-header">
                <div class="breadcrumb">
                    <a asp-action="Dashboard" asp-controller="Application">Dashboard</a>
                    <svg viewBox="0 0 24 24">
                        <polyline points="9 18 15 12 9 6" />
                    </svg>
                    <span>Additional Information</span>
                </div>
                <h1 class="page-title">Additional Information</h1>
                <p class="page-sub">You're almost done. Add any final notes, upload supporting documents, then submit
                    your application.</p>
                </div>

                <div class="step-mini">
                    <div class="step-mini-dot">10</div>
                    <div>
                        <div class="step-mini-label">Step 10 of 10</div>
                        <div class="step-mini-name">Additional Information &amp; Submission</div>
                    </div>
                    <div class="step-mini-spacer"></div>
                    <span class="step-mini-progress">Final step</span>
                    <div class="step-mini-bar">
                        <div class="step-mini-fill"></div>
                    </div>
                </div>

                <form asp-action="SaveAdditional" asp-controller="Application" method="post" id="additionalForm"
                      enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="form-card">
                        <div class="form-card-header">
                            <div class="form-card-icon">
                                <svg viewBox="0 0 24 24">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                            </div>
                            <div>
                                <div class="form-card-title">Additional Notes</div>
                                <div class="form-card-desc">Anything else you'd like the panel to know about your business
                                    or application.</div>
                                </div>
                            </div>
                            <div class="form-card-body">
                                <div class="form-group">
                                    <label class="field-label" for="additionalInfo">
                                        Additional information
                                        <span class="label-opt">(optional - max 1,000 characters)</span>
                                    </label>
                                    <textarea id="additionalInfo" name="AdditionalInformation"
                                              placeholder="Share any additional context, recent developments, or information that strengthens your application..."
                                              maxlength="1000" rows="5">@ViewBag.AdditionalInformation</textarea>
                                    <div class="char-count"><span id="charCount">0</span> / 1,000</div>
                                </div>
                            </div>
                        </div>

                        <div class="form-card">
                            <div class="form-card-header">
                                <div class="form-card-icon">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                        <polyline points="17 8 12 3 7 8" />
                                        <line x1="12" y1="3" x2="12" y2="15" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="form-card-title">Supporting Documents <span class="req">*</span></div>
                                    <div class="form-card-desc">Upload pitch decks, financial statements, product demos, or any
                                        relevant supporting files. PDF, Word, Excel, images accepted, max 10MB each.</div>
                                        <div class="upload-error" id="uploadError">Please upload at least one supporting document.
                                        </div>
                                    </div>
                                </div>
                                <div class="form-card-body">
                                    <div>
                                        <label class="field-label" style="margin-bottom:.6rem;display:block">
                                            Select document type before uploading
                                        </label>
                                        <div class="doc-type-bar" id="docTypeBar">
                                            @foreach (var t in new[] { "Pitch Deck", "Financial Statements", "Product Demo",
                     "Business Plan", "Certificate/License", "Other" })
                                            {
                                                <button type="button" class="doc-type-btn @(t == "Pitch Deck" ? "active" : "")"
                                                        data-type="@t" onclick="selectDocType(this)">@t</button>
                                            }
                                        </div>
                                    </div>

                                    <div class="upload-zone" id="uploadZone">
                                        <input type="file" id="fileInput" name="Documents" multiple
                                               accept=".pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.png,.jpg,.jpeg,.gif" />
                                        <div class="upload-icon">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                                                <polyline points="17 8 12 3 7 8" />
                                                <line x1="12" y1="3" x2="12" y2="15" />
                                            </svg>
                                        </div>
                                        <div class="upload-title">Drop files here or <span
                                            style="color:var(--teal);font-weight:500">browse</span></div>
                                            <div class="upload-sub">PDF, Word, Excel, PowerPoint, Images · Max 10MB each</div>
                                        </div>

                                        <div class="file-list" id="fileList">
                                            @{
                                                var savedDocs = ViewBag.Documents as IEnumerable<dynamic> ?? new List<dynamic>();
                                            }
                                            @foreach (var doc in savedDocs)
                                            {
                                                <div class="file-item" data-docid="@doc.id">
                                                    <div class="file-icon">
                                                        <svg viewBox="0 0 24 24">
                                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                                            <polyline points="14 2 14 8 20 8" />
                                                        </svg>
                                                    </div>
                                                    <div class="file-info">
                                                        <div class="file-name">@doc.name</div>
                                                        <div class="file-meta">@doc.type · @(Math.Round((double)doc.size / 1024, 1)) KB
                                                        </div>
                                                    </div>
                                                    <button type="button" class="file-remove" onclick="removeExistingDoc('@doc.id', this)">
                                                        <svg viewBox="0 0 24 24">
                                                            <polyline points="3 6 5 6 21 6" />
                                                            <path
                                                            d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" />
                                                        </svg>
                                                    </button>
                                                </div>
                                            }
                                        </div>

                                        <div id="docTypeInputs"></div>
                                    </div>
                                </div>

                                <div class="submit-warning">
                                    <svg viewBox="0 0 24 24">
                                        <path
                                        d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                                        <line x1="12" y1="9" x2="12" y2="13" />
                                        <line x1="12" y1="17" x2="12.01" y2="17" />
                                    </svg>
                                    <div class="submit-warning-text">
                                        <strong>You are about to submit your application.</strong><br />
                                        Once submitted, you will not be able to edit your responses. Please review all steps before
                                        proceeding. Your reference number will be sent to your email upon submission.
                                    </div>
                                </div>

                                <div class="form-card">
                                    <div class="form-card-header">
                                        <div class="form-card-icon">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M9 11l3 3L22 4" />
                                                <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                                            </svg>
                                        </div>
                                        <div>
                                            <div class="form-card-title">Declaration &amp; Agreement</div>
                                            <div class="form-card-desc">Please confirm your declarations before submitting.</div>
                                        </div>
                                    </div>
                                    <div class="form-card-body">
                                        <div class="checklist">
                                            <div class="check-item">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                                    <polyline points="22 4 12 14.01 9 11.01" />
                                                </svg>
                                                All 9 previous steps have been completed
                                            </div>
                                            <div class="check-item">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                                    <polyline points="22 4 12 14.01 9 11.01" />
                                                </svg>
                                                All information provided is accurate and truthful
                                            </div>
                                            <div class="check-item">
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                                    <polyline points="22 4 12 14.01 9 11.01" />
                                                </svg>
                                                You understand this application cannot be edited after submission
                                            </div>
                                        </div>

                                        <div style="margin-top:1.25rem;display:flex;flex-direction:column;gap:.75rem;">
                                            <div class="form-group" id="grp-terms">
                                                <div class="terms-row">
                                                    <input type="checkbox" id="agreeTerms" name="AgreeTerms" value="true" disabled />
                                                    <label for="agreeTerms">
                                                        I have read and agree to the NSIA Prize for Innovation
                                                        <button type="button" class="policy-link-btn"
                                                                onclick="openPolicyModal('terms')">Terms of Service</button>
                                                        <span id="termsStatus" class="policy-status">Read required</span>
                                                    </label>
                                                </div>
                                                <div class="field-error">You must agree to the Terms of Service to submit.</div>
                                            </div>

                                            <div class="form-group" id="grp-privacy">
                                                <div class="terms-row">
                                                    <input type="checkbox" id="agreePrivacy" name="AgreePrivacy" value="true"
                                                           disabled />
                                                    <label for="agreePrivacy">
                                                        I have read and agree to the NSIA
                                                        <button type="button" class="policy-link-btn"
                                                                onclick="openPolicyModal('privacy')">Privacy Policy</button>
                                                        <span id="privacyStatus" class="policy-status">Read required</span>
                                                    </label>
                                                </div>
                                                <div class="field-error">You must agree to the Privacy Policy to submit.</div>
                                            </div>

                                            <div class="form-group" id="grp-accuracy">
                                                <div class="terms-row">
                                                    <input type="checkbox" id="agreeAccuracy" name="AgreeAccuracy" value="true" />
                                                    <label for="agreeAccuracy">
                                                        I declare that all information provided in this application is accurate,
                                                        complete and truthful to the best of my knowledge.
                                                    </label>
                                                </div>
                                                <div class="field-error">You must confirm the accuracy of your information.</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-actions">
                                    <div class="actions-left">
                                        <a asp-action="Impact" asp-controller="Application" class="btn-back">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M19 12H5M12 5l-7 7 7 7" />
                                            </svg>
                                            Back
                                        </a>
                                        @* <button type="button" class="btn-save" id="saveBtn">
                        <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2
                        2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save draft
                    </button> *@
                                    </div>
                                    <button type="submit" class="btn-submit" id="submitBtn">
                                        <svg viewBox="0 0 24 24">
                                            <path d="M22 2L11 13" />
                                            <path d="M22 2L15 22 11 13 2 9l20-7z" />
                                        </svg>
                                        Submit Application
                                    </button>
                                </div>
                            </form>
                        </div>
                    </main>

                    <div class="policy-modal" id="policyModal" aria-hidden="true">
                        <div class="policy-modal-backdrop"></div>
                        <div class="policy-modal-dialog">
                            <div class="policy-modal-header">
                                <h3 id="policyModalTitle">Document Preview</h3>
                            </div>
                            <div class="policy-modal-body">
                                <iframe id="policyFrame" class="policy-frame" title="Policy document preview"></iframe>
                            </div>
                            <div class="policy-modal-footer">
                                <div id="policyCountdown" class="policy-countdown">Please read for 10 seconds</div>
                                <button type="button" id="policyConfirmBtn" class="doc-type-btn" disabled>I have read this</button>
                            </div>
                        </div>
                    </div>

                    <div class="toast" id="toast">
                        <svg viewBox="0 0 24 24">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                        <span id="toastMsg">Draft saved</span>
                    </div>

                    <script>
                            const hamburger = document.getElementById('hamburger');
                            const sideDrawer = document.getElementById('sideDrawer');
                            const drawerOverlay = document.getElementById('drawerOverlay');
                            const openDrawer = () => { sideDrawer.classList.add('open'); drawerOverlay.style.display = 'block'; setTimeout(() => drawerOverlay.classList.add('open'), 10); hamburger.classList.add('open'); document.body.style.overflow = 'hidden'; };
                            const closeDrawer = () => { sideDrawer.classList.remove('open'); drawerOverlay.classList.remove('open'); setTimeout(() => drawerOverlay.style.display = '', 300); hamburger.classList.remove('open'); document.body.style.overflow = ''; };
                            hamburger.addEventListener('click', () => sideDrawer.classList.contains('open') ? closeDrawer() : openDrawer());
                            drawerOverlay.addEventListener('click', closeDrawer);

                            const textarea = document.getElementById('additionalInfo');
                            const charCount = document.getElementById('charCount');
                            function updateCount() { charCount.textContent = textarea.value.length; }
                            textarea.addEventListener('input', updateCount);
                            updateCount();

                            let selectedDocType = 'Pitch Deck';
                            function selectDocType(btn) {
                                document.querySelectorAll('.doc-type-btn').forEach(b => b.classList.remove('active'));
                                btn.classList.add('active');
                                selectedDocType = btn.dataset.type;
                            }

                            const fileInput = document.getElementById('fileInput');
                            const fileList = document.getElementById('fileList');
                            const docTypeInputs = document.getElementById('docTypeInputs');
                            const uploadZone = document.getElementById('uploadZone');
                            let pendingFiles = [];

                            fileInput.addEventListener('change', handleFiles);

                            uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag'); });
                            uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag'));
                            uploadZone.addEventListener('drop', e => {
                                e.preventDefault();
                                uploadZone.classList.remove('drag');
                                handleFilesFromList(e.dataTransfer.files);
                            });

                            function handleFiles() { handleFilesFromList(fileInput.files); }

                            function handleFilesFromList(files) {
                                Array.from(files).forEach(file => {
                                    if (file.size > 10 * 1024 * 1024) {
                                        showToast(`${file.name} exceeds 10MB`, true);
                                        return;
                                    }
                                    pendingFiles.push({ file, type: selectedDocType });
                                    renderPendingFile(file, selectedDocType, pendingFiles.length - 1);
                                });
                                rebuildFileInputs();
                                uploadZone.classList.remove('error');
                                document.getElementById('uploadError').classList.remove('show');
                            }

                            function renderPendingFile(file, type, idx) {
                                const item = document.createElement('div');
                                item.className = 'file-item';
                                item.dataset.pendingIdx = idx;
                                item.innerHTML = `
                                                    <div class="file-icon">
                                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                                    </div>
                                                    <div class="file-info">
                                                        <div class="file-name">${escHtml(file.name)}</div>
                                                        <div class="file-meta">${escHtml(type)} · ${(file.size / 1024).toFixed(1)} KB</div>
                                                    </div>
                                                    <button type="button" class="file-remove" onclick="removePendingFile(${idx}, this)">
                                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                                    </button>`;
                                fileList.appendChild(item);
                            }

                            function removePendingFile(idx, btn) {
                                pendingFiles[idx] = null;
                                btn.closest('.file-item').remove();
                                rebuildFileInputs();
                            }

                            function rebuildFileInputs() {
                                docTypeInputs.innerHTML = '';
                                pendingFiles.forEach(pf => {
                                    if (!pf) return;
                                    const inp = document.createElement('input');
                                    inp.type = 'hidden';
                                    inp.name = 'DocumentTypes';
                                    inp.value = pf.type;
                                    docTypeInputs.appendChild(inp);
                                });

                                const dt = new DataTransfer();
                                pendingFiles.forEach(pf => { if (pf) dt.items.add(pf.file); });
                                fileInput.files = dt.files;
                            }

                            async function removeExistingDoc(docId, btn) {
                                const item = btn.closest('.file-item');
                                btn.disabled = true;
                                try {
                                    const fd = new FormData();
                                    fd.append('documentId', docId);
                                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                                    fd.append('__RequestVerificationToken', token);
                                    const res = await fetch('/Application/DeleteDocument', { method: 'POST', body: fd });
                                    if (res.ok) item.remove();
                                    else showToast('Could not delete document', true);
                                } catch {
                                    showToast('Could not delete document', true);
                                }
                            }

                            function escHtml(s) {
                                return String(s)
                                    .replace(/&/g, '&amp;')
                                    .replace(/"/g, '&quot;')
                                    .replace(/</g, '&lt;')
                                    .replace(/>/g, '&gt;');
                            }

                            function setInvalid(id) { document.getElementById(id)?.classList.add('invalid'); }
                            function clearInvalid(id) { document.getElementById(id)?.classList.remove('invalid'); }

                            ['agreeTerms', 'agreePrivacy', 'agreeAccuracy'].forEach(id => {
                                document.getElementById(id)?.addEventListener('change', () => {
                                    const map = { agreeTerms: 'grp-terms', agreePrivacy: 'grp-privacy', agreeAccuracy: 'grp-accuracy' };
                                    clearInvalid(map[id]);
                                });
                            });

                            function validate() {
                                let ok = true;

                                if (!policyReadState.terms || !document.getElementById('agreeTerms').checked) {
                                    setInvalid('grp-terms');
                                    ok = false;
                                }

                                if (!policyReadState.privacy || !document.getElementById('agreePrivacy').checked) {
                                    setInvalid('grp-privacy');
                                    ok = false;
                                }

                                if (!document.getElementById('agreeAccuracy').checked) {
                                    setInvalid('grp-accuracy');
                                    ok = false;
                                }

                                const hasPending = pendingFiles.some(pf => pf !== null);
                                const hasExisting = document.querySelectorAll('#fileList .file-item[data-docid]').length > 0;

                                if (!hasPending && !hasExisting) {
                                    document.getElementById('uploadZone').classList.add('error');
                                    document.getElementById('uploadError').classList.add('show');
                                    ok = false;
                                }

                                if (!ok) {
                                    document.querySelector('.invalid, .upload-zone.error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                                }

                                return ok;
                            }

                            function showToast(msg, isError) {
                                const t = document.getElementById('toast');
                                t.querySelector('svg').style.stroke = isError ? '#f87171' : 'var(--green)';
                                document.getElementById('toastMsg').textContent = msg;
                                t.classList.add('show');
                                setTimeout(() => t.classList.remove('show'), 3000);
                            }

                            document.getElementById('saveBtn').addEventListener('click', async () => {
                                const btn = document.getElementById('saveBtn');
                                btn.textContent = 'Saving...';
                                btn.disabled = true;
                                try {
                                    const fd = new FormData();
                                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                                    fd.append('__RequestVerificationToken', token);
                                    fd.append('AdditionalInformation', textarea.value);
                                    const res = await fetch('/Application/SaveAdditionalDraft', { method: 'POST', body: fd });
                                    showToast(res.ok ? 'Draft saved' : 'Could not save', !res.ok);
                                } catch {
                                    showToast('Could not save', true);
                                } finally {
                                    btn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save draft';
                                    btn.disabled = false;
                                }
                            });

                            document.getElementById('additionalForm').addEventListener('submit', function (e) {
                                if (!validate()) {
                                    e.preventDefault();
                                    return;
                                }
                                const btn = document.getElementById('submitBtn');
                                btn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Submitting...';
                                btn.disabled = true;
                            });
                    </script>
                    <script>
                            const policyDocs = {
                                terms: {
                                    title: 'Terms of Service',
                                    url: '/NPI_4_0_Terms_of_Service.pdf',
                                    checkboxId: 'agreeTerms',
                                    statusId: 'termsStatus'
                                },
                                privacy: {
                                    title: 'Privacy Policy',
                                    url: '/NPI_4_0_Privacy_Policy.pdf',
                                    checkboxId: 'agreePrivacy',
                                    statusId: 'privacyStatus'
                                }
                            };

                            const policyOrder = ['terms', 'privacy'];

                            const policyReadState = {
                                terms: false,
                                privacy: false
                            };

                            let activePolicyKey = null;
                            let policyTimer = null;
                            let secondsLeft = 0;

                            const policyModal = document.getElementById('policyModal');
                            const policyFrame = document.getElementById('policyFrame');
                            const policyModalTitle = document.getElementById('policyModalTitle');
                            const policyCountdown = document.getElementById('policyCountdown');
                            const policyConfirmBtn = document.getElementById('policyConfirmBtn');

                            function openPolicyModal(key) {
                                const doc = policyDocs[key];
                                activePolicyKey = key;
                                secondsLeft = 10;

                                policyModalTitle.textContent = doc.title;
                                policyFrame.src = doc.url;
                                policyConfirmBtn.disabled = true;
                                policyCountdown.textContent = `Please read for ${secondsLeft} seconds`;

                                policyModal.classList.add('open');
                                policyModal.setAttribute('aria-hidden', 'false');
                                document.body.style.overflow = 'hidden';

                                clearInterval(policyTimer);
                                policyTimer = setInterval(() => {
                                    secondsLeft -= 1;

                                    if (secondsLeft > 0) {
                                        policyCountdown.textContent = `Please read for ${secondsLeft} seconds`;
                                        return;
                                    }

                                    clearInterval(policyTimer);
                                    policyCountdown.textContent = 'You can now confirm that you have read this';
                                    policyConfirmBtn.disabled = false;
                                }, 1000);
                            }

                            function closePolicyModal() {
                                clearInterval(policyTimer);
                                policyTimer = null;
                                policyModal.classList.remove('open');
                                policyModal.setAttribute('aria-hidden', 'true');
                                policyFrame.src = '';
                                document.body.style.overflow = '';
                                activePolicyKey = null;
                            }

                            function openNextUnreadPolicy() {
                                const nextKey = policyOrder.find(key => !policyReadState[key]);
                                if (nextKey) {
                                    openPolicyModal(nextKey);
                                }
                            }

                            policyConfirmBtn.addEventListener('click', () => {
                                if (!activePolicyKey) return;

                                const doc = policyDocs[activePolicyKey];
                                const checkbox = document.getElementById(doc.checkboxId);
                                const status = document.getElementById(doc.statusId);
                                const completedKey = activePolicyKey;

                                policyReadState[completedKey] = true;
                                checkbox.disabled = false;
                                checkbox.checked = true;

                                status.textContent = 'Read confirmed';
                                status.classList.add('done');

                                closePolicyModal();

                                setTimeout(() => {
                                    openNextUnreadPolicy();
                                }, 200);
                            });

                            window.addEventListener('load', () => {
                                openNextUnreadPolicy();
                            });
                    </script>

                </body>

            </html>
