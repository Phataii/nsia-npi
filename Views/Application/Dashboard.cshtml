@{
    ViewData["Title"] = "Application Dashboard — NSIA Prize for Innovation";
    Layout = null;
    var applicantName = ViewBag.ApplicantName as string ?? "";
    var completedStep = (int)(ViewBag.CompletedStep ?? 0);
    var referenceNumber = ViewBag.ReferenceNumber as string ?? "";
    var initials      = string.Join("", applicantName.Split(' ').Take(2).Select(w => w[0]));
    var totalSteps    = 10;
    var progressPct   = (int)Math.Round((completedStep / (double)totalSteps) * 100);
    var ringOffset    = (int)(220 - (220 * completedStep / totalSteps));

    var steps = new[] {
        new { Num = 1,  Name = "Pre-Checklist",    Desc = "Confirm your eligibility and business sector before proceeding.",            Action = "PreChecklist",   Icon = "check"    },
        new { Num = 2,  Name = "Personal Info",    Desc = "Your name, contact details, NIN, and relationship to the business.",         Action = "PersonalInfo",   Icon = "user"     },
        new { Num = 3,  Name = "Company Info",     Desc = "Company details, location, registration, and compliance status.",           Action = "CompanyInfo",    Icon = "building" },
        new { Num = 4,  Name = "Team Info",        Desc = "Founders, team composition, experience, and employee count.",               Action = "TeamInfo",       Icon = "users"    },
        new { Num = 5,  Name = "Product & Growth", Desc = "Growth stage, milestones, users, business model, and key features.",        Action = "ProductInfo",    Icon = "box"      },
        new { Num = 6,  Name = "Commercial I",     Desc = "Revenue history, funding received, and financial projections.",             Action = "Commercial1",    Icon = "dollar"   },
        new { Num = 7,  Name = "Commercial II",    Desc = "Market strategy, competitive position, and customer growth metrics.",       Action = "Commercial2",    Icon = "trending" },
        new { Num = 8,  Name = "Sustainability",   Desc = "SDG alignment, sustainability practices, climate approach, and access.",    Action = "Sustainability", Icon = "leaf"     },
        new { Num = 9,  Name = "Impact",           Desc = "Social equity, jobs created, data protection, and ethical operations.",    Action = "Impact",         Icon = "heart"    },
        new { Num = 10, Name = "Additional",       Desc = "Supporting documents, final notes, and application submission.",            Action = "Additional",     Icon = "file"     },
    };

    string StepStatus(int num) {
        if (num <= completedStep) return "completed";
        if (num == completedStep + 1) return "active";
        return "locked";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal: #2DB8B0; --teal-d: #1a9990; --teal-deep: #0d7a73;
            --teal-light: #E8F7F6; --teal-pale: #F0FAF9;
            --green: #7BC144; --green-dark: #5a9130;
            --ink: #1C2B2A; --cream: #F5F9F8; --off: #EEF4F3;
            --muted: #4A6260; --border: rgba(45,184,176,0.2);
            --nav-h: 62px; --step-h: 56px;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'DM Sans', sans-serif; background: var(--off); color: var(--ink); min-height: 100vh; }

        /* ── NAV ── */
        .top-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: var(--nav-h); background: white; display: flex; align-items: center; padding: 0 2rem; justify-content: space-between; }
        .top-nav::after { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.08) 0%, transparent 60%); }
        .nav-brand { display: flex; align-items: center; position: relative; z-index: 1; }
        .nav-brand img { height: 32px; width: auto; }
        .nav-right { display: flex; align-items: center; gap: 1.25rem; position: relative; z-index: 1; }
        
        .nav-deadline { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--ink); }
        .nav-deadline svg { width: 13px; height: 13px; stroke: var(--ink); stroke-width: 1.75; fill: none; }
        .deadline-val { color: var(--ink); font-weight: 600; }
        .nav-user { display: flex; align-items: center; gap: 8px; }
        
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--ink); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: white; flex-shrink: 0; }
        .user-name { font-size: 12px; color: var(--ink); }
        .nav-logout { font-size: 11px; color: var(--ink); text-decoration: none; padding: .3rem .7rem; border: 1px solid var(--green-dark); border-radius: 100px; transition: all .2s; white-space: nowrap; }
        .nav-logout:hover { color: white; border-color: var(--teal-dark); background: var(--ink); }

        .hamburger { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; position: relative; z-index: 1; }
        .hamburger span { display: block; width: 22px; height: 2px; background: white; border-radius: 2px; transition: transform .3s, opacity .3s; }
        .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
        .hamburger.open span:nth-child(2) { opacity: 0; }
        .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

        /* ── STEP BAR ── */
        .step-bar { position: fixed; top: var(--nav-h); left: 0; right: 0; z-index: 190; height: var(--step-h); background: white; border-bottom: 1px solid var(--green); display: flex; align-items: stretch; overflow: hidden; }
        .step-item { flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 0 .35rem; text-decoration: none; color: var(--green); border-right: 1px solid var(--green); position: relative; transition: background .2s; min-width: 0; }
        .step-item:last-child { border-right: none; }
        .step-item::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: transparent; transition: background .2s; }
        .step-item:hover { background: var(--teal-pale); }
        .step-item.completed .step-num { background: var(--green); border-color: var(--green); color: white; }
        .step-item.completed .step-num svg { display: block; }
        .step-item.completed .step-num span { display: none; }
        .step-item.completed .step-name { color: var(--green); }
        .step-item.completed::after { background: var(--green); }
        .step-item.active { background: var(--teal-pale); }
        .step-item.active .step-num { background: var(--green); border-color: var(--green); color: white; }
        .step-item.active .step-name { color: var(--green); font-weight: 500; }
        .step-item.active::after { background: var(--green); }
        .step-num { width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 500; color: var(--muted); }
        .step-num svg { width: 9px; height: 9px; stroke: white; stroke-width: 3; fill: none; display: none; }
        .step-name { font-size: 10.5px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        
        /* ── DRAWER ── */
        .drawer-overlay { display: none; position: fixed; inset: 0; z-index: 150; background: rgba(0,0,0,0.5); opacity: 0; transition: opacity .3s; }
        .drawer-overlay.open { opacity: 1; }
        .side-drawer { position: fixed; top: 0; left: -280px; bottom: 0; z-index: 160; width: 280px; background: var(--ink); display: flex; flex-direction: column; transition: left .3s cubic-bezier(0.4,0,0.2,1); overflow-y: auto; }
        .side-drawer.open { left: 0; }
        .drawer-header { padding: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .drawer-header img { height: 30px; width: auto; filter: brightness(0) invert(1); }
        .drawer-user { padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px; }
        .drawer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: white; flex-shrink: 0; }
        .drawer-uname { font-size: 13px; font-weight: 500; color: white; }
        .drawer-uemail { font-size: 11px; color: rgba(255,255,255,0.35); }
        .drawer-steps { padding: .75rem 0; flex: 1; }
        .drawer-step-label { font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.3); letter-spacing: .1em; text-transform: uppercase; padding: .5rem 1.25rem .25rem; display: block; }
        .drawer-item { display: flex; align-items: center; gap: .9rem; padding: .75rem 1.25rem; text-decoration: none; color: rgba(255,255,255,0.55); transition: background .2s, color .2s; position: relative; }
        .drawer-item:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.85); }
        .drawer-item.active { background: rgba(45,184,176,0.15); color: white; }
        .drawer-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--teal); border-radius: 0 2px 2px 0; }
        .drawer-item-num { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 500; }
        .drawer-item.completed .drawer-item-num { background: var(--teal); border-color: var(--teal); }
        .drawer-item.active .drawer-item-num { background: var(--teal); border-color: var(--teal); }
        .drawer-item-num svg { width: 10px; height: 10px; stroke: white; stroke-width: 3; fill: none; display: none; }
        .drawer-item.completed .drawer-item-num svg { display: block; }
        .drawer-item.completed .drawer-item-num span { display: none; }
        .drawer-item-name { font-size: 13px; }
        .drawer-item-status { font-size: 10px; color: rgba(255,255,255,0.25); }
        .drawer-item.completed .drawer-item-status { color: var(--teal); }
        .drawer-item.active .drawer-item-status { color: rgba(45,184,176,0.8); }
        .drawer-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); }
        .drawer-logout { display: flex; align-items: center; gap: .6rem; font-size: 12px; color: rgba(255,255,255,0.35); text-decoration: none; transition: color .2s; }
        .drawer-logout svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.75; fill: none; }
        .drawer-logout:hover { color: rgba(255,255,255,0.65); }

        /* ── MAIN ── */
        .main { padding-top: calc(var(--nav-h) + var(--step-h)); min-height: 100vh; }
        .content { max-width: 980px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }

        /* ── WELCOME BANNER ── */
        .welcome-banner {
            background: var(--teal-light); border-radius: 14px;
            padding: 2.25rem 2.5rem; margin-bottom: 2rem;
            position: relative; overflow: hidden;
            display: flex; align-items: center; justify-content: space-between; gap: 2rem;
        }
        .welcome-banner::before {
            content: ''; position: absolute; inset: 0; pointer-events: none;
        
        }
        .welcome-banner::after {
            content: 'NPI'; position: absolute; right: 14rem; top: -1rem;
        }
        .welcome-banner > * { position: relative; z-index: 1; }
        .wb-eyebrow {
            display: inline-flex; align-items: center; gap: 5px;
            background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
            padding: .25rem .7rem; border-radius: 100px;
            font-size: 10px; font-weight: 600; color: var(--ink);
            letter-spacing: .08em; text-transform: uppercase; margin-bottom: .85rem; width: fit-content;
        }
        .wb-eyebrow-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--ink); animation: pulse 2s ease-in-out infinite; flex-shrink: 0; }
        @@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }
        .wb-title { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 700; color: var(--ink); line-height: 1.1; margin-bottom: .5rem; }
        .wb-title em { color: var(--green); font-style: italic; }
        .wb-sub { font-size: .84rem; color: var(--ink); font-weight: 300; max-width: 400px; line-height: 1.7; }

        .wb-right { display: flex; align-items: center; gap: 2rem; flex-shrink: 0; }

        /* Reference number pill */
        .ref-pill {
            text-align: center;
        }
        .ref-label { font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .3rem; }
        .ref-value { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 700; color: white; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); padding: .3rem .9rem; border-radius: 6px; letter-spacing: .05em; }

        /* Progress ring */
        .ring-wrap { position: relative; width: 86px; height: 86px; flex-shrink: 0; }
        .progress-ring { width: 86px; height: 86px; transform: rotate(-90deg); }
        .ring-bg { fill: none; stroke: rgba(255,255,255,0.12); stroke-width: 5; }
        .ring-fill { fill: none; stroke: var(--green); stroke-width: 5; stroke-linecap: round; stroke-dasharray: 220; transition: stroke-dashoffset 1s ease; }
        .ring-label { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
        .ring-pct { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 700; color: var(--ink); line-height: 1; }
        .ring-sub { font-size: 9px; color: var(--ink); text-transform: uppercase; letter-spacing: .07em; margin-top: 2px; }

        /* ── SECTION LABEL ── */
        .section-label {
            font-size: 11px; font-weight: 500; color: var(--muted);
            letter-spacing: .1em; text-transform: uppercase;
            margin-bottom: 1rem; margin-top: .25rem;
            display: flex; align-items: center; gap: 8px;
        }
        .section-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }

        /* ── STEP CARDS ── */
        .steps-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin-bottom: 2rem; }

        .step-card {
            background: white; border-radius: 12px;
            border: 1px solid var(--border); padding: 1.4rem;
            text-decoration: none; color: var(--ink);
            display: flex; flex-direction: column; gap: .75rem;
            transition: box-shadow .2s, transform .2s, border-color .2s;
            position: relative; overflow: hidden;
        }
        .step-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: transparent; transition: background .2s; }
        .step-card:hover:not(.locked) { box-shadow: 0 6px 24px rgba(45,184,176,0.12); transform: translateY(-2px); border-color: rgba(45,184,176,0.3); }
        .step-card.completed { border-color: rgba(45,184,176,0.2); }
        .step-card.completed::before { background: var(--teal); }
        .step-card.active::before { background: var(--teal); }
        .step-card.active { border-color: rgba(45,184,176,0.35); box-shadow: 0 0 0 3px rgba(45,184,176,0.08); }
        .step-card.locked { opacity: .5; cursor: not-allowed; pointer-events: none; }

        .card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: .5rem; }
        .card-icon { width: 40px; height: 40px; border-radius: 9px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
        .card-icon svg { width: 18px; height: 18px; stroke-width: 1.75; fill: none; }
        .step-card.completed .card-icon { background: var(--teal-light); }
        .step-card.completed .card-icon svg { stroke: var(--teal); }
        .step-card.active .card-icon { background: var(--teal-light); }
        .step-card.active .card-icon svg { stroke: var(--teal); }
        .step-card.locked .card-icon { background: var(--off); }
        .step-card.locked .card-icon svg { stroke: #c0ccc8; }
        .step-card:not(.completed):not(.active):not(.locked) .card-icon { background: var(--off); }
        .step-card:not(.completed):not(.active):not(.locked) .card-icon svg { stroke: var(--muted); }

        .card-badge { font-size: 10px; font-weight: 500; padding: .2rem .65rem; border-radius: 100px; letter-spacing: .05em; text-transform: uppercase; flex-shrink: 0; white-space: nowrap; }
        .badge-done    { background: var(--teal-light); color: var(--teal-deep); }
        .badge-active  { background: var(--teal-light); color: var(--teal);      }
        .badge-locked  { background: var(--off);         color: #b0bcba;          }
        .badge-pending { background: var(--off);         color: var(--muted);     }

        .card-num  { font-size: 10px; color: var(--muted); margin-bottom: .2rem; }
        .card-name { font-size: .92rem; font-weight: 600; color: var(--ink); line-height: 1.2; }
        .card-desc { font-size: .76rem; color: var(--muted); line-height: 1.6; flex: 1; }

        .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: .5rem; border-top: 1px solid rgba(45,184,176,0.1); margin-top: .25rem; }
        .card-action { font-size: .76rem; font-weight: 500; display: flex; align-items: center; gap: 4px; }
        .step-card.completed .card-action { color: var(--teal); }
        .step-card.active    .card-action { color: var(--teal); }
        .step-card.locked    .card-action { color: #c0ccc8;     }
        .card-action svg { width: 13px; height: 13px; stroke: currentColor; stroke-width: 2; fill: none; }

        /* ── INFO ROW ── */
        .info-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 2rem; }
        .info-card { background: white; border-radius: 10px; border: 1px solid var(--border); padding: 1.25rem 1.4rem; display: flex; align-items: flex-start; gap: .9rem; }
        .info-icon { width: 38px; height: 38px; border-radius: 8px; flex-shrink: 0; background: var(--teal-light); display: flex; align-items: center; justify-content: center; }
        .info-icon svg { width: 17px; height: 17px; stroke: var(--teal); stroke-width: 1.75; fill: none; }
        .info-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; margin-bottom: .3rem; }
        .info-value { font-size: .9rem; font-weight: 600; color: var(--ink); }
        .info-sub { font-size: .72rem; color: var(--muted); margin-top: 2px; }

        /* ── CONTINUE CTA ── */
        .continue-cta {
            background: white; border-radius: 12px; border: 1px solid var(--border);
            padding: 1.75rem 2rem;
            display: flex; align-items: center; justify-content: space-between; gap: 2rem;
        }
        .cta-left h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 700; color: var(--ink); margin-bottom: .3rem; }
        .cta-left p  { font-size: .82rem; color: var(--muted); line-height: 1.65; max-width: 480px; }
        .btn-cta {
            flex-shrink: 0; background: var(--teal); color: white;
            padding: .85rem 1.75rem; border-radius: 100px;
            font-size: .88rem; font-weight: 600; text-decoration: none;
            display: inline-flex; align-items: center; gap: 7px;
            transition: background .2s, transform .15s; white-space: nowrap;
            box-shadow: 0 4px 14px rgba(45,184,176,0.3);
        }
        .btn-cta:hover { background: var(--teal-d); transform: translateY(-1px); }
        .btn-cta svg { width: 15px; height: 15px; stroke: white; stroke-width: 2; fill: none; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 900px) {
            .step-bar { display: none; }
            .top-nav { padding: 0 1.25rem; }
            .hamburger { display: flex; }
            .nav-deadline, .user-name, .nav-logout { display: none; }
            .main { padding-top: var(--nav-h); }
            .content { padding: 1.5rem 1rem 3rem; }
            .welcome-banner { flex-direction: column; align-items: flex-start; padding: 1.5rem; }
            .welcome-banner::after { display: none; }
            .wb-right { gap: 1.5rem; }
            .info-row { grid-template-columns: 1fr 1fr; }
            .continue-cta { flex-direction: column; align-items: flex-start; }
            .btn-cta { width: 100%; justify-content: center; }
        }
        @@media (max-width: 560px) {
            .steps-grid { grid-template-columns: 1fr; }
            .info-row { grid-template-columns: 1fr; }
            .wb-right { flex-direction: row; gap: 1rem; }
            .wb-title { font-size: 1.55rem; }
        }
    </style>
</head>
<body>

<!-- TOP NAV -->
<nav class="top-nav">
    <div class="nav-brand">
        <a href="/"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></a>
    </div>
    <div class="nav-right">
        <div class="nav-deadline">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Deadline: <span class="deadline-val">30 Jun 2026</span>
        </div>
        <div class="nav-user">
            <div class="user-avatar">@initials</div>
            <span class="user-name">@applicantName</span>
        </div>
        <a asp-action="Logout" asp-controller="Account" class="nav-logout">Sign out</a>
        <button class="hamburger" id="hamburger" aria-label="Open menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<!-- STEP BAR -->
<div class="step-bar">
    @foreach (var s in steps) {
        var st = StepStatus(s.Num);
        <a asp-action="@s.Action" asp-controller="Application" class="step-item @st" title="@s.Name">
            <div class="step-num">
                <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                <span>@s.Num</span>
            </div>
            <span class="step-name">@s.Name</span>
        </a>
    }
</div>

<!-- MOBILE DRAWER -->
<div class="drawer-overlay" id="drawerOverlay"></div>
<aside class="side-drawer" id="sideDrawer">
    <div class="drawer-header"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
    <div class="drawer-user">
        <div class="drawer-avatar">@initials</div>
        <div>
            <div class="drawer-uname">@applicantName</div>
            <div class="drawer-uemail">NPI 4.0 Applicant</div>
        </div>
    </div>
    <div class="drawer-steps">
        <span class="drawer-step-label">Application Steps</span>
        @foreach (var s in steps) {
            var st    = StepStatus(s.Num);
            var label = st == "completed" ? "Completed" : st == "active" ? "In progress" : "Locked";
            <a asp-action="@s.Action" asp-controller="Application"
               class="drawer-item @st"
               style="@(st == "locked" ? "pointer-events:none;opacity:.4" : null)">
                <div class="drawer-item-num">
                    <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                    <span>@s.Num</span>
                </div>
                <div>
                    <div class="drawer-item-name">@s.Name</div>
                    <div class="drawer-item-status">@label</div>
                </div>
            </a>
        }
    </div>
    <div class="drawer-footer">
        <a asp-action="Logout" asp-controller="Account" class="drawer-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
        </a>
    </div>
</aside>

<!-- MAIN -->
<main class="main">
    <div class="content">

        <!-- Welcome Banner -->
        <div class="welcome-banner">
            <div>
                <div class="wb-eyebrow">
                    <span class="wb-eyebrow-dot"></span>
                    NPI 4.0 Application
                </div>
                <h1 class="wb-title">
                    Welcome back, <em>@applicantName.Split(' ')[0]</em>
                </h1>
                <p class="wb-sub">
                    @if (completedStep == 0) {
                        <text>You haven't started yet — let's go! Complete all 10 steps to submit your application.</text>
                    } else if (completedStep < totalSteps) {
                        <text>You're @completedStep of @totalSteps steps done. Keep going — you're making great progress!</text>
                    } else {
                        <text>All 10 steps completed. Review your application and submit before the deadline.</text>
                    }
                </p>
            </div>
            <div class="wb-right">
                @if (!string.IsNullOrEmpty(referenceNumber)) {
                    <div class="ref-pill">
                        <div class="ref-label">Reference</div>
                        <div class="ref-value">@referenceNumber</div>
                    </div>
                }
                <div class="ring-wrap">
                    <svg class="progress-ring" viewBox="0 0 86 86">
                        <circle class="ring-bg"   cx="43" cy="43" r="35"/>
                        <circle class="ring-fill" id="ringFill" cx="43" cy="43" r="35"
                                style="stroke-dashoffset: @ringOffset"/>
                    </svg>
                    <div class="ring-label">
                        <span class="ring-pct">@progressPct%</span>
                        <span class="ring-sub">Done</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Step Cards -->
        <div class="section-label">Application steps</div>
        <div class="steps-grid">
            @foreach (var s in steps) {
                var st        = StepStatus(s.Num);
                var badgeCls  = st == "completed" ? "badge-done" : st == "active" ? "badge-active" : st == "locked" ? "badge-locked" : "badge-pending";
                var badgeTxt  = st == "completed" ? "Completed"  : st == "active" ? "In Progress"  : st == "locked" ? "Locked"       : "Not Started";
                var actionTxt = st == "completed" ? "Edit"        : st == "active" ? "Continue"     : "Start";
                <a asp-action="@s.Action" asp-controller="Application"
                   class="step-card @st">
                    <div class="card-top">
                        <div class="card-icon">
                            @if (s.Icon == "check") {
                                <svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                            } else if (s.Icon == "user") {
                                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            } else if (s.Icon == "building") {
                                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                            } else if (s.Icon == "users") {
                                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            } else if (s.Icon == "box") {
                                <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                            } else if (s.Icon == "dollar") {
                                <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                            } else if (s.Icon == "trending") {
                                <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                            } else if (s.Icon == "leaf") {
                                <svg viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                            } else if (s.Icon == "heart") {
                                <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                            } else {
                                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                            }
                        </div>
                        <span class="card-badge @badgeCls">@badgeTxt</span>
                    </div>
                    <div>
                        <div class="card-num">Step @s.Num of @totalSteps</div>
                        <div class="card-name">@s.Name</div>
                    </div>
                    <div class="card-desc">@s.Desc</div>
                    <div class="card-footer">
                        <span class="card-action">
                            @if (st == "locked") {
                                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                <span>Complete previous step</span>
                            } else {
                                <text>@actionTxt</text>
                                <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            }
                        </span>
                    </div>
                </a>
            }
        </div>

        <!-- Info Row -->
        <div class="info-row">
            <div class="info-card">
                <div class="info-icon">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                    <div class="info-label">Deadline</div>
                    <div class="info-value">30 June 2026</div>
                    <div class="info-sub">Closes at 11:59 PM WAT</div>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon">
                    <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
                <div>
                    <div class="info-label">Progress</div>
                    <div class="info-value">@completedStep of @totalSteps steps</div>
                    <div class="info-sub">@progressPct% complete</div>
                </div>
            </div>
            <div class="info-card">
                <div class="info-icon">
                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                </div>
                <div>
                    <div class="info-label">Status</div>
                    <div class="info-value">
                        @if (completedStep == 0)          { <text>Not started</text>     }
                        else if (completedStep < totalSteps) { <text>In progress</text>  }
                        else                              { <text>Ready to submit</text> }
                    </div>
                    <div class="info-sub">
                        @if (!string.IsNullOrEmpty(referenceNumber)) {
                            <text>Ref: @referenceNumber</text>
                        } else {
                            <text>NPI 4.0 Application</text>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Continue / Submit CTA -->
        @* <div class="continue-cta">
            <div class="cta-left">
                @if (completedStep < totalSteps) {
                    <h3>Continue your application</h3>
                    <p>You have @(totalSteps - completedStep) step@(totalSteps - completedStep == 1 ? "" : "s") remaining. Complete all sections and submit before the 30 June 2026 deadline. Your progress is saved automatically.</p>
                } else {
                    <h3>You're ready to submit!</h3>
                    <p>All 10 steps are complete. Review your answers on each step, then submit your application for the NSIA Prize for Innovation 4.0.</p>
                }
            </div>
            @{
                var nextAction = completedStep < totalSteps
                    ? steps[completedStep].Action
                    : "Additional";
                var btnText = completedStep < totalSteps ? "Continue Application" : "Review & Submit";
            }
            <a asp-action="@nextAction" asp-controller="Application" class="btn-cta">
                <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                @btnText
            </a>
        </div> *@

    </div>
</main>

<script>
    // ── Drawer
    const hamburger     = document.getElementById('hamburger');
    const sideDrawer    = document.getElementById('sideDrawer');
    const drawerOverlay = document.getElementById('drawerOverlay');
    const openDrawer  = () => { sideDrawer.classList.add('open'); drawerOverlay.style.display='block'; setTimeout(()=>drawerOverlay.classList.add('open'),10); hamburger.classList.add('open'); document.body.style.overflow='hidden'; };
    const closeDrawer = () => { sideDrawer.classList.remove('open'); drawerOverlay.classList.remove('open'); setTimeout(()=>drawerOverlay.style.display='',300); hamburger.classList.remove('open'); document.body.style.overflow=''; };
    hamburger.addEventListener('click', () => sideDrawer.classList.contains('open') ? closeDrawer() : openDrawer());
    drawerOverlay.addEventListener('click', closeDrawer);

    // ── Animate ring on load
    window.addEventListener('load', () => {
        const ring = document.getElementById('ringFill');
        if (ring) {
            const target = ring.style.strokeDashoffset;
            ring.style.strokeDashoffset = 220;
            ring.style.transition = 'none';
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    ring.style.transition = 'stroke-dashoffset 1.2s ease';
                    ring.style.strokeDashoffset = target;
                });
            });
        }
    });
</script>
</body>
</html>