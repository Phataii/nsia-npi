@{
    ViewData["Title"] = "Pre-Submission Checklist — NSIA Prize for Innovation";
    Layout = null;
    var applicantName = ViewBag.ApplicantName as string ?? "";
    var completedStep = (int)(ViewBag.CompletedStep ?? 0);
    var initials      = string.Join("", applicantName.Split(' ').Take(2).Select(w => w[0]));

    var steps = new[] {
        new { Num = 1,  Name = "Pre-Checklist",    Action = "PreChecklist"   },
        new { Num = 2,  Name = "Personal Info",    Action = "PersonalInfo"   },
        new { Num = 3,  Name = "Company Info",     Action = "CompanyInfo"    },
        new { Num = 4,  Name = "Team Info",        Action = "TeamInfo"       },
