@{
    ViewData["Title"] = "Product, Growth & Traction — NSIA Prize for Innovation";
    Layout = null;
    var applicantName = ViewBag.ApplicantName as string ?? "";
    var completedStep = (int)(ViewBag.CompletedStep ?? 4);
    var initials      = string.Join("", applicantName.Split(' ').Take(2).Select(w => w[0]));

    var steps = new[] {
        new { Num = 1,  Name = "Pre-Checklist",    Action = "PreChecklist"   },
        new { Num = 2,  Name = "Personal Info",    Action = "PersonalInfo"   },
        new { Num = 3,  Name = "Company Info",     Action = "CompanyInfo"    },
        new { Num = 4,  Name = "Team Info",        Action = "TeamInfo"       },
        new { Num = 5,  Name = "Product & Growth", Action = "ProductInfo"    },
        new { Num = 6,  Name = "Commercial I",     Action = "Commercial1"    },
        new { Num = 7,  Name = "Commercial II",    Action = "Commercial2"    },
        new { Num = 8,  Name = "Sustainability",   Action = "Sustainability" },
        new { Num = 9,  Name = "Impact",           Action = "Impact"         },
        new { Num = 10, Name = "Additional Info",       Action = "Additional"     },
    };

    string StepStatus(int num) {
        if (num <= completedStep) return "completed";
        if (num == completedStep + 1) return "active";
        return "locked";
    }

    var savedMilestones = (ViewBag.KeyMilestones as string ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList();
    var savedFeatures = (ViewBag.KeyFeatures as string ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal: #2DB8B0; --teal-d: #1a9990; --teal-deep: #0d7a73;
            --teal-light: #E8F7F6; --teal-pale: #F0FAF9;
            --green: #7BC144; --green-dark: #5a9130;
            --ink: #1C2B2A; --cream: #F5F9F8; --off: #EEF4F3;
            --muted: #4A6260; --border: rgba(45,184,176,0.2);
            --nav-h: 62px; --step-h: 56px;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'DM Sans', sans-serif; background: var(--off); color: var(--ink); min-height: 100vh; }
        .top-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 200; height: var(--nav-h); background: white; display: flex; align-items: center; padding: 0 2rem; justify-content: space-between; }
        .top-nav::after { content: ''; position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.08) 0%, transparent 60%); }
        .nav-brand { display: flex; align-items: center; position: relative; z-index: 1; }
        .nav-brand img { height: 32px; width: auto; }
        .nav-right { display: flex; align-items: center; gap: 1.25rem; position: relative; z-index: 1; }
        
        .nav-deadline { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--ink); }
        .nav-deadline svg { width: 13px; height: 13px; stroke: var(--ink); stroke-width: 1.75; fill: none; }
        .deadline-val { color: var(--ink); font-weight: 600; }
        .nav-user { display: flex; align-items: center; gap: 8px; }
        
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--ink); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; color: white; flex-shrink: 0; }
        .user-name { font-size: 12px; color: var(--ink); }
        .nav-logout { font-size: 11px; color: var(--ink); text-decoration: none; padding: .3rem .7rem; border: 1px solid var(--green-dark); border-radius: 100px; transition: all .2s; white-space: nowrap; }
        .nav-logout:hover { color: white; border-color: var(--teal-dark); background: var(--ink); }

        .hamburger { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; position: relative; z-index: 1; }
        .hamburger span { display: block; width: 22px; height: 2px; background: white; border-radius: 2px; transition: transform .3s, opacity .3s; }
        .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
        .hamburger.open span:nth-child(2) { opacity: 0; }
        .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
        
        /* ── STEP BAR ── */
        .step-bar { position: fixed; top: var(--nav-h); left: 0; right: 0; z-index: 190; height: var(--step-h); background: white; border-bottom: 1px solid var(--green); display: flex; align-items: stretch; overflow: hidden; }
        .step-item { flex: 1; display: flex; align-items: center; justify-content: center; gap: 6px; padding: 0 .35rem; text-decoration: none; color: var(--green); border-right: 1px solid var(--green); position: relative; transition: background .2s; min-width: 0; }
        .step-item:last-child { border-right: none; }
        .step-item::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 2px; background: transparent; transition: background .2s; }
        .step-item:hover { background: var(--teal-pale); }
        .step-item.completed .step-num { background: var(--green); border-color: var(--green); color: white; }
        .step-item.completed .step-num svg { display: block; }
        .step-item.completed .step-num span { display: none; }
        .step-item.completed .step-name { color: var(--green); }
        .step-item.completed::after { background: var(--green); }
        .step-item.active { background: var(--teal-pale); }
        .step-item.active .step-num { background: var(--green); border-color: var(--green); color: white; }
        .step-item.active .step-name { color: var(--green); font-weight: 500; }
        .step-item.active::after { background: var(--green); }
        .step-num { width: 20px; height: 20px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: center; font-size: 9px; font-weight: 500; color: var(--muted); }
        .step-num svg { width: 9px; height: 9px; stroke: white; stroke-width: 3; fill: none; display: none; }
        .step-name { font-size: 10.5px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        
        .drawer-overlay { display: none; position: fixed; inset: 0; z-index: 150; background: rgba(0,0,0,0.5); opacity: 0; transition: opacity .3s; }
        .drawer-overlay.open { opacity: 1; }
        .side-drawer { position: fixed; top: 0; left: -280px; bottom: 0; z-index: 160; width: 280px; background: var(--ink); display: flex; flex-direction: column; transition: left .3s cubic-bezier(0.4,0,0.2,1); overflow-y: auto; }
        .side-drawer.open { left: 0; }
        .drawer-header { padding: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
        .drawer-header img { height: 30px; width: auto; filter: brightness(0) invert(1); }
        .drawer-user { padding: 1rem 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; align-items: center; gap: 10px; }
        .drawer-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: white; flex-shrink: 0; }
        .drawer-uname { font-size: 13px; font-weight: 500; color: white; }
        .drawer-uemail { font-size: 11px; color: rgba(255,255,255,0.35); }
        .drawer-steps { padding: .75rem 0; flex: 1; }
        .drawer-step-label { font-size: 10px; font-weight: 500; color: rgba(255,255,255,0.3); letter-spacing: .1em; text-transform: uppercase; padding: .5rem 1.25rem .25rem; display: block; }
        .drawer-item { display: flex; align-items: center; gap: .9rem; padding: .75rem 1.25rem; text-decoration: none; color: rgba(255,255,255,0.55); transition: background .2s, color .2s; position: relative; }
        .drawer-item:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.85); }
        .drawer-item.active { background: rgba(45,184,176,0.15); color: white; }
        .drawer-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--teal); border-radius: 0 2px 2px 0; }
        .drawer-item-num { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 500; }
        .drawer-item.completed .drawer-item-num { background: var(--teal); border-color: var(--teal); }
        .drawer-item.active .drawer-item-num { background: var(--teal); border-color: var(--teal); }
        .drawer-item-num svg { width: 10px; height: 10px; stroke: white; stroke-width: 3; fill: none; display: none; }
        .drawer-item.completed .drawer-item-num svg { display: block; }
        .drawer-item.completed .drawer-item-num span { display: none; }
        .drawer-item-name { font-size: 13px; }
        .drawer-item-status { font-size: 10px; color: rgba(255,255,255,0.25); }
        .drawer-item.completed .drawer-item-status { color: var(--teal); }
        .drawer-item.active .drawer-item-status { color: rgba(45,184,176,0.8); }
        .drawer-footer { padding: 1rem 1.25rem; border-top: 1px solid rgba(255,255,255,0.08); }
        .drawer-logout { display: flex; align-items: center; gap: .6rem; font-size: 12px; color: rgba(255,255,255,0.35); text-decoration: none; transition: color .2s; }
        .drawer-logout svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.75; fill: none; }
        .drawer-logout:hover { color: rgba(255,255,255,0.65); }
        .main { padding-top: calc(var(--nav-h) + var(--step-h)); min-height: 100vh; }
        .content { max-width: 760px; margin: 0 auto; padding: 2.5rem 2rem 4rem; }
        .page-header { margin-bottom: 2rem; }
        .breadcrumb { display: flex; align-items: center; gap: .4rem; font-size: 11px; color: var(--muted); margin-bottom: .75rem; flex-wrap: wrap; }
        .breadcrumb a { color: var(--teal); text-decoration: none; }
        .breadcrumb a:hover { text-decoration: underline; }
        .breadcrumb svg { width: 10px; height: 10px; stroke: var(--muted); stroke-width: 2; fill: none; }
        .page-title { font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif; font-size: 2rem; font-weight: 700; color: var(--ink); line-height: 1.1; margin-bottom: .35rem; }
        .page-sub { font-size: .84rem; color: var(--muted); line-height: 1.65; }
        .step-mini { display: flex; align-items: center; gap: .75rem; background: white; border-radius: 8px; border: 1px solid var(--border); padding: .85rem 1.25rem; margin-bottom: 2rem; }
        .step-mini-dot { width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; background: var(--teal); color: white; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; }
        .step-mini-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; }
        .step-mini-name { font-size: .85rem; font-weight: 500; color: var(--ink); }
        .step-mini-spacer { flex: 1; }
        .step-mini-progress { font-size: 11px; color: var(--muted); white-space: nowrap; }
        .step-mini-bar { width: 120px; height: 4px; background: var(--off); border-radius: 10px; overflow: hidden; flex-shrink: 0; }
        .step-mini-fill { height: 100%; background: linear-gradient(to right, var(--teal), var(--green)); border-radius: 10px; width: 50%; }
        .form-card { background: white; border-radius: 12px; border: 1px solid var(--border); overflow: hidden; margin-bottom: 1.25rem; }
        .form-card-header { padding: 1.1rem 1.75rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 1rem; }
        .form-card-icon { width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: var(--teal-light); }
        .form-card-icon svg { width: 17px; height: 17px; stroke: var(--teal); stroke-width: 1.75; fill: none; }
        .form-card-title { font-size: .92rem; font-weight: 500; color: var(--ink); margin-bottom: 2px; }
        .form-card-desc { font-size: .74rem; color: var(--muted); line-height: 1.4; }
        .form-card-body { padding: 1.75rem; display: flex; flex-direction: column; gap: 1.35rem; }
        .form-group { display: flex; flex-direction: column; gap: .38rem; }
        label.field-label { font-size: .75rem; font-weight: 500; color: var(--ink); letter-spacing: .02em; }
        .label-req { color: #e53e3e; margin-left: 2px; }
        .label-opt { font-size: .68rem; color: var(--muted); font-weight: 400; margin-left: 4px; }

        /* Radio options */
        .radio-options { display: flex; flex-direction: column; gap: .6rem; }
        .radio-options.cols-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
        .r-option { position: relative; }
        .r-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
        .r-label { display: flex; align-items: flex-start; gap: .75rem; padding: .8rem 1.1rem; border-radius: 8px; border: 1.5px solid var(--border); background: white; cursor: pointer; transition: border-color .2s, background .2s; user-select: none; }
        .r-label:hover { border-color: var(--teal); background: var(--teal-pale); }
        .r-option input:checked + .r-label { border-color: var(--teal); background: var(--teal-light); }
        .r-radio { width: 18px; height: 18px; border-radius: 50%; flex-shrink: 0; border: 1.5px solid rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; transition: all .2s; margin-top: 1px; }
        .r-option input:checked + .r-label .r-radio { border-color: var(--teal); background: var(--teal); }
        .r-dot { width: 6px; height: 6px; border-radius: 50%; background: white; opacity: 0; transform: scale(0); transition: all .15s; }
        .r-option input:checked + .r-label .r-dot { opacity: 1; transform: scale(1); }
        .r-text { font-size: .82rem; color: var(--ink); flex: 1; line-height: 1.45; }
        .r-sub { font-size: .7rem; color: var(--muted); margin-top: 1px; }
        .r-option input:checked + .r-label .r-text { color: var(--teal-deep); font-weight: 500; }

        /* Multi-select */
        .mc-options { display: flex; flex-direction: column; gap: .6rem; }
        .mc-options.cols-2 { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; }
        .mc-option { position: relative; }
        .mc-option input[type="checkbox"] { position: absolute; opacity: 0; width: 0; height: 0; }
        .mc-label { display: flex; align-items: flex-start; gap: .75rem; padding: .8rem 1.1rem; border-radius: 8px; border: 1.5px solid var(--border); background: white; cursor: pointer; transition: border-color .2s, background .2s; user-select: none; }
        .mc-label:hover { border-color: var(--teal); background: var(--teal-pale); }
        .mc-option input:checked + .mc-label { border-color: var(--teal); background: var(--teal-light); }
        .mc-box { width: 18px; height: 18px; border-radius: 4px; flex-shrink: 0; border: 1.5px solid rgba(0,0,0,0.2); display: flex; align-items: center; justify-content: center; transition: all .15s; margin-top: 1px; }
        .mc-option input:checked + .mc-label .mc-box { background: var(--teal); border-color: var(--teal); }
        .mc-box svg { width: 10px; height: 10px; stroke: white; stroke-width: 3; fill: none; opacity: 0; }
        .mc-option input:checked + .mc-label .mc-box svg { opacity: 1; }
        .mc-text { font-size: .82rem; color: var(--ink); flex: 1; line-height: 1.45; }
        .mc-sub { font-size: .7rem; color: var(--muted); margin-top: 1px; }
        .mc-option input:checked + .mc-label .mc-text { color: var(--teal-deep); font-weight: 500; }

        /* Validation */
        .field-error { font-size: .71rem; color: #b91c1c; display: none; margin-top: .2rem; }
        .form-group.invalid .field-error { display: block; }
        .form-group.invalid .r-label { border-color: #f87171; }
        .form-group.invalid .mc-label { border-color: #f87171; }

        .form-actions { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-top: 1.25rem; }
        .actions-left { display: flex; align-items: center; gap: .75rem; }
        .btn-back { display: inline-flex; align-items: center; gap: 6px; padding: .72rem 1.3rem; border-radius: 100px; border: 1px solid var(--border); background: white; font-size: .84rem; color: var(--muted); text-decoration: none; font-family: 'DM Sans', sans-serif; transition: all .2s; }
        .btn-back:hover { border-color: var(--teal); color: var(--teal); }
        .btn-back svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 2; fill: none; }
        .btn-save { display: inline-flex; align-items: center; gap: 7px; padding: .72rem 1.5rem; border-radius: 100px; background: white; border: 1px solid var(--teal); font-size: .84rem; font-weight: 500; color: var(--teal); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all .2s; }
        .btn-save:hover { background: var(--teal-pale); }
        .btn-save svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 2; fill: none; }
        .btn-next { display: inline-flex; align-items: center; gap: 7px; padding: .76rem 1.75rem; border-radius: 100px; background: var(--teal); color: white; border: none; font-size: .88rem; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background .2s, transform .15s; }
        .btn-next:hover { background: var(--teal-d); transform: translateY(-1px); }
        .btn-next:active { transform: scale(0.98); }
        .btn-next svg { width: 15px; height: 15px; stroke: white; stroke-width: 2; fill: none; }
        .toast { position: fixed; bottom: 2rem; right: 2rem; z-index: 300; background: var(--ink); color: white; padding: .75rem 1.25rem; border-radius: 100px; font-size: .8rem; display: flex; align-items: center; gap: .6rem; box-shadow: 0 4px 20px rgba(0,0,0,0.15); transform: translateY(20px); opacity: 0; transition: transform .3s, opacity .3s; pointer-events: none; }
        .toast.show { transform: translateY(0); opacity: 1; }
        .toast svg { width: 14px; height: 14px; stroke: var(--green); stroke-width: 2; fill: none; flex-shrink: 0; }

        @@media (max-width: 900px) {
            .step-bar { display: none; }
            .top-nav { padding: 0 1.25rem; }
            .hamburger { display: flex; }
            .nav-deadline, .user-name, .nav-logout { display: none; }
            .main { padding-top: var(--nav-h); }
            .content { padding: 1.5rem 1rem 3rem; }
            .step-mini-bar, .step-mini-progress { display: none; }
            .radio-options.cols-2 { grid-template-columns: 1fr; }
            .mc-options.cols-2 { grid-template-columns: 1fr; }
        }
        @@media (max-width: 560px) {
            .page-title { font-size: 1.65rem; }
            .form-card-body { padding: 1.25rem; }
            .form-actions { flex-direction: column; align-items: stretch; }
            .actions-left { justify-content: space-between; }
            .btn-next { justify-content: center; padding: 1rem; }
            .toast { left: 1rem; right: 1rem; bottom: 1rem; justify-content: center; }
        }
    </style>
</head>
<body>

<!-- TOP NAV -->
<nav class="top-nav">
    <div class="nav-brand"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
    <div class="nav-right">
        <div class="nav-deadline">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Deadline: <span class="deadline-val">30 Jun 2026</span>
        </div>
        <div class="nav-user">
            <div class="user-avatar">@initials</div>
            <span class="user-name">@applicantName</span>
        </div>
        <a asp-action="Logout" asp-controller="Account" class="nav-logout">Sign out</a>
        <button class="hamburger" id="hamburger" aria-label="Open menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

<!-- STEP BAR -->
<div class="step-bar">
    @foreach (var s in steps) {
        var st = StepStatus(s.Num);
        <a asp-action="@s.Action" asp-controller="Application" class="step-item @st" title="@s.Name">
            <div class="step-num">
                <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                <span>@s.Num</span>
            </div>
            <span class="step-name">@s.Name</span>
        </a>
    }
</div>

<!-- MOBILE DRAWER -->
<div class="drawer-overlay" id="drawerOverlay"></div>
<aside class="side-drawer" id="sideDrawer">
    <div class="drawer-header"> <a href="/"><img src="~/logo.png" alt="NSIA" /></a></div>
    <div class="drawer-user">
        <div class="drawer-avatar">@initials</div>
        <div><div class="drawer-uname">@applicantName</div><div class="drawer-uemail">NPI 4.0 Applicant</div></div>
    </div>
    <div class="drawer-steps">
        <span class="drawer-step-label">Application Steps</span>
        @foreach (var s in steps) {
            var st    = StepStatus(s.Num);
            var label = st == "completed" ? "Completed" : st == "active" ? "In progress" : "Locked";
            <a asp-action="@s.Action" asp-controller="Application"
               class="drawer-item @st"
               style="@(st == "locked" ? "pointer-events:none;opacity:.4" : null)">
                <div class="drawer-item-num">
                    <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                    <span>@s.Num</span>
                </div>
                <div>
                    <div class="drawer-item-name">@s.Name</div>
                    <div class="drawer-item-status">@label</div>
                </div>
            </a>
        }
    </div>
    <div class="drawer-footer">
        <a asp-action="Logout" asp-controller="Account" class="drawer-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
        </a>
    </div>
</aside>

<!-- MAIN -->
<main class="main">
    <div class="content">

        <div class="page-header">
            <div class="breadcrumb">
                <a asp-action="Dashboard" asp-controller="Application">Dashboard</a>
                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                <span>Product, Growth &amp; Traction</span>
            </div>
            <h1 class="page-title">Product, Growth &amp; Traction</h1>
            <p class="page-sub">Tell us about your product, where you are in your growth journey, and the traction you have achieved so far.</p>
        </div>

        <div class="step-mini">
            <div class="step-mini-dot">5</div>
            <div>
                <div class="step-mini-label">Step 5 of 10</div>
                <div class="step-mini-name">Product, Growth &amp; Traction</div>
            </div>
            <div class="step-mini-spacer"></div>
            <span class="step-mini-progress">Step 5 of 10</span>
            <div class="step-mini-bar"><div class="step-mini-fill"></div></div>
        </div>

        <form asp-action="SaveProductInfo" asp-controller="Application"
              method="post" id="productForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- ── CARD 1: Growth Stage ── -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon">
                        <svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                    <div>
                        <div class="form-card-title">Growth Stage &amp; Milestones</div>
                        <div class="form-card-desc">Where your business currently is in its growth journey.</div>
                    </div>
                </div>
                <div class="form-card-body">

                    <!-- Growth Stage -->
                    <div class="form-group" id="grp-stage">
                        <label class="field-label">
                            What stage of growth is your business currently at? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options">
                            @{
                                var stages = new[]
                                {
                                    ("Startup Stage",     "We are in the startup stage, building and validating our business model."),
                                    ("Growth Stage",      "We are in the growth stage, expanding our market reach and scaling operations."),
                                    ("Established Stage", "We are an established business with a solid market presence and steady revenue."),
                                    ("Mature Business",   "Mature Business, Industry leader with significant market share."),
                                };
                            }
                            @foreach (var (val, desc) in stages) {
                                <div class="r-option">
                                    <input type="radio" id="stage-@val.Replace(" ","-").ToLower()"
                                           name="GrowthStage" value="@val"
                                           @(ViewBag.GrowthStage == val ? "checked" : "") />
                                    <label class="r-label" for="stage-@val.Replace(" ","-").ToLower()">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <div>
                                            <div class="r-text">@val</div>
                                            <div class="r-sub">@desc</div>
                                        </div>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select your growth stage.</div>
                    </div>

                    <!-- Key Milestones — select top 2 -->
                    <div class="form-group" id="grp-milestones">
                        <label class="field-label">
                            What key milestones has your business achieved so far?
                            <span class="label-req">*</span>
                            <span class="label-opt">(select up to 2)</span>
                        </label>
                        <div class="mc-options">
                            @{
                                var milestones = new[]
                                {
                                    "Secured initial funding and developed a prototype",
                                    "Launched a pilot program and gained early adopters",
                                    "Established key partnerships and collaborations",
                                    "Received industry recognition and awards",
                                };
                            }
                            @foreach (var m in milestones) {
                                <div class="mc-option">
                                    <input type="checkbox" id="ms-@m.Replace(" ","-").ToLower().Substring(0,15)"
                                           name="KeyMilestones" value="@m"
                                           @(savedMilestones.Contains(m) ? "checked" : "") />
                                    <label class="mc-label" for="ms-@m.Replace(" ","-").ToLower().Substring(0,15)">
                                        <div class="mc-box"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div>
                                        <span class="mc-text">@m</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select at least one milestone.</div>
                    </div>

                </div>
            </div>

            <!-- ── CARD 2: Users & Traction ── -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div>
                        <div class="form-card-title">Users &amp; Traction</div>
                        <div class="form-card-desc">Current customer base and total users who have interacted with your product.</div>
                    </div>
                </div>
                <div class="form-card-body">

                    <!-- Existing Users -->
                    <div class="form-group" id="grp-existingusers">
                        <label class="field-label">
                            How many existing users/customers do you have? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options cols-2">
                            @{
                                var userRanges = new[]{"1-50","51-200","201-500","500+"};
                            }
                            @foreach (var val in userRanges) {
                                <div class="r-option">
                                    <input type="radio" id="eu-@val" name="ExistingUsers" value="@val"
                                           @(ViewBag.ExistingUsers == val ? "checked" : "") />
                                    <label class="r-label" for="eu-@val">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select an option.</div>
                    </div>

                    <!-- Total Users Reached -->
                    <div class="form-group" id="grp-totalusers">
                        <label class="field-label">
                            Approximately how many users have interacted with or used your product/service? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options cols-2">
                            @foreach (var val in userRanges) {
                                <div class="r-option">
                                    <input type="radio" id="tu-@val" name="TotalUsersReached" value="@val"
                                           @(ViewBag.TotalUsersReached == val ? "checked" : "") />
                                    <label class="r-label" for="tu-@val">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select an option.</div>
                    </div>

                </div>
            </div>

            <!-- ── CARD 3: Business Model & Strategy ── -->
            <div class="form-card">
                <div class="form-card-header">
                    <div class="form-card-icon">
                        <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </div>
                    <div>
                        <div class="form-card-title">Business Model &amp; Strategy</div>
                        <div class="form-card-desc">How your business operates and competes in the market.</div>
                    </div>
                </div>
                <div class="form-card-body">

                    <!-- Core Business Model -->
                    <div class="form-group" id="grp-bizmodel">
                        <label class="field-label">
                            What is your core business model? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options cols-2">
                            @{
                                var bizModels = new[]
                                {
                                    "Subscription-based services",
                                    "One-time purchase with maintenance options",
                                    "Partnership and licensing agreements",
                                    "Free with premium features",
                                };
                            }
                            @foreach (var val in bizModels) {
                                <div class="r-option">
                                    <input type="radio" id="bm-@val.Replace(" ","-").Replace("/","-").ToLower().Substring(0,12)"
                                           name="CoreBusinessModel" value="@val"
                                           @(ViewBag.CoreBusinessModel == val ? "checked" : "") />
                                    <label class="r-label" for="bm-@val.Replace(" ","-").Replace("/","-").ToLower().Substring(0,12)">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select your business model.</div>
                    </div>

                    <!-- USP -->
                    <div class="form-group" id="grp-usp">
                        <label class="field-label">
                            What is your Unique Selling Point (USP)? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options">
                            @{
                                var usps = new[]
                                {
                                    "Affordable and scalable solutions tailored to local needs",
                                    "Innovative technology with user-friendly interfaces",
                                    "Comprehensive support and training",
                                    "Sustainable and eco-friendly practices",
                                };
                            }
                            @foreach (var val in usps) {
                                <div class="r-option">
                                    <input type="radio" id="usp-@val.Replace(" ","-").ToLower().Substring(0,12)"
                                           name="UniqueSellingPoint" value="@val"
                                           @(ViewBag.UniqueSellingPoint == val ? "checked" : "") />
                                    <label class="r-label" for="usp-@val.Replace(" ","-").ToLower().Substring(0,12)">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select your USP.</div>
                    </div>

                    <!-- Competitors -->
                    <div class="form-group" id="grp-competitors">
                        <label class="field-label">
                            Who are your main competitors? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options cols-2">
                            @{
                                var competitors = new[]
                                {
                                    "Established industry leaders",
                                    "Emerging startups",
                                    "Local service providers",
                                    "International corporations",
                                };
                            }
                            @foreach (var val in competitors) {
                                <div class="r-option">
                                    <input type="radio" id="comp-@val.Replace(" ","-").ToLower().Substring(0,12)"
                                           name="MainCompetitors" value="@val"
                                           @(ViewBag.MainCompetitors == val ? "checked" : "") />
                                    <label class="r-label" for="comp-@val.Replace(" ","-").ToLower().Substring(0,12)">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select your main competitors.</div>
                    </div>

                    <!-- Market Penetration -->
                    <div class="form-group" id="grp-penetration">
                        <label class="field-label">
                            How do you plan to penetrate the market with your products/services? <span class="label-req">*</span>
                        </label>
                        <div class="radio-options cols-2">
                            @{
                                var penetrations = new[]
                                {
                                    "Direct sales and strategic partnerships",
                                    "Online marketing and social media campaigns",
                                    "Community outreach and engagement",
                                    "Industry events and trade shows",
                                };
                            }
                            @foreach (var val in penetrations) {
                                <div class="r-option">
                                    <input type="radio" id="pen-@val.Replace(" ","-").ToLower().Substring(0,12)"
                                           name="MarketPenetrationStrategy" value="@val"
                                           @(ViewBag.MarketPenetrationStrategy == val ? "checked" : "") />
                                    <label class="r-label" for="pen-@val.Replace(" ","-").ToLower().Substring(0,12)">
                                        <div class="r-radio"><div class="r-dot"></div></div>
                                        <span class="r-text">@val</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select a market penetration strategy.</div>
                    </div>

                    <!-- Key Features — select top 2 -->
                    <div class="form-group" id="grp-features">
                        <label class="field-label">
                            What are the key features of your product/service?
                            <span class="label-req">*</span>
                            <span class="label-opt">(select up to 2)</span>
                        </label>
                        <div class="mc-options cols-2">
                            @{
                                var features = new[]
                                {
                                    "User-friendly interface",
                                    "Cost-effectiveness",
                                    "Scalability",
                                    "Sustainability",
                                };
                            }
                            @foreach (var f in features) {
                                <div class="mc-option">
                                    <input type="checkbox" id="feat-@f.Replace(" ","-").ToLower()"
                                           name="KeyFeatures" value="@f"
                                           @(savedFeatures.Contains(f) ? "checked" : "") />
                                    <label class="mc-label" for="feat-@f.Replace(" ","-").ToLower()">
                                        <div class="mc-box"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></div>
                                        <span class="mc-text">@f</span>
                                    </label>
                                </div>
                            }
                        </div>
                        <div class="field-error">Please select at least one key feature.</div>
                    </div>

                </div>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <div class="actions-left">
                    <a asp-action="TeamInfo" asp-controller="Application" class="btn-back">
                        <svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
                        Back
                    </a>
                    <button type="button" class="btn-save" id="saveBtn">
                        <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                        Save draft
                    </button>
                </div>
                <button type="submit" class="btn-next" id="nextBtn">
                    Save &amp; Continue
                    <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </button>
            </div>

        </form>
    </div>
</main>

<div class="toast" id="toast">
    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span id="toastMsg">Draft saved</span>
</div>

<script>
    // ── Drawer
    const hamburger     = document.getElementById('hamburger');
    const sideDrawer    = document.getElementById('sideDrawer');
    const drawerOverlay = document.getElementById('drawerOverlay');
    const openDrawer  = () => { sideDrawer.classList.add('open'); drawerOverlay.style.display='block'; setTimeout(()=>drawerOverlay.classList.add('open'),10); hamburger.classList.add('open'); document.body.style.overflow='hidden'; };
    const closeDrawer = () => { sideDrawer.classList.remove('open'); drawerOverlay.classList.remove('open'); setTimeout(()=>drawerOverlay.style.display='',300); hamburger.classList.remove('open'); document.body.style.overflow=''; };
    hamburger.addEventListener('click', () => sideDrawer.classList.contains('open') ? closeDrawer() : openDrawer());
    drawerOverlay.addEventListener('click', closeDrawer);

    // ── Max 2 checkboxes for milestones and features
    function limitCheckboxes(name, max) {
        document.querySelectorAll(`input[name="${name}"]`).forEach(cb => {
            cb.addEventListener('change', () => {
                const checked = document.querySelectorAll(`input[name="${name}"]:checked`);
                if (checked.length > max) cb.checked = false;
            });
        });
    }
    limitCheckboxes('KeyMilestones', 2);
    limitCheckboxes('KeyFeatures', 2);

    // ── Validation
    function setInvalid(id)   { document.getElementById(id)?.classList.add('invalid'); }
    function clearInvalid(id) { document.getElementById(id)?.classList.remove('invalid'); }

    const radioMap = {
        GrowthStage:              'grp-stage',
        ExistingUsers:            'grp-existingusers',
        TotalUsersReached:        'grp-totalusers',
        CoreBusinessModel:        'grp-bizmodel',
        UniqueSellingPoint:       'grp-usp',
        MainCompetitors:          'grp-competitors',
        MarketPenetrationStrategy:'grp-penetration',
    };
    Object.keys(radioMap).forEach(name => {
        document.querySelectorAll(`input[name="${name}"]`).forEach(r =>
            r.addEventListener('change', () => clearInvalid(radioMap[name]))
        );
    });
    ['KeyMilestones','KeyFeatures'].forEach(name => {
        document.querySelectorAll(`input[name="${name}"]`).forEach(c =>
            c.addEventListener('change', () => clearInvalid(name === 'KeyMilestones' ? 'grp-milestones' : 'grp-features'))
        );
    });

    function validate() {
        let ok = true;
        Object.entries(radioMap).forEach(([name, grp]) => {
            if (!document.querySelector(`input[name="${name}"]:checked`))
                { setInvalid(grp); ok = false; }
        });
        if (!document.querySelector('input[name="KeyMilestones"]:checked'))
            { setInvalid('grp-milestones'); ok = false; }
        if (!document.querySelector('input[name="KeyFeatures"]:checked'))
            { setInvalid('grp-features'); ok = false; }
        if (!ok) document.querySelector('.invalid')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return ok;
    }

    // ── Toast
    function showToast(msg, isError) {
        const t = document.getElementById('toast');
        t.querySelector('svg').style.stroke = isError ? '#f87171' : 'var(--green)';
        document.getElementById('toastMsg').textContent = msg;
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // ── Save draft
    document.getElementById('saveBtn').addEventListener('click', async () => {
        const btn = document.getElementById('saveBtn');
        btn.textContent = 'Saving...'; btn.disabled = true;
        try {
            const fd  = new FormData(document.getElementById('productForm'));
            const res = await fetch('/Application/SaveProductInfoDraft', { method: 'POST', body: fd });
            showToast(res.ok ? 'Draft saved' : 'Could not save', !res.ok);
        } catch { showToast('Could not save', true); }
        finally {
            btn.innerHTML = '<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Save draft';
            btn.disabled = false;
        }
    });

    // ── Submit
    document.getElementById('productForm').addEventListener('submit', function(e) {
        if (!validate()) { e.preventDefault(); return; }
        const btn = document.getElementById('nextBtn');
        btn.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Saving...';
        btn.disabled = true;
    });
</script>
</body>
</html>