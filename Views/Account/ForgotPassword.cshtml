@{
    ViewData["Title"] = "Forgot Password — NSIA Prize for Innovation";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --teal-pale: #F0FAF9;
                --green: #7BC144;
                --ink: #1C2B2A;
                --muted: #4A6260;
                --off: #EEF4F3;
                --border: rgba(45, 184, 176, 0.2);
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--teal-light);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1.5rem;
                position: relative;
                overflow: hidden;
            }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                pointer-events: none;
                @* background:
                    radial-gradient(ellipse at 15% 40%, rgba(13, 122, 115, 0.5) 0%, transparent 55%),
                    radial-gradient(ellipse at 85% 70%, rgba(123, 193, 68, 0.2) 0%, transparent 50%); *@
            }

            body::after {
                content: 'NPI';
                position: fixed;
                right: -2rem;
                bottom: -3rem;
                font-family: 'Cormorant Garamond', serif;
                font-size: 20rem;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.05);
                line-height: 1;
                pointer-events: none;
            }

            .card-wrap {
                width: 100%;
                max-width: 440px;
                position: relative;
                z-index: 1;
            }

            /* Back link */
            .back-link {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-size: .78rem;
                color: rgba(255, 255, 255, 0.7);
                text-decoration: none;
                margin-bottom: 1.5rem;
                transition: color .2s;
            }

            .back-link:hover {
                color: white;
            }

            .back-link svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            /* Card */
            .card {
                background: white;
                border-radius: 16px;
                padding: 2.5rem;
                width: 100%;
                box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
            }

            .card-logo {
                margin-bottom: 1.75rem;
            }

            .card-logo img {
                height: 30px;
                width: auto;
            }

            .card-title {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .35rem;
                line-height: 1.1;
            }

            .card-sub {
                font-size: .82rem;
                color: var(--muted);
                line-height: 1.65;
                margin-bottom: 1.75rem;
            }

            /* Success state */
            .success-state {
                text-align: center;
                padding: 1rem 0;
            }

            .success-icon {
                width: 64px;
                height: 64px;
                border-radius: 50%;
                background: var(--teal-light);
                margin: 0 auto 1.25rem;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .success-icon svg {
                width: 28px;
                height: 28px;
                stroke: var(--teal);
                stroke-width: 2;
                fill: none;
            }

            .success-title {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .5rem;
            }

            .success-sub {
                font-size: .82rem;
                color: var(--muted);
                line-height: 1.7;
                margin-bottom: 1.75rem;
            }

            .success-email {
                font-weight: 500;
                color: var(--teal);
            }

            /* Form */
            .form-group {
                display: flex;
                flex-direction: column;
                gap: .38rem;
                margin-bottom: 1.1rem;
            }

            label.field-label {
                font-size: .74rem;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .02em;
            }

            .input-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                pointer-events: none;
            }

            .input-icon svg {
                width: 15px;
                height: 15px;
                stroke: var(--muted);
                stroke-width: 1.75;
                fill: none;
                display: block;
            }

            input[type="email"] {
                width: 100%;
                padding: .75rem .9rem .75rem 2.5rem;
                border: 1px solid var(--border);
                border-radius: 8px;
                font-size: .85rem;
                font-family: 'DM Sans', sans-serif;
                color: var(--ink);
                outline: none;
                transition: border-color .2s, box-shadow .2s;
                background: white;
            }

            input:focus {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(45, 184, 176, 0.12);
            }

            input::placeholder {
                color: #aab5af;
            }

            /* Error */
            .error-banner {
                background: rgba(220, 38, 38, 0.07);
                border: 1px solid rgba(220, 38, 38, 0.2);
                border-radius: 8px;
                padding: .75rem 1rem;
                font-size: .8rem;
                color: #b91c1c;
                display: flex;
                align-items: center;
                gap: .6rem;
                margin-bottom: 1.25rem;
            }

            .error-banner svg {
                width: 15px;
                height: 15px;
                stroke: #b91c1c;
                stroke-width: 1.75;
                fill: none;
                flex-shrink: 0;
            }

            /* Buttons */
            .btn-primary {
                width: 100%;
                background: var(--teal);
                color: white;
                padding: .85rem;
                border: none;
                border-radius: 100px;
                font-size: .9rem;
                font-weight: 600;
                font-family: 'DM Sans', sans-serif;
                cursor: pointer;
                transition: background .2s, transform .15s;
                box-shadow: 0 4px 14px rgba(45, 184, 176, 0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }

            .btn-primary:hover {
                background: var(--teal-d);
                transform: translateY(-1px);
            }

            .btn-primary:active {
                transform: scale(0.98);
            }

            .btn-primary svg {
                width: 15px;
                height: 15px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            .btn-primary:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

            .btn-outline {
                width: 100%;
                background: white;
                color: var(--teal);
                padding: .85rem;
                border: 1.5px solid var(--teal);
                border-radius: 100px;
                font-size: .9rem;
                font-weight: 500;
                font-family: 'DM Sans', sans-serif;
                cursor: pointer;
                transition: background .2s;
                text-decoration: none;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                margin-top: .75rem;
            }

            .btn-outline:hover {
                background: var(--teal-pale);
            }

            .btn-outline svg {
                width: 15px;
                height: 15px;
                stroke: var(--teal);
                stroke-width: 2;
                fill: none;
            }

            .divider {
                text-align: center;
                font-size: .76rem;
                color: var(--muted);
                margin: 1.25rem 0;
                position: relative;
            }

            .divider::before,
            .divider::after {
                content: '';
                position: absolute;
                top: 50%;
                width: calc(50% - 30px);
                height: 1px;
                background: var(--border);
            }

            .divider::before {
                left: 0;
            }

            .divider::after {
                right: 0;
            }

            .login-link {
                text-align: center;
                font-size: .78rem;
                color: var(--muted);
                margin-top: 1.25rem;
            }

            .login-link a {
                color: var(--teal);
                text-decoration: none;
                font-weight: 500;
            }

            .login-link a:hover {
                text-decoration: underline;
            }

            @@media (max-width: 480px) {
                .card {
                    padding: 1.75rem 1.25rem;
                }

                body::after {
                    display: none;
                }
            }
    </style>
</head>

<body>
    <div class="card-wrap">

        <a asp-action="Login" asp-controller="Account" class="back-link">
            <svg viewBox="0 0 24 24">
                <path d="M19 12H5M12 5l-7 7 7 7" />
            </svg>
            Back to login
        </a>

        <div class="card">
            <div class="card-logo"><img src="~/logo.png" alt="NSIA" /></div>

            @if (ViewBag.Success == true)
            {
                <!-- ── SUCCESS STATE ── -->
                <div class="success-state">
                    <div class="success-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                            <polyline points="22,6 12,13 2,6" />
                        </svg>
                    </div>
                    <h1 class="success-title">Check your email</h1>
                    <p class="success-sub">
                        If an account exists for
                        <span class="success-email">@ViewBag.Email</span>,
                        we've sent a 6-digit reset code. It expires in 15 minutes.
                    </p>
                    <a asp-action="ResetPassword" asp-controller="Account" asp-route-email="@ViewBag.Email"
                       class="btn-primary" style="text-decoration:none">
                        <svg viewBox="0 0 24 24">
                            <rect x="3" y="11" width="18" height="11" rx="2" />
                            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                        </svg>
                        Enter reset code
                    </a>
                    <div class="divider">or</div>
                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Email" value="@ViewBag.Email" />
                        <button type="submit" class="btn-outline">
                            <svg viewBox="0 0 24 24">
                                <polyline points="1 4 1 10 7 10" />
                                <path d="M3.51 15a9 9 0 1 0 .49-3.36" />
                            </svg>
                            Resend code
                        </button>
                    </form>
                </div>
            }
            else
            {
                <!-- ── FORM STATE ── -->
                <h1 class="card-title">Forgot password?</h1>
                <p class="card-sub">Enter the email address linked to your NPI 4.0 account. We'll send you a 6-digit code to
                    reset your password.</p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-banner">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post" id="forgotForm" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label class="field-label" for="email">Email address</label>
                            <div class="input-wrap">
                                <span class="input-icon">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                        <polyline points="22,6 12,13 2,6" />
                                    </svg>
                                </span>
                                <input type="email" id="email" name="Email" placeholder="you@example.com"
                                       autocomplete="email" />
                            </div>
                        </div>
                        <button type="submit" class="btn-primary" id="submitBtn">
                            <svg viewBox="0 0 24 24">
                                <line x1="22" y1="2" x2="11" y2="13" />
                                <polygon points="22 2 15 22 11 13 2 9 22 2" />
                            </svg>
                            Send reset code
                        </button>
                    </form>

                    <div class="login-link">
                        Remember your password?
                        <a asp-action="Login" asp-controller="Account">Sign in</a>
                    </div>
                }
            </div>
        </div>

        <script>
                document.getElementById('forgotForm')?.addEventListener('submit', function () {
                    const btn = document.getElementById('submitBtn');
                    btn.disabled = true;
                    btn.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Sending...';
                });
        </script>
    </body>

</html>