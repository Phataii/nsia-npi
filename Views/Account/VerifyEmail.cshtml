@{
    ViewData["Title"] = "Verify Your Email — NSIA Prize for Innovation";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal: #0e86ab; --teal-d: #0a6b8a;
            --green: #08703a; --green-d: #065a2f;
            --lime: #83c240;
            --ink: #0d1a12; --cream: #faf8f3;
            --muted: #5a6b60; --border: rgba(0,0,0,0.1);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        /* ── LEFT PANEL ── */
        .panel-left {
            background: var(--ink);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
            min-height: 100vh;
        }
        .panel-left::before {
            content: '';
            position: absolute; inset: 0;
            background:
                radial-gradient(ellipse at 15% 40%, rgba(14,134,171,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 85% 70%, rgba(8,112,58,0.2) 0%, transparent 55%);
        }
        .panel-left > * { position: relative; z-index: 1; }

        .brand { display: flex; align-items: center; gap: 10px; }
        .brand-icon {
            width: 38px; height: 38px; border-radius: 8px;
            background: linear-gradient(135deg, var(--teal), var(--green));
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .brand-icon svg { width: 18px; height: 18px; stroke: white; stroke-width: 2; fill: none; }
        .brand-text strong { display: block; font-size: 11px; font-weight: 500; color: var(--teal); letter-spacing: .08em; text-transform: uppercase; }
        .brand-text span { display: block; font-size: 10px; color: rgba(255,255,255,0.4); }

        .panel-center { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 2.5rem 0; }

        .step-indicator { display: flex; align-items: center; gap: .5rem; margin-bottom: 2rem; }
        .step-dot {
            width: 28px; height: 28px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 500; flex-shrink: 0;
        }
        .step-dot.done { background: var(--lime); color: var(--ink); }
        .step-dot.active { background: var(--teal); color: white; }
        .step-dot.inactive { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); }
        .step-line { width: 28px; height: 1px; background: rgba(255,255,255,0.1); flex-shrink: 0; }
        .step-line.done { background: var(--lime); }
        .step-label { font-size: 10px; color: rgba(255,255,255,0.35); letter-spacing: .06em; text-transform: uppercase; margin-left: .25rem; }

        .left-visual {
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 2rem;
        }
        .envelope-wrap {
            width: 100px; height: 100px; border-radius: 50%;
            background: rgba(14,134,171,0.12); border: 1px solid rgba(14,134,171,0.25);
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }
        .envelope-wrap::after {
            content: '';
            position: absolute; inset: -8px; border-radius: 50%;
            border: 1px solid rgba(14,134,171,0.1);
        }
        .envelope-wrap svg { width: 44px; height: 44px; stroke: var(--teal); stroke-width: 1.5; fill: none; }
        .envelope-dot {
            position: absolute; top: 12px; right: 12px;
            width: 20px; height: 20px; border-radius: 50%;
            background: var(--lime); border: 2px solid var(--ink);
            display: flex; align-items: center; justify-content: center;
            animation: bounce 2s ease-in-out infinite;
        }
        .envelope-dot svg { width: 10px; height: 10px; stroke: var(--ink); stroke-width: 3; fill: none; }
        @@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }

        .left-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(1.8rem, 2.5vw, 2.8rem);
            font-weight: 700; color: white; line-height: 1.1;
            margin-bottom: 1rem;
        }
        .left-title em { color: var(--lime); font-style: italic; }
        .left-desc {
            font-size: .84rem; line-height: 1.8;
            color: rgba(255,255,255,0.5);
            font-weight: 300; margin-bottom: 2rem;
        }

        .security-badges { display: flex; flex-direction: column; gap: .65rem; }
        .sec-badge { display: flex; align-items: center; gap: .75rem; }
        .sec-icon {
            width: 32px; height: 32px; border-radius: 8px; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .sec-icon.t { background: rgba(14,134,171,0.15); }
        .sec-icon.g { background: rgba(8,112,58,0.15); }
        .sec-icon.l { background: rgba(131,194,64,0.12); }
        .sec-icon svg { width: 15px; height: 15px; stroke-width: 1.75; fill: none; }
        .sec-icon.t svg { stroke: var(--teal); }
        .sec-icon.g svg { stroke: #4ade80; }
        .sec-icon.l svg { stroke: var(--lime); }
        .sec-text { font-size: .78rem; color: rgba(255,255,255,0.45); line-height: 1.4; font-weight: 300; }

        .left-footer {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 1.5rem;
            display: flex; align-items: center; justify-content: space-between; gap: 1rem;
        }
        .left-footer span { font-size: .72rem; color: rgba(255,255,255,0.3); }
        .left-footer a { font-size: .72rem; color: var(--teal); text-decoration: none; }
        .left-footer a:hover { text-decoration: underline; }

        /* ── MOBILE HEADER ── */
        .mobile-header {
            display: none;
            background: var(--ink);
            padding: 1rem 1.25rem;
            align-items: center;
            justify-content: space-between;
            position: sticky; top: 0; z-index: 10;
        }
        .mobile-brand { display: flex; align-items: center; gap: 8px; }
        .mobile-brand-icon {
            width: 32px; height: 32px; border-radius: 6px;
            background: linear-gradient(135deg, var(--teal), var(--green));
            display: flex; align-items: center; justify-content: center;
        }
        .mobile-brand-icon svg { width: 15px; height: 15px; stroke: white; stroke-width: 2; fill: none; }
        .mobile-brand-text { font-size: 11px; font-weight: 500; color: white; letter-spacing: .06em; text-transform: uppercase; }
        .mobile-step-badge {
            font-size: 10px; font-weight: 500; color: var(--teal);
            background: rgba(14,134,171,0.12); border: 1px solid rgba(14,134,171,0.25);
            padding: .25rem .65rem; border-radius: 100px; letter-spacing: .06em;
        }

        /* ── RIGHT PANEL ── */
        .panel-right {
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 3rem 3.5rem;
            background: var(--cream);
        }
        .form-wrap { width: 100%; max-width: 400px; }

        .form-header { text-align: center; margin-bottom: 2rem; }
        .email-chip {
            display: inline-flex; align-items: center; gap: 6px;
            background: rgba(14,134,171,0.08); border: 1px solid rgba(14,134,171,0.2);
            padding: .3rem .85rem; border-radius: 100px;
            font-size: 11px; color: var(--teal); font-weight: 500;
            margin-bottom: 1.25rem;
        }
        .email-chip svg { width: 12px; height: 12px; stroke: var(--teal); stroke-width: 2; fill: none; }
        .form-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem; font-weight: 700;
            color: var(--ink); line-height: 1.1; margin-bottom: .5rem;
        }
        .form-subtitle {
            font-size: .83rem; color: var(--muted); line-height: 1.65;
        }
        .form-subtitle strong { color: var(--ink); font-weight: 500; }

        /* ── OTP INPUTS ── */
        .otp-section { margin: 2rem 0; }
        .otp-label {
            font-size: .75rem; font-weight: 500; color: var(--ink);
            letter-spacing: .02em; text-align: center;
            display: block; margin-bottom: 1rem;
        }
        .otp-inputs {
            display: flex; gap: .75rem; justify-content: center;
            margin-bottom: .75rem;
        }
        .otp-input {
            width: 52px; height: 58px;
            border: 1.5px solid var(--border); border-radius: 10px;
            background: white; color: var(--ink);
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.75rem; font-weight: 700;
            text-align: center; outline: none;
            transition: border-color .2s, box-shadow .2s, transform .15s;
            -webkit-appearance: none; appearance: none;
            caret-color: var(--teal);
        }
        .otp-input:focus {
            border-color: var(--teal);
            box-shadow: 0 0 0 3px rgba(14,134,171,0.12);
            transform: translateY(-2px);
        }
        .otp-input.filled {
            border-color: var(--green);
            background: rgba(8,112,58,0.04);
        }
        .otp-input.error {
            border-color: #f87171;
            box-shadow: 0 0 0 3px rgba(248,113,113,0.12);
            animation: shake .4s ease;
        }
        @@keyframes shake {
            0%,100%{transform:translateX(0)}
            20%{transform:translateX(-5px)}
            40%{transform:translateX(5px)}
            60%{transform:translateX(-3px)}
            80%{transform:translateX(3px)}
        }
        .otp-input.success {
            border-color: var(--green);
            box-shadow: 0 0 0 3px rgba(8,112,58,0.1);
        }

        .otp-divider {
            width: 8px; height: 1.5px; background: rgba(0,0,0,0.15);
            border-radius: 10px; align-self: center; flex-shrink: 0;
        }

        .otp-hint {
            text-align: center; font-size: .75rem; color: var(--muted);
            display: flex; align-items: center; justify-content: center; gap: 5px;
        }
        .otp-hint svg { width: 13px; height: 13px; stroke: var(--muted); stroke-width: 1.75; fill: none; }

        /* ── ERROR / SUCCESS STATES ── */
        .status-msg {
            border-radius: 8px; padding: .75rem 1rem;
            font-size: .8rem; margin-bottom: 1.25rem;
            display: none; align-items: flex-start; gap: .6rem;
        }
        .status-msg.show { display: flex; }
        .status-msg.error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; }
        .status-msg.success { background: rgba(8,112,58,0.06); border: 1px solid rgba(8,112,58,0.2); color: var(--green); }
        .status-msg svg { width: 15px; height: 15px; stroke: currentColor; stroke-width: 2; fill: none; flex-shrink: 0; margin-top: 1px; }

        /* ── VERIFY BUTTON ── */
        .btn-verify {
            width: 100%; padding: .9rem;
            background: var(--green); color: white;
            border: none; border-radius: 6px;
            font-size: .9rem; font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer; letter-spacing: .03em;
            transition: background .2s, transform .15s, opacity .2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            margin-bottom: 1.5rem;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }
        .btn-verify:hover { background: var(--green-d); transform: translateY(-1px); }
        .btn-verify:active { transform: scale(0.98); }
        .btn-verify:disabled { opacity: .5; cursor: not-allowed; transform: none; }
        .btn-verify svg { width: 16px; height: 16px; stroke: white; stroke-width: 2; fill: none; flex-shrink: 0; }

        /* ── RESEND ── */
        .resend-section { text-align: center; margin-bottom: 1.5rem; }
        .resend-timer { font-size: .82rem; color: var(--muted); }
        .resend-timer span { font-weight: 500; color: var(--ink); font-variant-numeric: tabular-nums; }
        .btn-resend {
            background: none; border: none; cursor: pointer; padding: 0;
            font-size: .82rem; font-weight: 500; color: var(--teal);
            font-family: 'DM Sans', sans-serif;
            display: none; text-decoration: underline;
            -webkit-tap-highlight-color: transparent;
        }
        .btn-resend:hover { color: var(--teal-d); }
        .btn-resend.visible { display: inline; }

        /* ── DIVIDER ── */
        .divider {
            display: flex; align-items: center; gap: .75rem;
            margin-bottom: 1.25rem; color: var(--muted); font-size: .75rem;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1; height: 1px; background: var(--border);
        }

        /* ── WRONG EMAIL ── */
        .wrong-email {
            text-align: center; font-size: .79rem; color: var(--muted);
            line-height: 1.6;
        }
        .wrong-email a {
            color: var(--teal); text-decoration: none; font-weight: 500;
        }
        .wrong-email a:hover { text-decoration: underline; }

        /* ── SUCCESS OVERLAY ── */
        .success-screen {
            display: none;
            flex-direction: column; align-items: center;
            text-align: center; padding: 1rem 0;
        }
        .success-screen.show { display: flex; }
        .success-icon-wrap {
            width: 80px; height: 80px; border-radius: 50%;
            background: rgba(8,112,58,0.1); border: 1px solid rgba(8,112,58,0.2);
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.5rem;
            animation: pop .4s cubic-bezier(0.175,0.885,0.32,1.275);
        }
        @@keyframes pop { 0%{transform:scale(0.5);opacity:0} 100%{transform:scale(1);opacity:1} }
        .success-icon-wrap svg { width: 36px; height: 36px; stroke: var(--green); stroke-width: 2; fill: none; }
        .success-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.9rem; font-weight: 700; color: var(--ink);
            margin-bottom: .5rem; line-height: 1.1;
        }
        .success-desc { font-size: .85rem; color: var(--muted); line-height: 1.7; margin-bottom: 2rem; }
        .btn-continue {
            width: 100%; padding: .9rem;
            background: var(--green); color: white;
            border: none; border-radius: 6px;
            font-size: .9rem; font-weight: 500;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer; letter-spacing: .03em;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            transition: background .2s, transform .15s;
            text-decoration: none;
            -webkit-tap-highlight-color: transparent;
        }
        .btn-continue:hover { background: var(--green-d); transform: translateY(-1px); }
        .btn-continue svg { width: 16px; height: 16px; stroke: white; stroke-width: 2; fill: none; }

        /* ── RESPONSIVE ── */
        @@media (max-width: 900px) {
            body { grid-template-columns: 1fr; }
            .panel-left { display: none; }
            .mobile-header { display: flex; }
            .panel-right {
                padding: 2rem 1.5rem 3rem;
                justify-content: flex-start;
                min-height: calc(100vh - 56px);
            }
            .form-wrap { max-width: 100%; }
        }

        @@media (max-width: 480px) {
            .mobile-header { padding: .9rem 1rem; }
            .panel-right { padding: 1.75rem 1.25rem 2.5rem; }
            .otp-inputs { gap: .5rem; }
            .otp-input {
                width: 44px; height: 52px;
                font-size: 1.5rem; border-radius: 8px;
            }
            .form-title { font-size: 1.7rem; }
            .btn-verify, .btn-continue { padding: 1rem; font-size: .92rem; }
        }

        @@media (max-width: 360px) {
            .otp-inputs { gap: .35rem; }
            .otp-input { width: 38px; height: 46px; font-size: 1.35rem; }
            .otp-divider { width: 5px; }
        }
    </style>
</head>
<body>

<!-- MOBILE HEADER -->
<header class="mobile-header">
    <div class="mobile-brand">
        <div class="mobile-brand-icon">
            <svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg>
        </div>
        <span class="mobile-brand-text">NSIA — Prize for Innovation</span>
    </div>
    <span class="mobile-step-badge">Verify Email</span>
</header>

<!-- LEFT PANEL -->
<div class="panel-left">
    <div class="brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg>
        </div>
        <div class="brand-text">
            <strong>NSIA</strong>
            <span>Nigeria Sovereign Investment Authority</span>
        </div>
    </div>

    <div class="panel-center">
        <div class="step-indicator">
            <div class="step-dot done">✓</div>
            <div class="step-line done"></div>
            <div class="step-dot active">2</div>
            <div class="step-line"></div>
            <div class="step-dot inactive">3</div>
            <span class="step-label">Step 2 — Verify Email</span>
        </div>

        <div class="left-visual">
            <div class="envelope-wrap">
                <svg viewBox="0 0 24 24">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                <div class="envelope-dot">
                    <svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg>
                </div>
            </div>
        </div>

        <h1 class="left-title">Check your<br /><em>inbox.</em></h1>
        <p class="left-desc">
            We've sent a 6-digit verification code to your email address.
            Enter it on the right to confirm your account and continue your application.
        </p>

        <div class="security-badges">
            <div class="sec-badge">
                <div class="sec-icon t">
                    <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <span class="sec-text">Code expires in 10 minutes for your security</span>
            </div>
            <div class="sec-badge">
                <div class="sec-icon g">
                    <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <span class="sec-text">Never share your OTP with anyone, including NSIA staff</span>
            </div>
            <div class="sec-badge">
                <div class="sec-icon l">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <span class="sec-text">Check your spam folder if you don't see the email</span>
            </div>
        </div>
    </div>

    <div class="left-footer">
        <span>© 2026 NSIA. All rights reserved.</span>
            <a href="~/NPI_4_0_Privacy_Policy.pdf">Privacy Policy</a>
    </div>
</div>

<!-- RIGHT PANEL -->
<div class="panel-right">
    <div class="form-wrap">

        <!-- VERIFY FORM -->
        <div id="verifyForm">
            <div class="form-header">
                <div class="email-chip">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    Code sent
                </div>
                <h2 class="form-title">Verify your email</h2>
                <p class="form-subtitle">
                    Enter the 6-digit code we sent to<br />
                    <strong id="displayEmail">a***e@gmail.com</strong>
                </p>
            </div>

            <div class="status-msg error" id="errorMsg">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <span id="errorText">Invalid code. Please check and try again.</span>
            </div>

            <div class="status-msg success" id="successMsg">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span>Code verified! Redirecting you now...</span>
            </div>

            <form id="otpForm" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Email" id="hiddenEmail" />

                <div class="otp-section">
                    <span class="otp-label">Enter 6-digit verification code</span>
                    <div class="otp-inputs" id="otpInputs">
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp0" autocomplete="one-time-code" />
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp1" />
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp2" />
                        <div class="otp-divider"></div>
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp3" />
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp4" />
                        <input class="otp-input" type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" id="otp5" />
                    </div>
                    <div class="otp-hint">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        Digits only — paste your code or type it in
                    </div>
                </div>

                <button type="submit" class="btn-verify" id="submitBtn" disabled>
                    <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    Verify email address
                </button>
            </form>

            <div class="resend-section">
                <p class="resend-timer" id="resendTimer">
                    Resend code in <span id="countdown">10:00</span>
                </p>
                <button class="btn-resend" id="resendBtn" type="button">
                    Resend verification code
                </button>
            </div>

            <div class="divider">or</div>

            <div class="wrong-email">
                Used the wrong email?
                <a asp-action="Register" asp-controller="Account">Go back and change it</a>
            </div>
        </div>

        <!-- SUCCESS SCREEN -->
        <div class="success-screen" id="successScreen">
            <div class="success-icon-wrap">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </div>
            <h2 class="success-title">Email verified!</h2>
            <p class="success-desc">
                Your email address has been confirmed. You're now ready to complete
                your innovation profile and submit your NPI application.
            </p>
            <a asp-action="ApplicationStep2" asp-controller="Application" class="btn-continue">
                Continue to application
                <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
        </div>

    </div>
</div>

<script>
    // ── Prefill email display from query string or TempData
    // In your controller, pass the masked email via ViewBag.MaskedEmail
        const maskedEmail = '@(ViewBag.MaskedEmail ?? "your email")';
        const actualEmail = '@(ViewBag.ActualEmail ?? "")';
        document.getElementById('displayEmail').textContent = maskedEmail;
        document.getElementById('hiddenEmail').value = actualEmail;

    const inputs = Array.from({ length: 6 }, (_, i) => document.getElementById('otp' + i));
    const submitBtn = document.getElementById('submitBtn');
    const errorMsg  = document.getElementById('errorMsg');

    // ── OTP input behaviour
    function getOtpValue() { return inputs.map(i => i.value).join(''); }

    function checkComplete() {
        const complete = inputs.every(i => i.value.match(/^\d$/));
        submitBtn.disabled = !complete;
        inputs.forEach(i => {
            i.classList.toggle('filled', i.value.match(/^\d$/) !== null);
        });
    }

    inputs.forEach((input, idx) => {
        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace') {
                if (!input.value && idx > 0) {
                    inputs[idx - 1].value = '';
                    inputs[idx - 1].focus();
                    inputs[idx - 1].classList.remove('filled');
                }
                checkComplete();
            } else if (e.key === 'ArrowLeft' && idx > 0) {
                inputs[idx - 1].focus();
            } else if (e.key === 'ArrowRight' && idx < 5) {
                inputs[idx + 1].focus();
            }
        });

        input.addEventListener('input', (e) => {
            const val = e.target.value.replace(/\D/g, '');
            // Handle paste of full OTP into first box
            if (val.length > 1) {
                val.split('').slice(0, 6).forEach((ch, i) => {
                    if (inputs[i]) inputs[i].value = ch;
                });
                inputs[Math.min(5, val.length - 1)].focus();
                checkComplete();
                return;
            }
            input.value = val;
            inputs.forEach(i => i.classList.remove('error'));
            errorMsg.classList.remove('show');
            if (val && idx < 5) inputs[idx + 1].focus();
            checkComplete();
        });

        // Handle paste on any box
        input.addEventListener('paste', (e) => {
            e.preventDefault();
            const pasted = (e.clipboardData || window.clipboardData)
                .getData('text').replace(/\D/g, '').slice(0, 6);
            pasted.split('').forEach((ch, i) => { if (inputs[i]) inputs[i].value = ch; });
            inputs[Math.min(5, pasted.length - 1)].focus();
            checkComplete();
        });

        // Select all on focus for easy re-entry
        input.addEventListener('focus', () => input.select());
    });

    // ── Countdown timer
    let totalSeconds = 600; // 10 minutes
    const countdownEl = document.getElementById('countdown');
    const resendTimer = document.getElementById('resendTimer');
    const resendBtn   = document.getElementById('resendBtn');

    function formatTime(s) {
        const m = Math.floor(s / 60);
        const sec = s % 60;
        return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
    }

    const timer = setInterval(() => {
        totalSeconds--;
        countdownEl.textContent = formatTime(totalSeconds);
        if (totalSeconds <= 0) {
            clearInterval(timer);
            resendTimer.style.display = 'none';
            resendBtn.classList.add('visible');
        }
    }, 1000);

    resendBtn.addEventListener('click', () => {
        // Wire up to your resend endpoint
        resendBtn.textContent = 'Sending...';
        resendBtn.disabled = true;
        setTimeout(() => {
            totalSeconds = 600;
            resendBtn.classList.remove('visible');
            resendBtn.disabled = false;
            resendBtn.textContent = 'Resend verification code';
            resendTimer.style.display = '';
            countdownEl.textContent = formatTime(totalSeconds);
            // Restart timer
            const newTimer = setInterval(() => {
                totalSeconds--;
                countdownEl.textContent = formatTime(totalSeconds);
                if (totalSeconds <= 0) {
                    clearInterval(newTimer);
                    resendTimer.style.display = 'none';
                    resendBtn.classList.add('visible');
                }
            }, 1000);
        }, 1500);
    });

    // ── Form submit
        document.getElementById('otpForm').addEventListener('submit', async function (e) {
        e.preventDefault();
        const otp = getOtpValue();
        if (otp.length < 6) return;

        submitBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Verifying...';
        submitBtn.disabled = true;
        errorMsg.classList.remove('show');

        try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        const response = await fetch('/Account/VerifyEmail', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token
        },
        body: JSON.stringify({
        otp: getOtpValue(),
        email: document.getElementById('hiddenEmail').value
        })
        });
        const data = await response.json();

        if (response.ok) {
        document.getElementById('verifyForm').style.display = 'none';
        document.getElementById('successScreen').classList.add('show');
        // Redirect after showing success screen briefly
        setTimeout(() => { window.location.href = data.redirectUrl; }, 1500);
        } else {
        throw new Error(data.message ?? 'Invalid code');
        }

        } catch (err) {
        const msg = err.message ?? 'Invalid code. Please check and try again.';
        document.getElementById('errorText').textContent = msg;
        inputs.forEach(i => { i.classList.add('error'); i.classList.remove('filled'); });
        errorMsg.classList.add('show');
        submitBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" stroke="white" stroke-width="2" fill="none"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Verify email address';
        submitBtn.disabled = false;
        setTimeout(() => {
        inputs.forEach(i => { i.value = ''; i.classList.remove('error', 'filled'); });
        inputs[0].focus();
        checkComplete();
        }, 800);
        }
        });


        resendBtn.addEventListener('click', async () => {
        resendBtn.textContent = 'Sending...';
        resendBtn.disabled = true;

        try {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        await fetch('/Account/ResendOtp', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token
        },
        body: JSON.stringify({ email: document.getElementById('hiddenEmail').value })
        });
        } catch { /* fail silently — OTP send errors are logged server-side */ }

        // Restart timer regardless
        totalSeconds = 600;
        resendBtn.classList.remove('visible');
        resendBtn.disabled = false;
        resendBtn.textContent = 'Resend verification code';
        resendTimer.style.display = '';
        countdownEl.textContent = formatTime(totalSeconds);

        const newTimer = setInterval(() => {
        totalSeconds--;
        countdownEl.textContent = formatTime(totalSeconds);
        if (totalSeconds <= 0) {
        clearInterval(newTimer);
        resendTimer.style.display = 'none';
        resendBtn.classList.add('visible');
        }
        }, 1000);
        });
    // Auto-focus first input on load
    window.addEventListener('load', () => inputs[0].focus());
</script>
</body>
</html>