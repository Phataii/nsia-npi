@{
    ViewData["Title"] = "Reset Password — NSIA Prize for Innovation";
    Layout = null;
    var email = ViewBag.Email as string ?? "";
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" sizes="16x16" href="https://web.archive.org/web/20250328161536im_/http://nsia-ip.com/assets/images/favicons/favicon-16x16.png"/>
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --teal-pale: #F0FAF9;
                --green: #7BC144;
                --ink: #1C2B2A;
                --muted: #4A6260;
                --off: #EEF4F3;
                --border: rgba(45, 184, 176, 0.2);
            }

            html {
                scroll-behavior: smooth;
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--teal-light);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1.5rem;
                position: relative;
                overflow: hidden;
            }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                pointer-events: none;
                @* background:
                    radial-gradient(ellipse at 15% 40%, rgba(13, 122, 115, 0.5) 0%, transparent 55%),
                    radial-gradient(ellipse at 85% 70%, rgba(123, 193, 68, 0.2) 0%, transparent 50%); *@
            }

            body::after {
                content: 'NPI';
                position: fixed;
                right: -2rem;
                bottom: -3rem;
                font-family: 'Cormorant Garamond', serif;
                font-size: 20rem;
                font-weight: 700;
                color: rgba(255, 255, 255, 0.05);
                line-height: 1;
                pointer-events: none;
            }

            .card-wrap {
                width: 100%;
                max-width: 440px;
                position: relative;
                z-index: 1;
            }

            .back-link {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                font-size: .78rem;
                color: rgba(255, 255, 255, 0.7);
                text-decoration: none;
                margin-bottom: 1.5rem;
                transition: color .2s;
            }

            .back-link:hover {
                color: white;
            }

            .back-link svg {
                width: 14px;
                height: 14px;
                stroke: currentColor;
                stroke-width: 2;
                fill: none;
            }

            .card {
                background: white;
                border-radius: 16px;
                padding: 2.5rem;
                width: 100%;
                box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
            }

            .card-logo {
                margin-bottom: 1.75rem;
            }

            .card-logo img {
                height: 30px;
                width: auto;
            }

            .card-title {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .35rem;
                line-height: 1.1;
            }

            .card-sub {
                font-size: .82rem;
                color: var(--muted);
                line-height: 1.65;
                margin-bottom: 1.75rem;
            }

            .email-badge {
                display: inline-flex;
                align-items: center;
                gap: 5px;
                background: var(--teal-light);
                border: 1px solid rgba(45, 184, 176, 0.25);
                color: var(--teal-deep);
                padding: .25rem .75rem;
                border-radius: 100px;
                font-size: .76rem;
                font-weight: 500;
                margin-bottom: 1.75rem;
            }

            .email-badge svg {
                width: 12px;
                height: 12px;
                stroke: var(--teal);
                stroke-width: 1.75;
                fill: none;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: .38rem;
                margin-bottom: 1.1rem;
            }

            label.field-label {
                font-size: .74rem;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .02em;
            }

            .input-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                pointer-events: none;
            }

            .input-icon svg {
                width: 15px;
                height: 15px;
                stroke: var(--muted);
                stroke-width: 1.75;
                fill: none;
                display: block;
            }

            /* OTP boxes */
            .otp-wrap {
                display: flex;
                gap: .6rem;
            }

            .otp-box {
                flex: 1;
                height: 54px;
                width: 20px;
                border: 1.5px solid var(--border);
                border-radius: 8px;
                text-align: center;
                font-size: 1.3rem;
                font-weight: 600;
                color: var(--ink);
                font-family: 'DM Sans', sans-serif;
                outline: none;
                transition: border-color .2s, box-shadow .2s;
                background: white;
            }

            .otp-box:focus {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(45, 184, 176, 0.12);
            }

            .otp-box.filled {
                border-color: var(--teal);
                background: var(--teal-pale);
            }

            #otpHidden {
                display: none;
            }

           input[type="password"],
input[type="text"].has-toggle {
    width: 100%; padding: .75rem .9rem .75rem 2.5rem;
    border: 1px solid var(--border); border-radius: 8px;
    font-size: .85rem; font-family: 'DM Sans', sans-serif;
    color: var(--ink); outline: none;
    transition: border-color .2s, box-shadow .2s; background: white;
    padding-right: 2.5rem;
}
input[type="password"]:focus,
input[type="text"].has-toggle:focus {
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(45,184,176,0.12);
}

            input::placeholder {
                color: #aab5af;
            }

            /* Password toggle */
            .pw-wrap {
                position: relative;
            }

            .pw-toggle {
                position: absolute;
                right: 11px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                cursor: pointer;
                color: var(--muted);
                padding: 4px;
                display: flex;
            }

            .pw-toggle svg {
                width: 15px;
                height: 15px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            .pw-toggle:hover {
                color: var(--teal);
            }

            @* input.has-toggle {
                padding-right: 2.5rem;
            } *@

            /* Password strength */
            .pw-strength {
                margin-top: .5rem;
            }

            .pw-strength-bar {
                height: 3px;
                background: var(--off);
                border-radius: 100px;
                overflow: hidden;
                margin-bottom: .3rem;
            }

            .pw-strength-fill {
                height: 100%;
                border-radius: 100px;
                transition: width .3s, background .3s;
                width: 0;
            }

            .pw-strength-text {
                font-size: .7rem;
                color: var(--muted);
            }

            .error-banner {
                background: rgba(220, 38, 38, 0.07);
                border: 1px solid rgba(220, 38, 38, 0.2);
                border-radius: 8px;
                padding: .75rem 1rem;
                font-size: .8rem;
                color: #b91c1c;
                display: flex;
                align-items: center;
                gap: .6rem;
                margin-bottom: 1.25rem;
            }

            .error-banner svg {
                width: 15px;
                height: 15px;
                stroke: #b91c1c;
                stroke-width: 1.75;
                fill: none;
                flex-shrink: 0;
            }

            .btn-primary {
                width: 100%;
                background: var(--teal);
                color: white;
                padding: .85rem;
                border: none;
                border-radius: 100px;
                font-size: .9rem;
                font-weight: 600;
                font-family: 'DM Sans', sans-serif;
                cursor: pointer;
                transition: background .2s, transform .15s;
                box-shadow: 0 4px 14px rgba(45, 184, 176, 0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }

            .btn-primary:hover {
                background: var(--teal-d);
                transform: translateY(-1px);
            }

            .btn-primary:disabled {
                opacity: .6;
                cursor: not-allowed;
                transform: none;
            }

            .btn-primary svg {
                width: 15px;
                height: 15px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            /* Done state */
            .done-state {
                text-align: center;
                padding: 1rem 0;
            }

            .done-icon {
                width: 64px;
                height: 64px;
                border-radius: 50%;
                background: rgba(123, 193, 68, 0.12);
                margin: 0 auto 1.25rem;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .done-icon svg {
                width: 28px;
                height: 28px;
                stroke: var(--green);
                stroke-width: 2;
                fill: none;
            }

            .done-title {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.5rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .5rem;
            }

            .done-sub {
                font-size: .82rem;
                color: var(--muted);
                line-height: 1.7;
                margin-bottom: 1.75rem;
            }

            .btn-login-now {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                width: 100%;
                background: var(--teal);
                color: white;
                padding: .85rem;
                border-radius: 100px;
                text-decoration: none;
                font-size: .9rem;
                font-weight: 600;
                transition: background .2s;
                box-shadow: 0 4px 14px rgba(45, 184, 176, 0.3);
            }

            .btn-login-now:hover {
                background: var(--teal-d);
            }

            .btn-login-now svg {
                width: 15px;
                height: 15px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            .resend-row {
                text-align: center;
                font-size: .76rem;
                color: var(--muted);
                margin-top: 1.25rem;
            }

            .resend-row a {
                color: var(--teal);
                text-decoration: none;
                font-weight: 500;
            }

            .resend-row a:hover {
                text-decoration: underline;
            }

            @@media (max-width: 480px) {
                .card {
                    padding: 1.75rem 1.25rem;
                }

                body::after {
                    display: none;
                }
            }
    </style>
</head>

<body>
    <div class="card-wrap">

        <a asp-action="ForgotPassword" asp-controller="Account" class="back-link">
            <svg viewBox="0 0 24 24">
                <path d="M19 12H5M12 5l-7 7 7 7" />
            </svg>
            Back
        </a>

        <div class="card">
            <div class="card-logo"><img src="~/logo.png" alt="NSIA" /></div>

            @if (ViewBag.Done == true)
            {
                <!-- ── DONE STATE ── -->
                <div class="done-state">
                    <div class="done-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                            <polyline points="22 4 12 14.01 9 11.01" />
                        </svg>
                    </div>
                    <h1 class="done-title">Password reset!</h1>
                    <p class="done-sub">Your password has been updated successfully. You can now sign in with your new
                        password.</p>
                        <a asp-action="Login" asp-controller="Account" class="btn-login-now">
                            <svg viewBox="0 0 24 24">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                <polyline points="10 17 15 12 10 7" />
                                <line x1="15" y1="12" x2="3" y2="12" />
                            </svg>
                            Sign in now
                        </a>
                    </div>
                } else
                {
                    <!-- ── FORM STATE ── -->
                    <h1 class="card-title">Reset password</h1>
                    <p class="card-sub">Enter the 6-digit code we sent you, then choose a new password.</p>

                    @if (!string.IsNullOrEmpty(email))
                    {
                        <div class="email-badge">
                            <svg viewBox="0 0 24 24">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                <polyline points="22,6 12,13 2,6" />
                            </svg>
                            @email
                        </div>
                    }

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-banner">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" y1="8" x2="12" y2="12" />
                                <line x1="12" y1="16" x2="12.01" y2="16" />
                            </svg>
                            @ViewBag.Error
                        </div>
                    }

                    <form asp-action="ResetPassword" asp-controller="Account" method="post" id="resetForm" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Email" value="@email" />
                        <input type="hidden" name="Otp" id="otpHidden" />

                        <!-- OTP boxes -->
                        <div class="form-group">
                            <label class="field-label">6-digit reset code</label>
                            <div class="otp-wrap" id="otpWrap">
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                                <input type="text" class="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]" />
                            </div>
                        </div>

                        <!-- New password -->
                        <div class="form-group">
                            <label class="field-label" for="newPassword">New password</label>
                            <div class="input-wrap pw-wrap">
                                <span class="input-icon"><svg viewBox="0 0 24 24">
                                    <rect x="3" y="11" width="18" height="11" rx="2" />
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                </svg></span>
                                <input type="password" id="newPassword" name="NewPassword" placeholder="Min. 8 characters"
                                       class="has-toggle" autocomplete="new-password" />
                                <button type="button" class="pw-toggle" id="pwToggle">
                                    <svg id="pwEye" viewBox="0 0 24 24">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                        <circle cx="12" cy="12" r="3" />
                                    </svg>
                                </button>
                            </div>
                            <div class="pw-strength">
                                <div class="pw-strength-bar">
                                    <div class="pw-strength-fill" id="pwBar"></div>
                                </div>
                                <div class="pw-strength-text" id="pwText"></div>
                            </div>
                        </div>

                        <button type="submit" class="btn-primary" id="submitBtn">
                            <svg viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                            Reset password
                        </button>
                    </form>

                    <div class="resend-row">
                        Didn't get a code?
                        <a asp-action="ForgotPassword" asp-controller="Account">Send again</a>
                    </div>
                }
            </div>
        </div>

        <script>
                // ── OTP boxes
                const boxes = document.querySelectorAll('.otp-box');
                const otpHidden = document.getElementById('otpHidden');

                function updateHidden() {
                    otpHidden.value = Array.from(boxes).map(b => b.value).join('');
                }

                boxes.forEach((box, idx) => {
                    box.addEventListener('input', () => {
                        box.value = box.value.replace(/\D/g, '').slice(-1);
                        box.classList.toggle('filled', box.value !== '');
                        updateHidden();
                        if (box.value && idx < boxes.length - 1) boxes[idx + 1].focus();
                    });
                    box.addEventListener('keydown', e => {
                        if (e.key === 'Backspace' && !box.value && idx > 0) boxes[idx - 1].focus();
                    });
                    box.addEventListener('paste', e => {
                        e.preventDefault();
                        const text = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '');
                        text.split('').slice(0, 6).forEach((ch, i) => {
                            if (boxes[i]) { boxes[i].value = ch; boxes[i].classList.add('filled'); }
                        });
                        updateHidden();
                        boxes[Math.min(text.length, 5)].focus();
                    });
                });

                // ── Password toggle
                const pwInput = document.getElementById('newPassword');
                const pwEye = document.getElementById('pwEye');
                const eyeOn = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
                const eyeOff = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
                document.getElementById('pwToggle').addEventListener('click', () => {
                    const isText = pwInput.type === 'text';
                    pwInput.type = isText ? 'password' : 'text';
                    pwEye.innerHTML = isText ? eyeOn : eyeOff;
                });

                // ── Password strength
                const pwBar = document.getElementById('pwBar');
                const pwText = document.getElementById('pwText');
                const levels = [
                    { label: '', color: '', width: '0%' },
                    { label: 'Weak', color: '#ef4444', width: '25%' },
                    { label: 'Fair', color: '#f59e0b', width: '50%' },
                    { label: 'Good', color: '#2DB8B0', width: '75%' },
                    { label: 'Strong', color: '#7BC144', width: '100%' },
                ];
                pwInput.addEventListener('input', () => {
                    const v = pwInput.value;
                    let score = 0;
                    if (v.length >= 8) score++;
                    if (/[A-Z]/.test(v)) score++;
                    if (/[0-9]/.test(v)) score++;
                    if (/[^A-Za-z0-9]/.test(v)) score++;
                    const lvl = levels[score];
                    pwBar.style.width = lvl.width;
                    pwBar.style.background = lvl.color;
                    pwText.textContent = lvl.label;
                    pwText.style.color = lvl.color;
                });

                // ── Submit
                document.getElementById('resetForm').addEventListener('submit', function (e) {
                    const otp = otpHidden.value;
                    if (otp.length !== 6) { e.preventDefault(); alert('Please enter all 6 digits of your reset code.'); return; }
                    if (!pwInput.value || pwInput.value.length < 8) { e.preventDefault(); alert('Password must be at least 8 characters.'); return; }
                    const btn = document.getElementById('submitBtn');
                    btn.disabled = true;
                    btn.innerHTML = '<svg viewBox="0 0 24 24" width="15" height="15" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Resetting...';
                });
        </script>
    </body>

</html>