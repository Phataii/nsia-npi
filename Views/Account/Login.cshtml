@{
    ViewData["Title"] = "Login - NSIA Prize for Innovation";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" sizes="16x16"
          href="https://web.archive.org/web/20250328161536im_/http://nsia-ip.com/assets/images/favicons/favicon-16x16.png" />
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --teal-pale: #F0FAF9;
                --green: #7BC144;
                --green-dark: #5a9130;
                --ink: #1C2B2A;
                --cream: #F5F9F8;
                --off: #EEF4F3;
                --muted: #4A6260;
                --border: rgba(45, 184, 176, 0.2);
                --nav-h: 62px;
                --step-h: 56px;
            }

            html,
            body {
                height: 100%;
            }

            body {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                background: var(--cream);
                color: var(--ink);
                display: grid;
                grid-template-columns: 1fr 1fr;
                min-height: 100vh;
            }

            /* ── LEFT PANEL ── */
            .panel-left {
                background: var(--teal-light);
                padding: 3rem;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                position: relative;
                overflow: hidden;
            }

            .panel-left::before {
                content: '';
                position: absolute;
                inset: 0;

            }

            .panel-left>* {
                position: relative;
                z-index: 1;
            }

            .brand {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .brand-icon img {
                width: 150px;
                height: 40px;
            }

            .panel-center {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 2.5rem 0;
            }

            .left-eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                background: rgba(131, 194, 64, 0.12);
                border: 1px solid rgba(131, 194, 64, 0.25);
                padding: .3rem .75rem;
                border-radius: 100px;
                font-size: 10px;
                font-weight: 500;
                color: var(--lime);
                letter-spacing: .1em;
                text-transform: uppercase;
                width: fit-content;
                margin-bottom: 1.75rem;
            }

            .left-eyebrow-dot {
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: var(--lime);
                animation: pulse 2s ease-in-out infinite;
            }

            @@keyframes pulse {

                0%,
                100% {
                    opacity: 1
                }

                50% {
                    opacity: .4
                }
            }

            .left-title {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                font-size: clamp(2rem, 3.5vw, 3.2rem);
                font-weight: 700;
                color: var(--ink);
                line-height: 1.05;
                margin-bottom: 1.25rem;
            }

            .left-title em {
                color: var(--ink);
                font-style: italic;
            }

            .left-desc {
                font-size: .85rem;
                line-height: 1.8;
                color: var(--ink) max-width: 340px;
                font-weight: 300;
                margin-bottom: 2.5rem;
            }

            .stats-row {
                display: flex;
                gap: 2rem;
            }

            .stat {}

            .stat-val {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                font-size: 1.7rem;
                font-weight: 700;
                color: var(--lime);
                line-height: 1;
            }

            .stat-lbl {
                font-size: 10px;
                color: var(--ink);
                letter-spacing: .07em;
                text-transform: uppercase;
                margin-top: 3px;
            }

            .testimonial {
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                padding-top: 1.75rem;
            }

            .quote {
                font-size: .82rem;
                line-height: 1.75;
                color: var(--ink);
                font-style: italic;
                margin-bottom: .9rem;
                font-weight: 300;
            }

            .quote-author {
                display: flex;
                align-items: center;
                gap: .75rem;
            }

            .author-avatar {
                width: 34px;
                height: 34px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--teal), var(--green));
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 11px;
                font-weight: 500;
                color: white;
                flex-shrink: 0;
            }

            .author-name {
                font-size: .78rem;
                font-weight: 500;
                color: var(--ink);
            }

            .author-role {
                font-size: .7rem;
                color: var(--ink);
            }

            /* ── RIGHT PANEL ── */
            .panel-right {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 3rem 3.5rem;
                background: var(--cream);
            }

            .form-wrap {
                width: 100%;
                max-width: 400px;
            }

            .form-header {
                margin-bottom: 2.25rem;
            }

            .form-title {
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                font-size: 2rem;
                font-weight: 700;
                color: var(--ink);
                line-height: 1.1;
                margin-bottom: .4rem;
            }

            .form-subtitle {
                font-size: .83rem;
                color: var(--muted);
                line-height: 1.6;
            }

            .form-subtitle a {
                color: var(--teal);
                text-decoration: none;
                font-weight: 500;
            }

            .form-subtitle a:hover {
                text-decoration: underline;
            }

            .form-group {
                margin-bottom: 1.25rem;
            }

            label {
                display: block;
                font-size: .75rem;
                font-weight: 500;
                color: var(--ink);
                margin-bottom: .4rem;
                letter-spacing: .02em;
            }

            .input-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                width: 16px;
                height: 16px;
                color: var(--muted);
                pointer-events: none;
            }

            .input-icon svg {
                width: 16px;
                height: 16px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            input[type="email"],
            input[type="password"],
            input[type="text"] {
                width: 100%;
                padding: .7rem .9rem .7rem 2.6rem;
                border: 1px solid var(--border);
                border-radius: 6px;
                font-size: .85rem;
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                background: white;
                color: var(--ink);
                transition: border-color .2s, box-shadow .2s;
                outline: none;
            }

            input[type="email"]:focus,
            input[type="password"]:focus,
            input[type="text"]:focus {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(14, 134, 171, 0.1);
            }

            input::placeholder {
                color: #aab0ac;
            }

            .toggle-pw {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                cursor: pointer;
                padding: 2px;
                color: var(--muted);
                display: flex;
                align-items: center;
            }

            .toggle-pw svg {
                width: 16px;
                height: 16px;
                stroke: currentColor;
                stroke-width: 1.75;
                fill: none;
            }

            .toggle-pw:hover {
                color: var(--teal);
            }

            .form-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 1.5rem;
            }

            .checkbox-wrap {
                display: flex;
                align-items: center;
                gap: .5rem;
                cursor: pointer;
            }

            .checkbox-wrap input[type="checkbox"] {
                width: 15px;
                height: 15px;
                padding: 0;
                accent-color: var(--teal);
                cursor: pointer;
                flex-shrink: 0;
            }

            .checkbox-wrap span {
                font-size: .78rem;
                color: var(--muted);
            }

            .forgot-link {
                font-size: .78rem;
                color: var(--teal);
                text-decoration: none;
                font-weight: 500;
            }

            .forgot-link:hover {
                text-decoration: underline;
            }

            .btn-submit {
                width: 100%;
                padding: .85rem;
                background: var(--teal);
                color: white;
                border: none;
                border-radius: 6px;
                font-size: .88rem;
                font-weight: 500;
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                letter-spacing: .03em;
                cursor: pointer;
                transition: background .2s, transform .15s;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                margin-bottom: 1.25rem;
            }

            .btn-submit:hover {
                background: var(--teal-d);
                transform: translateY(-1px);
            }

            .btn-submit:active {
                transform: translateY(0);
            }

            .btn-submit svg {
                width: 16px;
                height: 16px;
                stroke: white;
                stroke-width: 2;
                fill: none;
            }

            .divider {
                display: flex;
                align-items: center;
                gap: .75rem;
                margin-bottom: 1.25rem;
                color: var(--muted);
                font-size: .75rem;
            }

            .divider::before,
            .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

            .btn-register {
                width: 100%;
                padding: .82rem;
                background: white;
                color: var(--ink);
                border: 1px solid var(--border);
                border-radius: 6px;
                font-size: .85rem;
                font-weight: 500;
                font-family: 'Century Gothic', CenturyGothic, AppleGothic, sans-serif;
                cursor: pointer;
                transition: border-color .2s, background .2s;
                text-align: center;
                text-decoration: none;
                display: block;
            }

            .btn-register:hover {
                border-color: var(--teal);
                background: rgba(14, 134, 171, 0.03);
                color: var(--teal);
            }

            .error-msg {
                background: #fef2f2;
                border: 1px solid #fecaca;
                border-radius: 6px;
                padding: .75rem 1rem;
                font-size: .8rem;
                color: #b91c1c;
                margin-bottom: 1.25rem;
                display: none;
                align-items: flex-start;
                gap: .5rem;
            }

            .error-msg.show {
                display: flex;
            }

            .error-msg svg {
                width: 15px;
                height: 15px;
                stroke: #b91c1c;
                stroke-width: 2;
                fill: none;
                flex-shrink: 0;
                margin-top: 1px;
            }

            .form-footer {
                margin-top: 2rem;
                padding-top: 1.5rem;
                border-top: 1px solid var(--border);
                text-align: center;
            }

            .form-footer p {
                font-size: .72rem;
                color: var(--muted);
                line-height: 1.6;
            }

            .form-footer a {
                color: var(--teal);
                text-decoration: none;
            }

            .form-footer a:hover {
                text-decoration: underline;
            }

            /* Validation states */
            .input-wrap.invalid input {
                border-color: #f87171;
            }

            .input-wrap.invalid input:focus {
                box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.12);
            }

            .field-error {
                font-size: .72rem;
                color: #b91c1c;
                margin-top: .3rem;
                display: none;
            }

            .input-wrap.invalid+.field-error {
                display: block;
            }

            @@media (max-width: 768px) {
                body {
                    grid-template-columns: 1fr;
                }

                .panel-left {
                    display: none;
                }

                .panel-right {
                    padding: 2.5rem 1.75rem;
                    min-height: 100vh;
                }
            }
    </style>
</head>

<body>

    <!-- LEFT PANEL -->
    <div class="panel-left">
        <div class="brand">
            <a href="/">
                <div class="brand-icon">
                    <img src="~/web/20250328144002im_/http:/nsia-ip.com/assets/images/logo.png" alt="NSIA" />
                </div>
            </a>
        </div>

        <div class="panel-center">
            @* <div class="left-eyebrow">
                <span class="left-eyebrow-dot"></span>
                NPI 4.0. Now Open
            </div> *@
            <h1 class="left-title">
                Your Innovation<br />
                Starts Here.
            </h1>
            <p class="left-desc">
                Sign in to manage your application for the NSIA Prize for Innovation, Nigeria’s premier platform for
                innovative and impact-driven businesses.
            </p>
            @* <div class="stats-row">
            <div class="stat">
                <div class="stat-val">$220K</div>
                <div class="stat-lbl">Prize Pool</div>
            </div>
            <div class="stat">
                <div class="stat-val">5,000+</div>
                <div class="stat-lbl">Applicants</div>
            </div>
            <div class="stat">
                <div class="stat-val">3</div>
                <div class="stat-lbl">Sectors</div>
            </div>
        </div> *@
        </div>

        @* <hr/>
    <div class="testimonial">
        <p class="quote">
            "Winning the NSIA Prize gave us the funding and mentorship we needed to scale
            from Lagos to five states in under a year."
        </p>
        <div class="quote-author">
            <div class="author-avatar">AO</div>
            <div>
                <div class="author-name">John Doe</div>
                <div class="author-role">NPI Season 3 Winner · HealthBridge Nigeria</div>
            </div>
        </div>
    </div> *@
    </div>

    <!-- RIGHT PANEL -->
    <div class="panel-right">
        <div class="form-wrap">
            <div class="form-header">
                <h2 class="form-title">Welcome!</h2>
                @* <p class="form-subtitle">
                Don't have an account?
                <a href="/account/register">Create one free</a>
            </p> *@
            </div>

            <div class="error-msg" id="errorMsg">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                <span id="errorText">Invalid email or password. Please try again.</span>
            </div>

            <form asp-action="Login" asp-controller="Account" method="post" id="loginForm" novalidate>
                @Html.AntiForgeryToken()
                @if (ViewBag.ShowError == true)
                {
                    <div class="error-msg show" id="errorMsg">
                        <svg viewBox="0 0 24 24">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <span>@(ViewBag.ErrorText ?? "Something went wrong. Please try again.")</span>
                    </div>
                }
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <div class="input-wrap" id="emailWrap">
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                <polyline points="22,6 12,13 2,6" />
                            </svg>
                        </span>
                        <input type="email" id="email" name="Email" placeholder="you@example.com"
                               autocomplete="email" />
                    </div>
                    <div class="field-error">Please enter a valid email address.</div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-wrap" id="passwordWrap">
                        <span class="input-icon">
                            <svg viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <input type="password" id="password" name="Password" placeholder="Enter your password"
                               autocomplete="current-password" />
                        <button type="button" class="toggle-pw" id="togglePw" aria-label="Toggle password visibility">
                            <svg id="eyeIcon" viewBox="0 0 24 24">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        </button>
                    </div>
                    <div class="field-error">Password is required.</div>
                </div>

                <div class="form-row">
                    <label class="checkbox-wrap">
                        <input type="checkbox" name="RememberMe" id="remember" />
                        <span>Remember me</span>
                    </label>
                    <a asp-action="ForgotPassword" asp-controller="Account" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <svg viewBox="0 0 24 24">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <polyline points="10 17 15 12 10 7" />
                        <line x1="15" y1="12" x2="3" y2="12" />
                    </svg>
                    Sign in to your account
                </button>

                <div class="divider">or</div>

                <a href="/account/register" class="btn-register">
                    Create a new applicant account
                </a>
            </form>

            <div class="form-footer">
                <p>
                    By signing in, you agree to NSIA's
                    <a href="~/NPI_4_0_Terms_of_Service.pdf">Terms of Use</a> and
                    <a href="~/NPI_4_0_Privacy_Policy.pdf">Privacy Policy</a>.<br />
                    Need help? <a href="mailto:npi@nsia.com.ng">Contact support</a>
                </p>
            </div>
        </div>
    </div>

    <script>
            const togglePw = document.getElementById('togglePw');
            const pwInput = document.getElementById('password');
            const eyeIcon = document.getElementById('eyeIcon');
            const eyeOff = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
            const eyeOn = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';

            togglePw.addEventListener('click', () => {
                const isText = pwInput.type === 'text';
                pwInput.type = isText ? 'password' : 'text';
                eyeIcon.innerHTML = isText ? eyeOn : eyeOff;
            });

            const form = document.getElementById('loginForm');
            const emailInput = document.getElementById('email');
            const emailWrap = document.getElementById('emailWrap');
            const passwordWrap = document.getElementById('passwordWrap');
            const errorMsg = document.getElementById('errorMsg');
            const submitBtn = document.getElementById('submitBtn');

            function validateEmail(v) { return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(v); }

            form.addEventListener('submit', function (e) {
                let valid = true;

                if (!validateEmail(emailInput.value.trim())) {
                    emailWrap.classList.add('invalid');
                    valid = false;
                } else {
                    emailWrap.classList.remove('invalid');
                }

                if (pwInput.value.trim().length < 1) {
                    passwordWrap.classList.add('invalid');
                    valid = false;
                } else {
                    passwordWrap.classList.remove('invalid');
                }

                if (!valid) {
                    e.preventDefault();
                    return;
                }

                submitBtn.innerHTML = '<svg viewBox="0 0 24 24" width="16" height="16" stroke="white" stroke-width="2" fill="none"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Signing in...';
                submitBtn.disabled = true;
            });

            emailInput.addEventListener('input', () => emailWrap.classList.remove('invalid'));
            pwInput.addEventListener('input', () => passwordWrap.classList.remove('invalid'));
    </script>
</body>

</html>
