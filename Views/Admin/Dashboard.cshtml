@{
    Layout = null;
    ViewData["Title"] = "Dashboard — NSIA Admin";
    var stepNames = new[] { "Profile", "Company Info", "Team Info", "Product Info", "Commercial", "Impact", "Additional" };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:wght@700;600&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{--teal:#0e86ab;--green:#08703a;--lime:#83c240;--ink:#0d1a12;--cream:#faf8f3;--off:#f4f2ec;--muted:#5a6b60;--border:rgba(0,0,0,0.08);--nav:220px}
        html,body{height:100%}
        body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);display:flex}

        /* SIDEBAR */
        .sidebar{width:var(--nav);background:var(--ink);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;bottom:0;left:0;z-index:100;overflow-y:auto}
        .sidebar::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(14,134,171,0.15) 0%,transparent 55%);pointer-events:none}
        .sidebar>*{position:relative;z-index:1}
        .sb-brand{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid rgba(255,255,255,0.07)}
        .sb-brand-inner{display:flex;align-items:center;gap:.65rem}
        .sb-icon{width:32px;height:32px;border-radius:7px;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .sb-icon svg{width:14px;height:14px;stroke:white;stroke-width:2;fill:none}
        .sb-title{font-size:11px;font-weight:500;color:var(--teal);letter-spacing:.07em;text-transform:uppercase}
        .sb-sub{font-size:10px;color:rgba(255,255,255,0.3)}
        .sb-section{padding:.75rem 0}
        .sb-label{font-size:9px;font-weight:500;color:rgba(255,255,255,0.25);letter-spacing:.1em;text-transform:uppercase;padding:.4rem 1.25rem .2rem;display:block}
        .sb-link{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.25rem;text-decoration:none;color:rgba(255,255,255,0.5);font-size:.8rem;transition:background .15s,color .15s;position:relative}
        .sb-link:hover{background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.85)}
        .sb-link.active{background:rgba(14,134,171,0.12);color:white}
        .sb-link.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2.5px;background:var(--teal);border-radius:0 2px 2px 0}
        .sb-link svg{width:15px;height:15px;stroke:currentColor;stroke-width:1.75;fill:none;flex-shrink:0}
        .sb-badge{margin-left:auto;background:rgba(131,194,64,0.15);border:1px solid rgba(131,194,64,0.25);color:var(--lime);font-size:.62rem;font-weight:600;padding:.15rem .5rem;border-radius:100px}
        .sb-footer{margin-top:auto;padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,0.07)}
        .sb-user{display:flex;align-items:center;gap:.65rem;margin-bottom:.75rem}
        .sb-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:white;flex-shrink:0}
        .sb-uname{font-size:.78rem;font-weight:500;color:rgba(255,255,255,0.75)}
        .sb-urole{font-size:.65rem;color:rgba(255,255,255,0.3)}
        .sb-logout{display:flex;align-items:center;gap:.5rem;font-size:.75rem;color:rgba(255,255,255,0.35);text-decoration:none;transition:color .2s}
        .sb-logout svg{width:13px;height:13px;stroke:currentColor;stroke-width:1.75;fill:none}
        .sb-logout:hover{color:rgba(255,255,255,0.65)}

        /* MAIN */
        .main{margin-left:var(--nav);flex:1;display:flex;flex-direction:column;min-height:100vh}
        .topbar{background:white;border-bottom:1px solid var(--border);padding:.9rem 2rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
        .topbar-title{font-size:.95rem;font-weight:500;color:var(--ink)}
        .topbar-right{display:flex;align-items:center;gap:1rem}
        .topbar-date{font-size:.75rem;color:var(--muted)}
        .btn-export{display:inline-flex;align-items:center;gap:6px;padding:.5rem 1.1rem;background:var(--green);color:white;border:none;border-radius:6px;font-size:.78rem;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;text-decoration:none;transition:background .2s}
        .btn-export:hover{background:#065a2f}
        .btn-export svg{width:13px;height:13px;stroke:white;stroke-width:2;fill:none}
        .content{padding:2rem;flex:1}

        /* STAT CARDS */
        .stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin-bottom:2rem}
        .stat-card{background:white;border-radius:10px;border:1px solid var(--border);padding:1.25rem;position:relative;overflow:hidden}
        .stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
        .stat-card.c-teal::before{background:var(--teal)}
        .stat-card.c-green::before{background:var(--green)}
        .stat-card.c-lime::before{background:var(--lime)}
        .stat-card.c-red::before{background:#ef4444}
        .stat-card.c-amber::before{background:#f59e0b}
        .sc-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:.5rem}
        .sc-value{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;color:var(--ink);line-height:1}
        .sc-sub{font-size:.7rem;color:var(--muted);margin-top:.3rem}

        /* GRID */
        .charts-grid{display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-bottom:1.5rem}
        .panel{background:white;border-radius:10px;border:1px solid var(--border);overflow:hidden}
        .panel-header{padding:1rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
        .panel-title{font-size:.85rem;font-weight:500;color:var(--ink)}
        .panel-body{padding:1.5rem}

        /* BAR CHART */
        .bar-chart{display:flex;flex-direction:column;gap:.65rem}
        .bar-row{display:flex;align-items:center;gap:.75rem}
        .bar-label{font-size:.75rem;color:var(--muted);width:110px;flex-shrink:0;text-align:right}
        .bar-track{flex:1;height:8px;background:var(--off);border-radius:10px;overflow:hidden}
        .bar-fill{height:100%;border-radius:10px;transition:width .6s ease}
        .bar-count{font-size:.72rem;font-weight:500;color:var(--ink);min-width:28px;text-align:right}

        /* STEP PROGRESS */
        .step-rows{display:flex;flex-direction:column;gap:.5rem}
        .step-row{display:flex;align-items:center;gap:.75rem}
        .step-tag{font-size:.68rem;font-weight:500;color:white;padding:.18rem .5rem;border-radius:4px;flex-shrink:0;min-width:22px;text-align:center}
        .step-row-label{font-size:.76rem;color:var(--muted);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .step-row-track{width:100px;height:6px;background:var(--off);border-radius:10px;overflow:hidden;flex-shrink:0}
        .step-row-fill{height:100%;border-radius:10px;background:var(--teal)}
        .step-row-count{font-size:.72rem;font-weight:500;color:var(--ink);min-width:28px;text-align:right}

        /* RECENT TABLE */
        .table-wrap{overflow-x:auto}
        table{width:100%;border-collapse:collapse;font-size:.8rem}
        thead tr{border-bottom:1px solid var(--border)}
        th{text-align:left;font-size:.68rem;font-weight:500;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;padding:.65rem .75rem;white-space:nowrap}
        td{padding:.75rem;border-bottom:1px solid rgba(0,0,0,0.04);color:var(--ink);vertical-align:middle}
        tbody tr:last-child td{border-bottom:none}
        tbody tr:hover td{background:rgba(0,0,0,0.015)}
        .status-pill{display:inline-block;padding:.18rem .6rem;border-radius:100px;font-size:.66rem;font-weight:500;letter-spacing:.04em}
        .sp-draft{background:var(--off);color:var(--muted)}
        .sp-submitted{background:rgba(14,134,171,0.1);color:var(--teal)}
        .sp-review{background:rgba(245,158,11,0.1);color:#b45309}
        .sp-shortlisted{background:rgba(8,112,58,0.1);color:var(--green)}
        .sp-rejected{background:rgba(239,68,68,0.08);color:#dc2626}
        .sp-winner{background:rgba(131,194,64,0.12);color:#4a7c10}
        .tbl-link{color:var(--teal);text-decoration:none;font-weight:500}
        .tbl-link:hover{text-decoration:underline}

        /* DONUT */
        .donut-wrap{display:flex;flex-direction:column;align-items:center;gap:1rem}
        .donut-legend{display:flex;flex-direction:column;gap:.5rem;width:100%}
        .legend-row{display:flex;align-items:center;gap:.6rem}
        .legend-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
        .legend-label{font-size:.75rem;color:var(--muted);flex:1}
        .legend-val{font-size:.75rem;font-weight:500;color:var(--ink)}

        @@media(max-width:1200px){.stats-grid{grid-template-columns:repeat(3,1fr)}}
        @@media(max-width:900px){.sidebar{display:none}.main{margin-left:0}.charts-grid{grid-template-columns:1fr}}
    </style>
</head>
<body>

@{
    var adminName     = ViewBag.AdminName as string ?? "Admin";
    var adminRole     = ViewBag.AdminRole as string ?? "Admin";
    var adminInitials = string.Join("", (adminName ?? "A").Split(' ').Take(2).Select(w => w[0]));
    var total         = (int)(ViewBag.Total ?? 0);
    var submitted     = (int)(ViewBag.Submitted ?? 0);
    var draft         = (int)(ViewBag.Draft ?? 0);
    var verified      = (int)(ViewBag.Verified ?? 0);
    var unverified    = (int)(ViewBag.Unverified ?? 0);
}

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sb-brand">
        <div class="sb-brand-inner">
            <div class="sb-icon"><svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg></div>
            <div><div class="sb-title">NSIA</div><div class="sb-sub">Prize for Innovation</div></div>
        </div>
    </div>
    <div class="sb-section">
        <span class="sb-label">Overview</span>
        <a href="/admin/dashboard" class="sb-link active">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
        <a href="/admin/applications" class="sb-link">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Applications
            <span class="sb-badge">@total</span>
        </a>
    </div>
    <div class="sb-section">
        <span class="sb-label">Export</span>
        <a href="/admin/export" class="sb-link">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export All CSV
        </a>
        <a href="/admin/export?status=Submitted" class="sb-link">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export Submitted
        </a>
    </div>
    @if (adminRole == "SuperAdmin") {
        <div class="sb-section">
            <span class="sb-label">Settings</span>
            <a href="/admin/users" class="sb-link">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Admin Users
            </a>
        </div>
    }
    <div class="sb-footer">
        <div class="sb-user">
            <div class="sb-avatar">@adminInitials</div>
            <div><div class="sb-uname">@adminName</div><div class="sb-urole">@adminRole</div></div>
        </div>
        <a href="/admin/logout" class="sb-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
        </a>
    </div>
</aside>

<!-- MAIN -->
<div class="main">
    <div class="topbar">
        <span class="topbar-title">Dashboard</span>
        <div class="topbar-right">
            <span class="topbar-date">@DateTime.UtcNow.ToString("dddd, dd MMMM yyyy")</span>
            <a href="/admin/export" class="btn-export">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Export CSV
            </a>
        </div>
    </div>

    <div class="content">

        <!-- Stat cards -->
        <div class="stats-grid">
            <div class="stat-card c-teal">
                <div class="sc-label">Total Registrations</div>
                <div class="sc-value">@total</div>
                <div class="sc-sub">All accounts created</div>
            </div>
            <div class="stat-card c-green">
                <div class="sc-label">Submitted</div>
                <div class="sc-value">@submitted</div>
                <div class="sc-sub">Complete applications</div>
            </div>
            <div class="stat-card c-amber">
                <div class="sc-label">In Progress</div>
                <div class="sc-value">@draft</div>
                <div class="sc-sub">Draft applications</div>
            </div>
            <div class="stat-card c-lime">
                <div class="sc-label">Verified Emails</div>
                <div class="sc-value">@verified</div>
                <div class="sc-sub">Of @total total</div>
            </div>
            <div class="stat-card c-red">
                <div class="sc-label">Unverified</div>
                <div class="sc-value">@unverified</div>
                <div class="sc-sub">Pending email verification</div>
            </div>
        </div>

        <div class="charts-grid">

            <!-- Sector + Stage breakdown -->
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">Applications by Sector</span>
                </div>
                <div class="panel-body">
                    @{
                        var sectors   = ViewBag.SectorBreakdown as dynamic ?? new List<dynamic>();
                        var maxSector = 1;
                        foreach (var s in sectors) { if (s.Count > maxSector) maxSector = s.Count; }
                        var sColors   = new[] { "#0e86ab","#08703a","#83c240","#f59e0b","#ef4444","#8b5cf6","#ec4899","#14b8a6" };
                        int si = 0;
                    }
                    <div class="bar-chart">
                        @foreach (var s in sectors) {
                            var pct = total > 0 ? (int)((s.Count / (double)maxSector) * 100) : 0;
                            <div class="bar-row">
                                <div class="bar-label">@s.Sector</div>
                                <div class="bar-track"><div class="bar-fill" style="width:@pct%;background:@sColors[si % sColors.Length]"></div></div>
                                <div class="bar-count">@s.Count</div>
                            </div>
                            si++;
                        }
                        @if (((IEnumerable<dynamic>)sectors).Count() == 0) {
                            <p style="font-size:.8rem;color:var(--muted);text-align:center;padding:1rem 0">No sector data yet.</p>
                        }
                    </div>
                </div>

                <div class="panel-header" style="border-top:1px solid var(--border)">
                    <span class="panel-title">Applications by Growth Stage</span>
                </div>
                <div class="panel-body">
                    @{
                        var stages   = ViewBag.StageBreakdown as dynamic ?? new List<dynamic>();
                        var maxStage = 1;
                        foreach (var st in stages) { if (st.Count > maxStage) maxStage = st.Count; }
                        var stColors = new[] { "#0e86ab","#08703a","#83c240","#f59e0b","#ef4444" };
                        int sti = 0;
                    }
                    <div class="bar-chart">
                        @foreach (var st in stages) {
                            var pct = (int)((st.Count / (double)maxStage) * 100);
                            <div class="bar-row">
                                <div class="bar-label">@st.Stage</div>
                                <div class="bar-track"><div class="bar-fill" style="width:@pct%;background:@stColors[sti % stColors.Length]"></div></div>
                                <div class="bar-count">@st.Count</div>
                            </div>
                            sti++;
                        }
                        @if (((IEnumerable<dynamic>)stages).Count() == 0) {
                            <p style="font-size:.8rem;color:var(--muted);text-align:center;padding:1rem 0">No stage data yet.</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Step completion -->
            <div class="panel">
                <div class="panel-header"><span class="panel-title">Step Completion</span></div>
                <div class="panel-body">
                    @{
                        var steps    = ViewBag.StepBreakdown as dynamic ?? new List<dynamic>();
                        var stepC    = new[] {"#0e86ab","#0a6b8a","#08703a","#065a2f","#83c240","#4a7c10","#f59e0b"};
                    }
                    <div class="step-rows">
                        @foreach (var step in steps) {
                            var pct = total > 0 ? (int)((step.Count / (double)total) * 100) : 0;
                            var idx = (int)step.Step - 1;
                            var sName = idx < stepNames.Length ? stepNames[idx] : $"Step {step.Step}";
                            <div class="step-row">
                                <span class="step-tag" style="background:@stepC[idx % stepC.Length]">@step.Step</span>
                                <span class="step-row-label">@sName</span>
                                <div class="step-row-track"><div class="step-row-fill" style="width:@pct%;background:@stepC[idx % stepC.Length]"></div></div>
                                <span class="step-row-count">@step.Count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent applications -->
        <div class="panel">
            <div class="panel-header">
                <span class="panel-title">Recent Registrations</span>
                <a href="/admin/applications" style="font-size:.76rem;color:var(--teal);text-decoration:none">View all →</a>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Reference</th>
                            <th>Company</th>
                            <th>Sector</th>
                            <th>Step</th>
                            <th>Status</th>
                            <th>Registered</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (nsia.Models.Application a in (ViewBag.RecentApplications ?? new List<nsia.Models.Application>())) {
                            var spCls = a.Status switch {
                                "Submitted"    => "sp-submitted",
                                "Under Review" => "sp-review",
                                "Shortlisted"  => "sp-shortlisted",
                                "Rejected"     => "sp-rejected",
                                "Winner"       => "sp-winner",
                                _              => "sp-draft"
                            };
                            <tr>
                                <td>
                                    <div style="font-weight:500;font-size:.82rem">@a.FullName</div>
                                    <div style="font-size:.7rem;color:var(--muted)">@a.Email</div>
                                </td>
                                <td style="font-size:.78rem;color:var(--muted)">@(a.ReferenceNumber ?? "—")</td>
                                <td style="font-size:.8rem">@(a.CompanyName ?? "—")</td>
                                @* <td style="font-size:.78rem;color:var(--muted)">@(a.Sector ?? "—")</td> *@
                                @if(@a.ApplicationStep == 8){
                                    <td style="font-size:.78rem;text-align:center">7 / 7</td>
                                }else{
                                    <td style="font-size:.78rem;text-align:center">@a.ApplicationStep / 7</td>
                                }
                                
                                <td><span class="status-pill @spCls">@a.Status</span></td>
                                <td style="font-size:.72rem;color:var(--muted)">@a.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td><a href="/admin/applications/@a.Id" class="tbl-link" style="font-size:.75rem">View</a></td>
                            </tr>
                        }
                        @if ((ViewBag.RecentApplications as IList<nsia.Models.Application>)?.Count == 0) {
                            <tr><td colspan="8" style="text-align:center;padding:2rem;color:var(--muted);font-size:.82rem">No applications yet.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
</body>
</html>