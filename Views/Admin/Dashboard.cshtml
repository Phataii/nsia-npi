@{
    ViewData["Title"] = "Dashboard";
    var total      = (int)(ViewBag.Total      ?? 0);
    var submitted  = (int)(ViewBag.Submitted  ?? 0);
    var drafts     = (int)(ViewBag.Drafts     ?? 0);
    var todayCount = (int)(ViewBag.Today      ?? 0);
    var byStatus   = ViewBag.ByStatus   as Dictionary<string, int> ?? new();
    var bySector   = ViewBag.BySector   as Dictionary<string, int> ?? new();
    var recentApps = ViewBag.RecentApps as IEnumerable<dynamic>   ?? new List<dynamic>();
}

@section Styles {
<style>
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-bottom: 2rem; }
    .stat-card { background: white; border-radius: 12px; border: 1px solid var(--border); padding: 1.5rem 1.75rem; display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
    .stat-label { font-size: .72rem; color: var(--muted); text-transform: uppercase; letter-spacing: .07em; margin-bottom: .4rem; }
    .stat-value { font-family: 'Cormorant Garamond', serif; font-size: 2.25rem; font-weight: 700; color: var(--ink); line-height: 1; }
    .stat-sub { font-size: .72rem; color: var(--muted); margin-top: .3rem; }
    .stat-icon { width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
    .stat-icon svg { width: 20px; height: 20px; stroke-width: 1.75; fill: none; }
    .stat-icon.teal { background: var(--teal-light); }
    .stat-icon.teal svg { stroke: var(--teal); }
    .stat-icon.green { background: rgba(123,193,68,0.12); }
    .stat-icon.green svg { stroke: var(--green-dark); }
    .stat-icon.amber { background: rgba(245,158,11,0.1); }
    .stat-icon.amber svg { stroke: #d97706; }
    .stat-icon.purple { background: rgba(139,92,246,0.1); }
    .stat-icon.purple svg { stroke: #7c3aed; }

    .charts-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 2rem; }
    .chart-card { background: white; border-radius: 12px; border: 1px solid var(--border); padding: 1.5rem; }
    .chart-title { font-size: .85rem; font-weight: 500; color: var(--ink); margin-bottom: 1.25rem; display: flex; align-items: center; justify-content: space-between; }
    .chart-title span { font-size: .72rem; color: var(--muted); font-weight: 400; }

    /* Bar chart */
    .bar-chart { display: flex; flex-direction: column; gap: .75rem; }
    .bar-row { display: flex; align-items: center; gap: .85rem; }
    .bar-label { font-size: .76rem; color: var(--muted); width: 90px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .bar-track { flex: 1; height: 8px; background: var(--off); border-radius: 100px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 100px; background: var(--teal); transition: width 1s ease; }
    .bar-count { font-size: .76rem; font-weight: 500; color: var(--ink); width: 30px; text-align: right; flex-shrink: 0; }

    /* Donut */
    .donut-wrap { display: flex; align-items: center; gap: 1.5rem; }
    .donut-legend { display: flex; flex-direction: column; gap: .6rem; flex: 1; }
    .legend-item { display: flex; align-items: center; gap: .6rem; font-size: .78rem; color: var(--ink); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

    /* Recent table */
    .table-card { background: white; border-radius: 12px; border: 1px solid var(--border); overflow: hidden; margin-bottom: 1.25rem; }
    .table-header { padding: 1.1rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .table-title { font-size: .88rem; font-weight: 500; color: var(--ink); }
    .table-link { font-size: .76rem; color: var(--teal); text-decoration: none; display: flex; align-items: center; gap: 4px; }
    .table-link svg { width: 12px; height: 12px; stroke: currentColor; stroke-width: 2; fill: none; }
    table { width: 100%; border-collapse: collapse; }
    th { font-size: .7rem; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; padding: .75rem 1.5rem; text-align: left; background: var(--off); border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: .9rem 1.5rem; font-size: .82rem; color: var(--ink); border-bottom: 1px solid rgba(45,184,176,0.06); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: var(--teal-pale); }
    .status-pill { display: inline-block; padding: .18rem .65rem; border-radius: 100px; font-size: .68rem; font-weight: 500; letter-spacing: .04em; white-space: nowrap; }
    .pill-submitted { background: rgba(45,184,176,0.12); color: var(--teal-deep); }
    .pill-draft     { background: rgba(245,158,11,0.1);  color: #92400e; }
    .pill-reviewed  { background: rgba(123,193,68,0.12); color: var(--green-dark); }
    .td-link { color: var(--teal); text-decoration: none; font-weight: 500; }
    .td-link:hover { text-decoration: underline; }

    @@media (max-width: 1100px) { .stats-grid { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 700px)  { .stats-grid { grid-template-columns: 1fr; } .charts-row { grid-template-columns: 1fr; } }
</style>
}

<div class="breadcrumb">
    <a asp-action="Dashboard" asp-controller="Admin">Admin</a>
    <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
    <span>Dashboard</span>
</div>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div>
            <div class="stat-label">Total Applications</div>
            <div class="stat-value">@total</div>
            <div class="stat-sub">All time</div>
        </div>
        <div class="stat-icon teal">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Submitted</div>
            <div class="stat-value">@submitted</div>
            <div class="stat-sub">Awaiting review</div>
        </div>
        <div class="stat-icon green">
            <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Drafts</div>
            <div class="stat-value">@drafts</div>
            <div class="stat-sub">In progress</div>
        </div>
        <div class="stat-icon amber">
            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
    </div>
    <div class="stat-card">
        <div>
            <div class="stat-label">Registered Today</div>
            <div class="stat-value">@todayCount</div>
            <div class="stat-sub">New today</div>
        </div>
        <div class="stat-icon purple">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="charts-row">

    <!-- By Sector -->
    <div class="chart-card">
        <div class="chart-title">Applications by Sector <span>All time</span></div>
        <div class="bar-chart" id="sectorChart">
            @{
                var sectorMax = bySector.Values.DefaultIfEmpty(1).Max();
            }
            @foreach (var kv in bySector.OrderByDescending(x => x.Value)) {
                var pct = sectorMax > 0 ? (kv.Value * 100 / sectorMax) : 0;
                <div class="bar-row">
                    <div class="bar-label" title="@kv.Key">@kv.Key</div>
                    <div class="bar-track"><div class="bar-fill" style="width:@pct%"></div></div>
                    <div class="bar-count">@kv.Value</div>
                </div>
            }
            @if (!bySector.Any()) {
                <div style="font-size:.8rem;color:var(--muted);text-align:center;padding:1rem 0">No data yet</div>
            }
        </div>
    </div>

    <!-- By Status -->
    <div class="chart-card">
        <div class="chart-title">Applications by Status <span>All time</span></div>
        <div class="donut-wrap">
            <svg width="110" height="110" viewBox="0 0 110 110" id="donutSvg">
                <circle cx="55" cy="55" r="40" fill="none" stroke="var(--off)" stroke-width="14"/>
                @{
                    var statusColors = new Dictionary<string, string> {
                        ["Submitted"] = "#2DB8B0",
                        ["Draft"]     = "#f59e0b",
                        ["Reviewed"]  = "#7BC144",
                        ["Shortlisted"] = "#7c3aed",
                        ["Rejected"]  = "#dc2626",
                    };
                    double statusTotal = byStatus.Values.Sum();
                    double offset = 0;
                    double circumference = 2 * Math.PI * 40;
                }
                @foreach (var kv in byStatus.OrderByDescending(x => x.Value)) {
                    if (statusTotal == 0) break;
                    var dashLen = (kv.Value / statusTotal) * circumference;
                    var color   = statusColors.GetValueOrDefault(kv.Key, "#9ca3af");
                    <circle cx="55" cy="55" r="40" fill="none"
                            stroke="@color" stroke-width="14"
                            stroke-dasharray="@dashLen.ToString("F1") @circumference.ToString("F1")"
                            stroke-dashoffset="@(-(offset * circumference / 360)).ToString("F1")"
                            transform="rotate(-90 55 55)" />
                    offset += (kv.Value / statusTotal) * 360;
                }
                @if (statusTotal == 0) {
                    <circle cx="55" cy="55" r="40" fill="none" stroke="var(--border)" stroke-width="14"/>
                }
                <text x="55" y="50" text-anchor="middle" font-family="Cormorant Garamond,serif" font-size="18" font-weight="700" fill="var(--ink)">@total</text>
                <text x="55" y="65" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="9" fill="var(--muted)">TOTAL</text>
            </svg>
            <div class="donut-legend">
                @foreach (var kv in byStatus.OrderByDescending(x => x.Value)) {
                    var color = statusColors.GetValueOrDefault(kv.Key, "#9ca3af");
                    <div class="legend-item">
                        <div class="legend-dot" style="background:@color"></div>
                        <span>@kv.Key</span>
                        <span style="margin-left:auto;font-weight:500">@kv.Value</span>
                    </div>
                }
                @if (!byStatus.Any()) {
                    <div style="font-size:.8rem;color:var(--muted)">No data yet</div>
                }
            </div>
        </div>
    </div>

</div>

<!-- Recent Applications -->
<div class="table-card">
    <div class="table-header">
        <span class="table-title">Recent Applications</span>
        <a asp-action="Applications" asp-controller="Admin" class="table-link">
            View all <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
    </div>
    <table>
        <thead>
            <tr>
                <th>Reference</th>
                <th>Applicant</th>
                <th>Company</th>
                <th>Sector</th>
                <th>Status</th>
                <th>Registered</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var app in recentApps) {
                <tr>
                    <td><code style="font-size:.75rem;color:var(--muted)">@app.ReferenceNumber</code></td>
                    <td>@app.FullName</td>
                    <td>@app.CompanyName</td>
                    <td>@app.BusinessSector</td>
                    <td>
                        <span class="status-pill @(app.Status == "Submitted" ? "pill-submitted" : app.Status == "Draft" ? "pill-draft" : "pill-reviewed")">
                            @app.Status
                        </span>
                    </td>
                    <td style="color:var(--muted)">@((app.CreatedAt as DateTime?)?.ToString("d MMM yyyy"))</td>
                    <td>
                        <a asp-action="ApplicationDetail" asp-controller="Admin" asp-route-id="@app.Id" class="td-link">
                            View
                        </a>
                    </td>
                </tr>
            }
            @if (!recentApps.Any()) {
                <tr><td colspan="7" style="text-align:center;color:var(--muted);padding:2rem">No applications yet.</td></tr>
            }
        </tbody>
    </table>
</div>