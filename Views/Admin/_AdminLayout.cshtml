@{
    var adminName  = Context.Session.GetString("AdminName")  ?? "Admin";
    var adminRole  = Context.Session.GetString("AdminRole")  ?? "Admin";
    var initials   = string.Join("", (adminName).Split(' ').Take(2).Select(w => w[0]));
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action     = ViewContext.RouteData.Values["action"]?.ToString()     ?? "";

    string NavActive(string a) => action.Equals(a, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — NSIA Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --teal: #2DB8B0; --teal-d: #1a9990; --teal-deep: #0d7a73;
            --teal-light: #E8F7F6; --teal-pale: #F0FAF9;
            --green: #7BC144; --green-dark: #5a9130;
            --ink: #1C2B2A; --cream: #F5F9F8; --off: #EEF4F3;
            --muted: #4A6260; --border: rgba(45,184,176,0.2);
            --nav: 240px; --nav-h: 62px;
        }
        html { scroll-behavior: smooth; }
        body { font-family: 'DM Sans', sans-serif; background: var(--off); color: var(--ink); min-height: 100vh; display: flex; }

        /* ── SIDEBAR ── */
        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0; z-index: 200;
            width: var(--nav); background: var(--teal);
            display: flex; flex-direction: column;
            transition: left .3s cubic-bezier(0.4,0,0.2,1);
        }
        .sidebar-header {
            padding: 1.35rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.07);
            display: flex; align-items: center; justify-content: space-between; flex-shrink: 0;
        }
        .sidebar-logo img { height: 28px; width: auto; }
        .sidebar-badge {
            font-size: 9px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase;
            background: rgba(45,184,176,0.15); border: 1px solid rgba(45,184,176,0.25);
            color: var(--teal); padding: .2rem .55rem; border-radius: 100px;
        }
        .sidebar-user {
            padding: 1rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.07);
            display: flex; align-items: center; gap: .85rem; flex-shrink: 0;
        }
        .sidebar-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: var(--teal); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; flex-shrink: 0;
        }
        .sidebar-uname { font-size: 13px; font-weight: 500; color: var(--ink); }
        .sidebar-urole { font-size: 10px; color: var(--ink); margin-top: 1px; }

        .sidebar-nav { flex: 1; padding: .75rem 0; overflow-y: auto; }
        .nav-section-label {
            font-size: 9px; font-weight: 600; color: var(--ink);
            letter-spacing: .12em; text-transform: uppercase;
            padding: .75rem 1.5rem .3rem; display: block;
        }
        .nav-item {
            display: flex; align-items: center; gap: .85rem;
            padding: .72rem 1.5rem; text-decoration: none;
            color: var(--ink); font-size: 13px;
            transition: background .15s, color .15s; position: relative;
        }
        .nav-item:hover { background: rgba(255,255,255,0.04); color: rgba(255,255,255,0.85); }
        .nav-item.active { background: rgba(45,184,176,0.12); color: white; }
        .nav-item.active::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--teal); border-radius: 0 2px 2px 0; }
        .nav-item svg { width: 16px; height: 16px; stroke: currentColor; stroke-width: 1.75; fill: none; flex-shrink: 0; }
        .nav-badge { margin-left: auto; font-size: 10px; font-weight: 600; background: var(--teal); color: white; padding: .1rem .45rem; border-radius: 100px; }

        .sidebar-footer {
            padding: 1rem 1.5rem; border-top: 1px solid rgba(255,255,255,0.07); flex-shrink: 0;
        }
        .sidebar-logout {
            display: flex; align-items: center; gap: .75rem;
            font-size: 12px; color: rgba(255,255,255,0.35); text-decoration: none;
            transition: color .2s; padding: .4rem 0;
        }
        .sidebar-logout svg { width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.75; fill: none; }
        .sidebar-logout:hover { color: rgba(255,255,255,0.65); }

        /* ── TOPBAR ── */
        .topbar {
            position: fixed; top: 0; left: var(--nav); right: 0; z-index: 100;
            height: var(--nav-h); background: white; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 2rem; gap: 1rem;
        }
        .topbar-title { font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-weight: 700; color: var(--ink); }
        .topbar-right { display: flex; align-items: center; gap: 1rem; }
        .topbar-time { font-size: 11px; color: var(--muted); }

        /* Mobile hamburger */
        .topbar-hamburger { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }
        .topbar-hamburger span { display: block; width: 22px; height: 2px; background: var(--ink); border-radius: 2px; transition: transform .3s, opacity .3s; }
        .topbar-hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
        .topbar-hamburger.open span:nth-child(2) { opacity: 0; }
        .topbar-hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

        .sidebar-overlay { display: none; position: fixed; inset: 0; z-index: 190; background: rgba(0,0,0,0.5); opacity: 0; transition: opacity .3s; }
        .sidebar-overlay.open { opacity: 1; }

        /* ── MAIN ── */
        .admin-main { margin-left: var(--nav); padding-top: var(--nav-h); min-height: 100vh; width: calc(100% - var(--nav)); }
        .admin-content { padding: 2rem 2rem 4rem; max-width: 1400px; }

        /* ── BREADCRUMB ── */
        .breadcrumb { display: flex; align-items: center; gap: .4rem; font-size: 11px; color: var(--muted); margin-bottom: 1.5rem; flex-wrap: wrap; }
        .breadcrumb a { color: var(--teal); text-decoration: none; }
        .breadcrumb a:hover { text-decoration: underline; }
        .breadcrumb svg { width: 10px; height: 10px; stroke: var(--muted); stroke-width: 2; fill: none; }

        @@media (max-width: 900px) {
            .sidebar { left: calc(-1 * var(--nav)); }
            .sidebar.open { left: 0; }
            .topbar { left: 0; }
            .topbar-hamburger { display: flex; }
            .admin-main { margin-left: 0; width: 100%; }
            .admin-content { padding: 1.5rem 1rem 3rem; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

<!-- SIDEBAR OVERLAY -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- SIDEBAR -->
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-logo"><img src="~/logo.png" alt="NSIA" /></div>
        <span class="sidebar-badge">Admin</span>
    </div>
    <div class="sidebar-user">
        <div class="sidebar-avatar">@initials</div>
        <div>
            <div class="sidebar-uname">@adminName</div>
            <div class="sidebar-urole">@adminRole</div>
        </div>
    </div>
    <nav class="sidebar-nav">
        <span class="nav-section-label">Overview</span>
        <a asp-action="Dashboard" asp-controller="Admin" class="nav-item @NavActive("Dashboard")">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>

        <span class="nav-section-label">Applications</span>
        <a asp-action="Applications" asp-controller="Admin" class="nav-item @NavActive("Applications")">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            All Applications
        </a>
        <a asp-action="ExportCsv" asp-controller="Admin" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export CSV
        </a>

        @if (adminRole == "SuperAdmin") {
            <span class="nav-section-label">Administration</span>
            <a asp-action="AdminUsers" asp-controller="Admin" class="nav-item @NavActive("AdminUsers")">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Admin Users
            </a>
        }
    </nav>
    <div class="sidebar-footer">
        <a asp-action="Logout" asp-controller="Admin" class="sidebar-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
        </a>
    </div>
</aside>

<!-- TOPBAR -->
<header class="topbar">
    <div style="display:flex;align-items:center;gap:1rem;">
        <button class="topbar-hamburger" id="topbarHamburger">
            <span></span><span></span><span></span>
        </button>
        <span class="topbar-title">@ViewData["Title"]</span>
    </div>
    <div class="topbar-right">
        <span class="topbar-time" id="adminClock"></span>
    </div>
</header>

<!-- MAIN -->
<main class="admin-main">
    <div class="admin-content">
        @RenderBody()
    </div>
</main>

<script>
    // ── Clock
    function tick() {
        const now = new Date();
        document.getElementById('adminClock').textContent =
            now.toLocaleDateString('en-NG', { weekday:'short', day:'numeric', month:'short', year:'numeric' })
            + ' · ' + now.toLocaleTimeString('en-NG', { hour:'2-digit', minute:'2-digit' });
    }
    tick(); setInterval(tick, 1000);

    // ── Sidebar toggle
    const sidebar        = document.getElementById('sidebar');
    const sidebarOverlay = document.getElementById('sidebarOverlay');
    const hamburger      = document.getElementById('topbarHamburger');

    function openSidebar()  { sidebar.classList.add('open'); sidebarOverlay.style.display='block'; setTimeout(()=>sidebarOverlay.classList.add('open'),10); hamburger.classList.add('open'); document.body.style.overflow='hidden'; }
    function closeSidebar() { sidebar.classList.remove('open'); sidebarOverlay.classList.remove('open'); setTimeout(()=>sidebarOverlay.style.display='',300); hamburger.classList.remove('open'); document.body.style.overflow=''; }
    hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
    sidebarOverlay.addEventListener('click', closeSidebar);
</script>

@RenderSection("Scripts", required: false)
</body>
</html>