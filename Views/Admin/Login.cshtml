@{
    Layout = null;
    ViewData["Title"] = "Admin Login — NSIA";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:wght@700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{--teal:#0e86ab;--green:#08703a;--lime:#83c240;--ink:#0d1a12;--cream:#faf8f3;--muted:#5a6b60;--border:rgba(0,0,0,0.1)}
        body{font-family:'DM Sans',sans-serif;background:var(--ink);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem;position:relative;overflow:hidden}
        body::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(14,134,171,0.2) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(8,112,58,0.15) 0%,transparent 55%)}
        .card{width:100%;max-width:400px;background:var(--cream);border-radius:16px;padding:2.5rem;position:relative;z-index:1}
        .card-brand{display:flex;align-items:center;gap:.65rem;margin-bottom:2rem}
        .brand-icon{width:36px;height:36px;border-radius:8px;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .brand-icon svg{width:16px;height:16px;stroke:white;stroke-width:2;fill:none}
        .brand-text strong{display:block;font-size:11px;font-weight:500;color:var(--teal);letter-spacing:.08em;text-transform:uppercase}
        .brand-text span{font-size:10px;color:var(--muted)}
        h1{font-family:'Cormorant Garamond',serif;font-size:1.75rem;font-weight:700;color:var(--ink);margin-bottom:.3rem}
        .sub{font-size:.8rem;color:var(--muted);margin-bottom:1.75rem}
        .error-box{background:#fef2f2;border:1px solid #fecaca;border-radius:7px;padding:.75rem 1rem;font-size:.8rem;color:#b91c1c;margin-bottom:1.25rem;display:flex;align-items:center;gap:.5rem}
        .error-box svg{width:14px;height:14px;stroke:#b91c1c;stroke-width:2;fill:none;flex-shrink:0}
        .form-group{margin-bottom:1.1rem}
        label{display:block;font-size:.74rem;font-weight:500;color:var(--ink);margin-bottom:.35rem}
        .input-wrap{position:relative}
        .input-icon{position:absolute;left:11px;top:50%;transform:translateY(-50%);pointer-events:none;color:var(--muted)}
        .input-icon svg{width:14px;height:14px;stroke:currentColor;stroke-width:1.75;fill:none;display:block}
        input[type=email],input[type=password]{width:100%;padding:.7rem .9rem .7rem 2.4rem;border:1px solid var(--border);border-radius:7px;font-size:.84rem;font-family:'DM Sans',sans-serif;background:white;color:var(--ink);outline:none;transition:border-color .2s,box-shadow .2s}
        input:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(14,134,171,0.1)}
        .btn{width:100%;padding:.85rem;background:var(--green);color:white;border:none;border-radius:7px;font-size:.88rem;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .2s}
        .btn:hover{background:#065a2f}
        .admin-badge{text-align:center;margin-top:1.5rem;font-size:.7rem;color:var(--muted);display:flex;align-items:center;justify-content:center;gap:.4rem}
        .admin-badge svg{width:12px;height:12px;stroke:var(--muted);stroke-width:2;fill:none}
    </style>
</head>
<body>
<div class="card">
    <div class="card-brand">
        <div class="brand-icon"><svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg></div>
        <div class="brand-text"><strong>NSIA</strong><span>Prize for Innovation</span></div>
    </div>
    <h1>Admin Portal</h1>
    <p class="sub">Sign in to manage applications and review submissions.</p>

    @if (ViewBag.Error != null) {
        <div class="error-box">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @ViewBag.Error
        </div>
    }

    <form method="post" action="/admin/login">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label>Email address</label>
            <div class="input-wrap">
                <span class="input-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                <input type="email" name="email" placeholder="admin@nsia-ip.com" required autocomplete="email" />
            </div>
        </div>
        <div class="form-group">
            <label>Password</label>
            <div class="input-wrap">
                <span class="input-icon"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></span>
                <input type="password" name="password" placeholder="Enter password" required autocomplete="current-password" />
            </div>
        </div>
        <button type="submit" class="btn">Sign in to Admin Portal</button>
    </form>
    <div class="admin-badge">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Restricted access — authorised personnel only
    </div>
</div>
</body>
</html>