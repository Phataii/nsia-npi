@{
    ViewData["Title"] = "Admin Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — NSIA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700&family=DM+Sans:wght@300;400;500&display=swap"
    rel="stylesheet">
    <style>
            *,
            *::before,
            *::after {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            :root {
                --teal: #2DB8B0;
                --teal-d: #1a9990;
                --teal-deep: #0d7a73;
                --teal-light: #E8F7F6;
                --green: #7BC144;
                --ink: #1C2B2A;
                --muted: #4A6260;
                --off: #EEF4F3;
                --border: rgba(45, 184, 176, 0.2);
            }

            body {
                font-family: 'DM Sans', sans-serif;
                background: var(--ink);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 1.5rem;
            }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background: radial-gradient(ellipse at 20% 50%, rgba(45, 184, 176, 0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(123, 193, 68, 0.1) 0%, transparent 55%);
                pointer-events: none;
            }

            .login-card {
                background: white;
                border-radius: 16px;
                padding: 2.75rem 2.5rem;
                width: 100%;
                max-width: 420px;
                position: relative;
                z-index: 1;
                box-shadow: 0 24px 60px rgba(0, 0, 0, 0.3);
            }

            .login-logo {
                margin-bottom: 2rem;
            }

            .login-logo img {
                height: 32px;
                width: auto;
            }

            .login-title {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.75rem;
                font-weight: 700;
                color: var(--ink);
                margin-bottom: .35rem;
            }

            .login-sub {
                font-size: .82rem;
                color: var(--muted);
                margin-bottom: 2rem;
                line-height: 1.6;
            }

            .form-group {
                display: flex;
                flex-direction: column;
                gap: .38rem;
                margin-bottom: 1.1rem;
            }

            label {
                font-size: .74rem;
                font-weight: 500;
                color: var(--ink);
                letter-spacing: .02em;
            }

            .input-wrap {
                position: relative;
            }

            .input-icon {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                pointer-events: none;
            }

            .input-icon svg {
                width: 15px;
                height: 15px;
                stroke: var(--muted);
                stroke-width: 1.75;
                fill: none;
                display: block;
            }

            input {
                width: 100%;
                padding: .75rem .9rem .75rem 2.5rem;
                border: 1px solid var(--border);
                border-radius: 7px;
                font-size: .85rem;
                font-family: 'DM Sans', sans-serif;
                color: var(--ink);
                outline: none;
                transition: border-color .2s, box-shadow .2s;
            }

            input:focus {
                border-color: var(--teal);
                box-shadow: 0 0 0 3px rgba(45, 184, 176, 0.12);
            }

            input::placeholder {
                color: #aab5af;
            }

            .error-banner {
                background: rgba(220, 38, 38, 0.07);
                border: 1px solid rgba(220, 38, 38, 0.2);
                border-radius: 7px;
                padding: .75rem 1rem;
                font-size: .8rem;
                color: #b91c1c;
                margin-bottom: 1.25rem;
                display: flex;
                align-items: center;
                gap: .6rem;
            }

            .error-banner svg {
                width: 15px;
                height: 15px;
                stroke: #b91c1c;
                stroke-width: 1.75;
                fill: none;
                flex-shrink: 0;
            }

            .btn-login {
                width: 100%;
                background: var(--teal);
                color: white;
                padding: .85rem;
                border: none;
                border-radius: 100px;
                font-size: .9rem;
                font-weight: 600;
                font-family: 'DM Sans', sans-serif;
                cursor: pointer;
                transition: background .2s, transform .15s;
                margin-top: .5rem;
                box-shadow: 0 4px 14px rgba(45, 184, 176, 0.3);
            }

            .btn-login:hover {
                background: var(--teal-d);
                transform: translateY(-1px);
            }

            .login-footer {
                margin-top: 1.5rem;
                text-align: center;
                font-size: .75rem;
                color: var(--muted);
            }
    </style>
</head>

<body>
    <div class="login-card">
        <div class="login-logo"><img src="~/logo.png" alt="NSIA" /></div>
        <h1 class="login-title">Admin Portal</h1>
        <p class="login-sub">Sign in to access the NSIA Prize for Innovation administration panel.</p>

        @if (ViewBag.ShowError == true)
        {
            <div class="error-banner">
                <svg viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                Invalid email address or password.
            </div>
        }

        <form asp-action="Login" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="email">Email Address</label>
                <div class="input-wrap">
                    <span class="input-icon"><svg viewBox="0 0 24 24">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                        <polyline points="22,6 12,13 2,6" />
                    </svg></span>
                    <input type="email" id="email" name="Email" placeholder="admin@nsia.com" autocomplete="email" />
                </div>
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <div class="input-wrap">
                    <span class="input-icon"><svg viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg></span>
                    <input type="password" id="password" name="Password" placeholder="••••••••"
                           autocomplete="current-password" />
                </div>
            </div>
            <button type="submit" class="btn-login">Sign in to Admin</button>
        </form>

        <div class="login-footer">NSIA Prize for Innovation 4.0 &nbsp;·&nbsp; Admin Portal</div>
    </div>
</body>

</html>