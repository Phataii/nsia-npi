@{
    ViewData["Title"] = "Admin Users";
    var users = ViewBag.Users as IEnumerable<dynamic> ?? new List<dynamic>();
}

@section Styles {
<style>
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem; }
    .page-header h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 700; color: var(--ink); }
    .btn-invite { padding: .65rem 1.4rem; background: var(--teal); color: white; border: none; border-radius: 100px; font-size: .84rem; font-weight: 500; font-family: 'DM Sans', sans-serif; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: background .2s; text-decoration: none; box-shadow: 0 4px 14px rgba(45,184,176,0.25); }
    .btn-invite:hover { background: var(--teal-d); }
    .btn-invite svg { width: 14px; height: 14px; stroke: white; stroke-width: 2; fill: none; }

    .users-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; }
    .user-card { background: white; border-radius: 12px; border: 1px solid var(--border); padding: 1.4rem; display: flex; flex-direction: column; gap: .85rem; }
    .user-card-top { display: flex; align-items: flex-start; gap: .9rem; }
    .user-card-avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--teal); color: white; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .user-card-avatar.inactive { background: var(--off); color: var(--muted); }
    .user-card-name { font-size: .92rem; font-weight: 500; color: var(--ink); }
    .user-card-email { font-size: .76rem; color: var(--muted); margin-top: 1px; }
    .role-pill { display: inline-block; padding: .18rem .65rem; border-radius: 100px; font-size: .68rem; font-weight: 500; margin-top: .35rem; }
    .role-super { background: rgba(139,92,246,0.1); color: #6d28d9; }
    .role-admin { background: var(--teal-light); color: var(--teal-deep); }
    .user-card-meta { display: flex; flex-direction: column; gap: .35rem; padding-top: .6rem; border-top: 1px solid var(--border); }
    .user-meta-row { display: flex; justify-content: space-between; font-size: .75rem; }
    .user-meta-row span:first-child { color: var(--muted); }
    .user-meta-row span:last-child { color: var(--ink); font-weight: 400; }
    .user-card-footer { display: flex; justify-content: flex-end; }
    .btn-toggle { padding: .4rem 1rem; border-radius: 100px; font-size: .76rem; font-weight: 500; font-family: 'DM Sans', sans-serif; cursor: pointer; border: none; transition: all .2s; }
    .btn-toggle.deactivate { background: rgba(220,38,38,0.08); color: #b91c1c; }
    .btn-toggle.deactivate:hover { background: rgba(220,38,38,0.15); }
    .btn-toggle.activate { background: rgba(45,184,176,0.1); color: var(--teal-deep); }
    .btn-toggle.activate:hover { background: var(--teal-light); }
    .inactive-banner { font-size: .72rem; color: #b91c1c; background: rgba(220,38,38,0.06); border: 1px solid rgba(220,38,38,0.15); border-radius: 6px; padding: .35rem .75rem; text-align: center; }
</style>
}

<div class="breadcrumb">
    <a asp-action="Dashboard" asp-controller="Admin">Admin</a>
    <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
    <span>Admin Users</span>
</div>

<div class="page-header">
    <h2>Admin Users</h2>
    <a href="#" class="btn-invite">
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Invite Admin
    </a>
</div>

<div class="users-grid">
    @foreach (var user in users) {
        var initials = string.Join("", ((string)(user.FullName ?? "")).Split(' ').Take(2).Select(w => w.Length > 0 ? w[0].ToString() : ""));
        var isActive = (bool)(user.IsActive ?? true);
        <div class="user-card">
            <div class="user-card-top">
                <div class="user-card-avatar @(isActive ? "" : "inactive")">@initials</div>
                <div>
                    <div class="user-card-name">@user.FullName</div>
                    <div class="user-card-email">@user.Email</div>
                    <span class="role-pill @(user.Role == "SuperAdmin" ? "role-super" : "role-admin")">@user.Role</span>
                </div>
            </div>
            @if (!isActive) {
                <div class="inactive-banner">Account deactivated</div>
            }
            <div class="user-card-meta">
                <div class="user-meta-row">
                    <span>Created</span>
                    <span>@((user.CreatedAt as DateTime?)?.ToString("d MMM yyyy"))</span>
                </div>
                <div class="user-meta-row">
                    <span>Last login</span>
                    <span>@((user.LastLoginAt as DateTime?)?.ToString("d MMM yyyy, HH:mm") ?? "Never")</span>
                </div>
            </div>
            <div class="user-card-footer">
                <form asp-action="ToggleAdminUser" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@user.Id" />
                    <button type="submit" class="btn-toggle @(isActive ? "deactivate" : "activate")">
                        @(isActive ? "Deactivate" : "Activate")
                    </button>
                </form>
            </div>
        </div>
    }
</div>