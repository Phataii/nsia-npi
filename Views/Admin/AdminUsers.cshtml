@{
    Layout = null;
    ViewData["Title"] = "Admin Users — NSIA Admin";
    var adminName  = ViewBag.AdminName as string ?? "Admin";
    var adminInit  = string.Join("", adminName.Split(' ').Take(2).Select(w => w[0]));
    var adminUsers = ViewBag.AdminUsers as List<nsia.Models.AdminUser> ?? new();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:wght@700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{--teal:#0e86ab;--green:#08703a;--lime:#83c240;--ink:#0d1a12;--cream:#faf8f3;--off:#f4f2ec;--muted:#5a6b60;--border:rgba(0,0,0,0.08);--nav:220px}
        html,body{height:100%}
        body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);display:flex}
        .sidebar{width:var(--nav);background:var(--ink);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;bottom:0;left:0;z-index:100;overflow-y:auto}
        .sidebar::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(14,134,171,0.15) 0%,transparent 55%);pointer-events:none}
        .sidebar>*{position:relative;z-index:1}
        .sb-brand{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid rgba(255,255,255,0.07)}
        .sb-brand-inner{display:flex;align-items:center;gap:.65rem}
        .sb-icon{width:32px;height:32px;border-radius:7px;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .sb-icon svg{width:14px;height:14px;stroke:white;stroke-width:2;fill:none}
        .sb-title{font-size:11px;font-weight:500;color:var(--teal);letter-spacing:.07em;text-transform:uppercase}
        .sb-sub{font-size:10px;color:rgba(255,255,255,0.3)}
        .sb-section{padding:.75rem 0}
        .sb-label{font-size:9px;font-weight:500;color:rgba(255,255,255,0.25);letter-spacing:.1em;text-transform:uppercase;padding:.4rem 1.25rem .2rem;display:block}
        .sb-link{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.25rem;text-decoration:none;color:rgba(255,255,255,0.5);font-size:.8rem;transition:background .15s,color .15s;position:relative}
        .sb-link:hover{background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.85)}
        .sb-link.active{background:rgba(14,134,171,0.12);color:white}
        .sb-link.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2.5px;background:var(--teal);border-radius:0 2px 2px 0}
        .sb-link svg{width:15px;height:15px;stroke:currentColor;stroke-width:1.75;fill:none;flex-shrink:0}
        .sb-footer{margin-top:auto;padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,0.07)}
        .sb-user{display:flex;align-items:center;gap:.65rem;margin-bottom:.75rem}
        .sb-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:white;flex-shrink:0}
        .sb-uname{font-size:.78rem;font-weight:500;color:rgba(255,255,255,0.75)}
        .sb-urole{font-size:.65rem;color:rgba(255,255,255,0.3)}
        .sb-logout{display:flex;align-items:center;gap:.5rem;font-size:.75rem;color:rgba(255,255,255,0.35);text-decoration:none}
        .sb-logout svg{width:13px;height:13px;stroke:currentColor;stroke-width:1.75;fill:none}
        .sb-logout:hover{color:rgba(255,255,255,0.65)}
        .main{margin-left:var(--nav);flex:1;display:flex;flex-direction:column}
        .topbar{background:white;border-bottom:1px solid var(--border);padding:.9rem 2rem;display:flex;align-items:center;justify-content:space-between}
        .topbar-title{font-size:.95rem;font-weight:500}
        .content{padding:1.5rem 2rem 3rem;max-width:900px}
        .panel{background:white;border-radius:10px;border:1px solid var(--border);overflow:hidden;margin-bottom:1.5rem}
        .panel-header{padding:.9rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
        .panel-title{font-size:.85rem;font-weight:500}
        table{width:100%;border-collapse:collapse;font-size:.8rem}
        thead tr{border-bottom:1px solid var(--border);background:rgba(0,0,0,0.015)}
        th{text-align:left;font-size:.67rem;font-weight:500;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;padding:.7rem 1rem;white-space:nowrap}
        td{padding:.8rem 1rem;border-bottom:1px solid rgba(0,0,0,0.04);vertical-align:middle}
        tbody tr:last-child td{border-bottom:none}
        .role-badge{display:inline-block;padding:.18rem .6rem;border-radius:100px;font-size:.66rem;font-weight:500}
        .role-super{background:rgba(131,194,64,0.12);color:#4a7c10}
        .role-admin{background:rgba(14,134,171,0.1);color:var(--teal)}
        .active-badge{display:inline-block;padding:.18rem .6rem;border-radius:100px;font-size:.66rem;font-weight:500}
        .active-yes{background:rgba(8,112,58,0.1);color:var(--green)}
        .active-no{background:rgba(239,68,68,0.08);color:#dc2626}
        .btn-toggle{padding:.3rem .75rem;border-radius:5px;font-size:.72rem;font-family:'DM Sans',sans-serif;border:1px solid var(--border);background:white;cursor:pointer;transition:background .15s}
        .btn-toggle:hover{background:var(--off)}
        /* CREATE FORM */
        .create-form{display:grid;grid-template-columns:1fr 1fr;gap:1rem;padding:1.25rem 1.5rem}
        .form-group{display:flex;flex-direction:column;gap:.35rem}
        .form-group.full{grid-column:1/-1}
        label{font-size:.72rem;font-weight:500;color:var(--ink)}
        input[type=text],input[type=email],input[type=password],select.form-sel{width:100%;padding:.62rem .85rem;border:1px solid var(--border);border-radius:6px;font-size:.82rem;font-family:'DM Sans',sans-serif;background:white;color:var(--ink);outline:none;transition:border-color .2s}
        input:focus,select.form-sel:focus{border-color:var(--teal);box-shadow:0 0 0 3px rgba(14,134,171,0.1)}
        .btn-create{padding:.65rem 1.5rem;background:var(--green);color:white;border:none;border-radius:6px;font-size:.82rem;font-weight:500;font-family:'DM Sans',sans-serif;cursor:pointer;transition:background .2s}
        .btn-create:hover{background:#065a2f}
        .alert{padding:.75rem 1.25rem;border-radius:7px;font-size:.8rem;margin-bottom:1rem}
        .alert-success{background:rgba(8,112,58,0.08);color:var(--green);border:1px solid rgba(8,112,58,0.2)}
        .alert-error{background:#fef2f2;color:#b91c1c;border:1px solid #fecaca}
        @@media(max-width:900px){.sidebar{display:none}.main{margin-left:0}.create-form{grid-template-columns:1fr}}
    </style>
</head>
<body>
<aside class="sidebar">
    <div class="sb-brand">
        <div class="sb-brand-inner">
            <div class="sb-icon"><svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg></div>
            <div><div class="sb-title">NSIA</div><div class="sb-sub">Prize for Innovation</div></div>
        </div>
    </div>
    <div class="sb-section">
        <span class="sb-label">Overview</span>
        <a href="/admin/dashboard" class="sb-link">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Dashboard
        </a>
        <a href="/admin/applications" class="sb-link">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Applications
        </a>
    </div>
    <div class="sb-section">
        <span class="sb-label">Settings</span>
        <a href="/admin/users" class="sb-link active">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>Admin Users
        </a>
    </div>
    <div class="sb-footer">
        <div class="sb-user">
            <div class="sb-avatar">@adminInit</div>
            <div><div class="sb-uname">@adminName</div><div class="sb-urole">SuperAdmin</div></div>
        </div>
        <a href="/admin/logout" class="sb-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Sign out
        </a>
    </div>
</aside>

<div class="main">
    <div class="topbar">
        <span class="topbar-title">Admin Users</span>
    </div>
    <div class="content">

        @if (TempData["Success"] != null) {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null) {
            <div class="alert alert-error">@TempData["Error"]</div>
        }

        <!-- Create form -->
        <div class="panel">
            <div class="panel-header"><span class="panel-title">Create New Admin</span></div>
            <form method="post" action="/admin/users/create">
                @Html.AntiForgeryToken()
                <div class="create-form">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" name="fullName" placeholder="Jane Doe" required />
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email" placeholder="jane@nsia.com.ng" required />
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="Min. 8 characters" required minlength="8" />
                    </div>
                    <div class="form-group">
                        <label>Role</label>
                        <select name="role" class="form-sel">
                            <option value="Admin">Admin</option>
                            <option value="SuperAdmin">SuperAdmin</option>
                        </select>
                    </div>
                    <div class="form-group full" style="align-items:flex-start">
                        <button type="submit" class="btn-create">Create Admin User</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Users table -->
        <div class="panel">
            <div class="panel-header"><span class="panel-title">@adminUsers.Count admin user@(adminUsers.Count != 1 ? "s" : "")</span></div>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Last Login</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in adminUsers) {
                        <tr>
                            <td style="font-weight:500;font-size:.82rem">@u.FullName</td>
                            <td style="font-size:.78rem;color:var(--muted)">@u.Email</td>
                            <td><span class="role-badge @(u.Role == "SuperAdmin" ? "role-super" : "role-admin")">@u.Role</span></td>
                            <td><span class="active-badge @(u.IsActive ? "active-yes" : "active-no")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                            <td style="font-size:.72rem;color:var(--muted)">@(u.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                            <td style="font-size:.72rem;color:var(--muted)">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <form method="post" action="/admin/users/@u.Id/toggle" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-toggle">@(u.IsActive ? "Deactivate" : "Activate")</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
</body>
</html>