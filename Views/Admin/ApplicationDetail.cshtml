@{
    Layout = null;
    ViewData["Title"] = "Application Detail — NSIA Admin";
    var a         = ViewBag.Application as nsia.Models.Application;
    var adminName = ViewBag.AdminName as string ?? "Admin";
    var adminInit = string.Join("", adminName.Split(' ').Take(2).Select(w => w[0]));

    string YN(bool? v) => v == true ? "Yes" : v == false ? "No" : "—";
    string Val(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Cormorant+Garamond:wght@700&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
        :root{--teal:#0e86ab;--green:#08703a;--lime:#83c240;--ink:#0d1a12;--cream:#faf8f3;--off:#f4f2ec;--muted:#5a6b60;--border:rgba(0,0,0,0.08);--nav:220px}
        html,body{height:100%}
        body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--ink);display:flex}
        .sidebar{width:var(--nav);background:var(--ink);display:flex;flex-direction:column;flex-shrink:0;position:fixed;top:0;bottom:0;left:0;z-index:100;overflow-y:auto}
        .sidebar::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 20%,rgba(14,134,171,0.15) 0%,transparent 55%);pointer-events:none}
        .sidebar>*{position:relative;z-index:1}
        .sb-brand{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid rgba(255,255,255,0.07)}
        .sb-brand-inner{display:flex;align-items:center;gap:.65rem}
        .sb-icon{width:32px;height:32px;border-radius:7px;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .sb-icon svg{width:14px;height:14px;stroke:white;stroke-width:2;fill:none}
        .sb-title{font-size:11px;font-weight:500;color:var(--teal);letter-spacing:.07em;text-transform:uppercase}
        .sb-sub{font-size:10px;color:rgba(255,255,255,0.3)}
        .sb-section{padding:.75rem 0}
        .sb-label{font-size:9px;font-weight:500;color:rgba(255,255,255,0.25);letter-spacing:.1em;text-transform:uppercase;padding:.4rem 1.25rem .2rem;display:block}
        .sb-link{display:flex;align-items:center;gap:.75rem;padding:.7rem 1.25rem;text-decoration:none;color:rgba(255,255,255,0.5);font-size:.8rem;transition:background .15s,color .15s;position:relative}
        .sb-link:hover{background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.85)}
        .sb-link.active{background:rgba(14,134,171,0.12);color:white}
        .sb-link.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2.5px;background:var(--teal);border-radius:0 2px 2px 0}
        .sb-link svg{width:15px;height:15px;stroke:currentColor;stroke-width:1.75;fill:none;flex-shrink:0}
        .sb-footer{margin-top:auto;padding:1rem 1.25rem;border-top:1px solid rgba(255,255,255,0.07)}
        .sb-user{display:flex;align-items:center;gap:.65rem;margin-bottom:.75rem}
        .sb-avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--green));display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;color:white;flex-shrink:0}
        .sb-uname{font-size:.78rem;font-weight:500;color:rgba(255,255,255,0.75)}
        .sb-urole{font-size:.65rem;color:rgba(255,255,255,0.3)}
        .sb-logout{display:flex;align-items:center;gap:.5rem;font-size:.75rem;color:rgba(255,255,255,0.35);text-decoration:none;transition:color .2s}
        .sb-logout svg{width:13px;height:13px;stroke:currentColor;stroke-width:1.75;fill:none}
        .sb-logout:hover{color:rgba(255,255,255,0.65)}
        .main{margin-left:var(--nav);flex:1;display:flex;flex-direction:column;min-height:100vh}
        .topbar{background:white;border-bottom:1px solid var(--border);padding:.9rem 2rem;display:flex;align-items:center;gap:1rem;flex-shrink:0;flex-wrap:wrap}
        .topbar-back{display:flex;align-items:center;gap:5px;font-size:.78rem;color:var(--muted);text-decoration:none;transition:color .2s}
        .topbar-back:hover{color:var(--teal)}
        .topbar-back svg{width:13px;height:13px;stroke:currentColor;stroke-width:2;fill:none}
        .topbar-title{font-size:.95rem;font-weight:500;color:var(--ink)}
        .topbar-right{margin-left:auto;display:flex;align-items:center;gap:.75rem}
        .content{padding:1.5rem 2rem 3rem;flex:1;max-width:1000px}

        /* HEADER CARD */
        .app-header{background:var(--ink);border-radius:12px;padding:1.75rem 2rem;margin-bottom:1.5rem;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:space-between;gap:2rem}
        .app-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 10% 50%,rgba(14,134,171,0.2) 0%,transparent 55%),radial-gradient(ellipse at 90% 30%,rgba(8,112,58,0.15) 0%,transparent 50%)}
        .app-header>*{position:relative;z-index:1}
        .app-header-left{}
        .app-ref{font-size:.7rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.35rem}
        .app-name{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:700;color:white;line-height:1.1;margin-bottom:.25rem}
        .app-email{font-size:.8rem;color:rgba(255,255,255,0.5)}
        .app-header-right{display:flex;flex-direction:column;align-items:flex-end;gap:.65rem;flex-shrink:0}
        .status-pill{display:inline-block;padding:.25rem .8rem;border-radius:100px;font-size:.72rem;font-weight:500}
        .sp-draft{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.55)}
        .sp-submitted{background:rgba(14,134,171,0.2);color:#7dd3fc}
        .sp-review{background:rgba(245,158,11,0.15);color:#fcd34d}
        .sp-shortlisted{background:rgba(8,112,58,0.2);color:#86efac}
        .sp-rejected{background:rgba(239,68,68,0.15);color:#fca5a5}
        .sp-winner{background:rgba(131,194,64,0.15);color:var(--lime)}

        /* STATUS FORM */
        .status-form{display:flex;align-items:center;gap:.5rem}
        .status-form select{padding:.35rem .65rem;border-radius:5px;border:1px solid rgba(255,255,255,0.15);background:rgba(255,255,255,0.08);color:white;font-family:'DM Sans',sans-serif;font-size:.75rem;outline:none;cursor:pointer}
        .status-form select option{background:var(--ink);color:white}
        .btn-save-status{padding:.35rem .85rem;background:var(--lime);color:var(--ink);border:none;border-radius:5px;font-size:.72rem;font-weight:600;font-family:'DM Sans',sans-serif;cursor:pointer;transition:opacity .2s}
        .btn-save-status:hover{opacity:.85}

        /* SECTIONS */
        .sections-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
        .section-card{background:white;border-radius:10px;border:1px solid var(--border)}
        .section-card.full{grid-column:1/-1}
        .sc-header{padding:.85rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.65rem}
        .sc-header-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .sc-header-icon svg{width:13px;height:13px;stroke-width:1.75;fill:none}
        .sc-header-icon.teal{background:rgba(14,134,171,0.1)}
        .sc-header-icon.teal svg{stroke:var(--teal)}
        .sc-header-icon.green{background:rgba(8,112,58,0.1)}
        .sc-header-icon.green svg{stroke:var(--green)}
        .sc-header-icon.lime{background:rgba(131,194,64,0.1)}
        .sc-header-icon.lime svg{stroke:#4a7c10}
        .sc-header-icon.ink{background:rgba(13,26,18,0.07)}
        .sc-header-icon.ink svg{stroke:var(--ink)}
        .sc-title{font-size:.8rem;font-weight:500;color:var(--ink)}
        .sc-body{padding:1.1rem 1.25rem;display:flex;flex-direction:column;gap:.55rem}
        .field-row{display:flex;align-items:baseline;gap:.5rem;font-size:.78rem}
        .field-label{color:var(--muted);min-width:130px;flex-shrink:0;font-size:.72rem}
        .field-value{color:var(--ink);font-weight:400;flex:1;word-break:break-word}
        .field-value.mono{font-family:monospace;font-size:.74rem;color:var(--teal)}
        .field-block{font-size:.78rem}
        .field-block .field-label{display:block;margin-bottom:.3rem}
        .field-block .field-value{display:block;background:var(--off);border-radius:6px;padding:.65rem .85rem;font-size:.78rem;line-height:1.6;color:var(--ink)}

        /* FOUNDERS */
        .founder-cards{display:flex;flex-direction:column;gap:.75rem;padding:1.1rem 1.25rem}
        .founder-card{background:var(--off);border-radius:8px;padding:1rem 1.1rem;display:grid;grid-template-columns:1fr 1fr;gap:.35rem .75rem}
        .fc-name{grid-column:1/-1;font-weight:500;font-size:.85rem;color:var(--ink);margin-bottom:.1rem}
        .fc-field{font-size:.74rem;color:var(--muted)}
        .fc-field span{color:var(--ink)}

        /* DOCS */
        .doc-list{padding:1.1rem 1.25rem;display:flex;flex-direction:column;gap:.6rem}
        .doc-row{display:flex;align-items:center;gap:.75rem;padding:.75rem 1rem;background:var(--off);border-radius:8px}
        .doc-type{width:32px;height:32px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.6rem;font-weight:700}
        .doc-type.pdf{background:rgba(220,38,38,0.1);color:#dc2626}
        .doc-type.doc{background:rgba(37,99,235,0.1);color:#2563eb}
        .doc-type.xls{background:rgba(22,163,74,0.1);color:#16a34a}
        .doc-type.other{background:var(--off);color:var(--muted)}
        .doc-name{font-size:.8rem;font-weight:500;color:var(--ink);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
        .doc-meta{font-size:.7rem;color:var(--muted);white-space:nowrap}
        .doc-link{font-size:.72rem;color:var(--teal);text-decoration:none;white-space:nowrap}
        .doc-link:hover{text-decoration:underline}

        /* STEP PROGRESS */
        .step-progress{display:flex;gap:4px;padding:1rem 1.25rem}
        .sp-seg{flex:1;height:6px;border-radius:10px;background:var(--off)}
        .sp-seg.done{background:var(--green)}
        .sp-seg.current{background:var(--teal)}

        @@media(max-width:900px){.sidebar{display:none}.main{margin-left:0}.sections-grid{grid-template-columns:1fr}.app-header{flex-direction:column;align-items:flex-start}}
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
    <div class="sb-brand">
        <div class="sb-brand-inner">
            <div class="sb-icon"><svg viewBox="0 0 24 24"><polyline points="2 7 12 2 22 7"/><polyline points="2 12 12 17 22 12"/><polyline points="2 17 12 22 22 17"/></svg></div>
            <div><div class="sb-title">NSIA</div><div class="sb-sub">Prize for Innovation</div></div>
        </div>
    </div>
    <div class="sb-section">
        <span class="sb-label">Overview</span>
        <a href="/admin/dashboard" class="sb-link">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
        </a>
        <a href="/admin/applications" class="sb-link active">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Applications
        </a>
    </div>
    <div class="sb-section">
        <span class="sb-label">Export</span>
        <a href="/admin/export" class="sb-link">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export All CSV
        </a>
    </div>
    <div class="sb-footer">
        <div class="sb-user">
            <div class="sb-avatar">@adminInit</div>
            <div><div class="sb-uname">@adminName</div><div class="sb-urole">@(ViewBag.AdminRole ?? "Admin")</div></div>
        </div>
        <a href="/admin/logout" class="sb-logout">
            <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign out
        </a>
    </div>
</aside>

<div class="main">
    <div class="topbar">
        <a href="/admin/applications" class="topbar-back">
            <svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Applications
        </a>
        <span style="color:var(--border)">›</span>
        <span class="topbar-title">@a?.FullName</span>
        @if (TempData["Success"] != null) {
            <span style="font-size:.76rem;color:var(--green);background:rgba(8,112,58,0.08);padding:.25rem .75rem;border-radius:100px;margin-left:.5rem">@TempData["Success"]</span>
        }
    </div>

    <div class="content">

        <!-- Header -->
        <div class="app-header">
            <div class="app-header-left">
                <div class="app-ref">@(a?.ReferenceNumber ?? "No Reference") &nbsp;·&nbsp; Registered @a?.CreatedAt.ToString("dd MMM yyyy")</div>
                <div class="app-name">@a?.FullName</div>
                <div class="app-email">@a?.Email &nbsp;·&nbsp; @a?.Phone</div>
            </div>
            <div class="app-header-right">
                @{
                    var spCls = a?.Status switch {
                        "Submitted"    => "sp-submitted",
                        "Under Review" => "sp-review",
                        "Shortlisted"  => "sp-shortlisted",
                        "Rejected"     => "sp-rejected",
                        "Winner"       => "sp-winner",
                        _              => "sp-draft"
                    };
                }
                <span class="status-pill @spCls">@a?.Status</span>
                <form method="post" action="/admin/applications/@a?.Id/status" class="status-form">
                    @Html.AntiForgeryToken()
                    <select name="status">
                        @foreach (var s in new[]{"Draft","Submitted","Under Review","Shortlisted","Rejected","Winner"}) {
                            <option value="@s" selected="@(a?.Status == s ? "selected" : null)">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn-save-status">Update</button>
                </form>
            </div>
        </div>

        <!-- Step progress bar -->
        <div style="background:white;border-radius:10px;border:1px solid var(--border);margin-bottom:1.25rem;padding:.85rem 1.25rem">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.6rem">
                <span style="font-size:.72rem;font-weight:500;color:var(--muted)">Application Progress</span>
                @* <span style="font-size:.72rem;color:var(--muted)">Step @a?.ApplicationStep of 7</span> *@
                @if(@a?.ApplicationStep == 8){
                    <td style="font-size:.72rem;color:var(--muted)">7 / 7</td>
                }else{
                    <td style="font-size:.72rem;color:var(--muted)">@a.ApplicationStep / 7</td>
                }
            </div>
            <div class="step-progress">
                @for (int i = 1; i <= 7; i++) {
                    var cls = i < a?.ApplicationStep ? "done" : i == a?.ApplicationStep ? "current" : "";
                    <div class="sp-seg @cls"></div>
                }
            </div>
        </div>

        <div class="sections-grid">

            <!-- Profile -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon teal"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                    <span class="sc-title">Applicant Profile</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">Full Name</span><span class="field-value">@Val(a?.FullName)</span></div>
                    <div class="field-row"><span class="field-label">Email</span><span class="field-value">@Val(a?.Email)</span></div>
                    <div class="field-row"><span class="field-label">Phone</span><span class="field-value">@Val(a?.Phone)</span></div>
                    <div class="field-row"><span class="field-label">Gender</span><span class="field-value">@Val(a?.Gender)</span></div>
                    <div class="field-row"><span class="field-label">Email Verified</span><span class="field-value">@YN(a?.IsEmailVerified)</span></div>
                    <div class="field-row"><span class="field-label">Submitted</span><span class="field-value">@(a?.SubmittedAt?.ToString("dd MMM yyyy HH:mm") ?? "—")</span></div>
                </div>
            </div>

            <!-- Company -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon green"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div>
                    <span class="sc-title">Company Info</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">Company</span><span class="field-value">@Val(a?.CompanyName)</span></div>
                    <div class="field-row"><span class="field-label">Website</span><span class="field-value mono">@Val(a?.CompanyUrl)</span></div>
                    <div class="field-row"><span class="field-label">Address</span><span class="field-value">@Val(a?.BusinessAddress)</span></div>
                    <div class="field-row"><span class="field-label">Year Inc.</span><span class="field-value">@(a?.YearOfIncorporation?.ToString() ?? "—")</span></div>
                    <div class="field-row"><span class="field-label">Registered (NG)</span><span class="field-value">@YN(a?.IsLegallyRegisteredInNigeria)</span></div>
                    <div class="field-row"><span class="field-label">CAC Reg No.</span><span class="field-value">@Val(a?.CacRegistrationNumber)</span></div>
                    <div class="field-row"><span class="field-label">Operational Entity</span><span class="field-value">@YN(a?.IsNigerianEntityOperational)</span></div>
                    <div class="field-row"><span class="field-label">Foreign Affiliates</span><span class="field-value">@YN(a?.HasForeignAffiliates)</span></div>
                </div>
            </div>

            <!-- Description -->
            <div class="section-card full">
                <div class="sc-header">
                    <div class="sc-header-icon teal"><svg viewBox="0 0 24 24"><line x1="17" y1="10" x2="3" y2="10"/><line x1="21" y1="6" x2="3" y2="6"/><line x1="21" y1="14" x2="3" y2="14"/><line x1="17" y1="18" x2="3" y2="18"/></svg></div>
                    <span class="sc-title">Company Description</span>
                </div>
                <div class="sc-body">
                    <div class="field-block"><span class="field-value">@Val(a?.CompanyDescription)</span></div>
                </div>
            </div>

            <!-- Product -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon lime"><svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
                    <span class="sc-title">Product Info</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">Sector</span><span class="field-value">@Val(a?.Sector)</span></div>
                    <div class="field-row"><span class="field-label">Growth Stage</span><span class="field-value">@Val(a?.GrowthStage)</span></div>
                    <div class="field-row"><span class="field-label">MVP Link</span><span class="field-value mono">@Val(a?.MvpLink)</span></div>
                    <div class="field-row"><span class="field-label">User Count</span><span class="field-value">@Val(a?.UserCountRange)</span></div>
                    <div class="field-row"><span class="field-label">Business Model</span><span class="field-value">@Val(a?.BusinessModel)</span></div>
                    <div class="field-row"><span class="field-label">USP</span><span class="field-value">@Val(a?.UniqueSellingPoint)</span></div>
                    <div class="field-row"><span class="field-label">Go-to-Market</span><span class="field-value">@Val(a?.GoToMarketStrategy)</span></div>
                </div>
            </div>

            <!-- Commercial -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon green"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
                    <span class="sc-title">Commercial</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">Generating Revenue</span><span class="field-value">@YN(a?.HasStartedGeneratingRevenue)</span></div>
                    <div class="field-row"><span class="field-label">Fundraising</span><span class="field-value">@YN(a?.IsCurrentlyFundraising)</span></div>
                    <div class="field-row"><span class="field-label">Valuation</span><span class="field-value">@Val(a?.CompanyValuation)</span></div>
                    <div class="field-row"><span class="field-label">Projected Revenue</span><span class="field-value">@Val(a?.ProjectedRevenueNextYear)</span></div>
                    <div class="field-row"><span class="field-label">Gross Margins</span><span class="field-value">@Val(a?.GrossMargins)</span></div>
                    <div class="field-row"><span class="field-label">Runway</span><span class="field-value">@Val(a?.OperatingRunway)</span></div>
                    <div class="field-row"><span class="field-label">IP Ownership</span><span class="field-value">@Val(a?.IpOwnership)</span></div>
                    <div class="field-row"><span class="field-label">Market Share</span><span class="field-value">@Val(a?.EstimatedMarketShare)</span></div>
                    <div class="field-row"><span class="field-label">CAC</span><span class="field-value">@Val(a?.AverageCustomerAcquisitionCost)</span></div>
                </div>
            </div>

            <!-- Impact -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon lime"><svg viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg></div>
                    <span class="sc-title">Impact &amp; Sustainability</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">SDG Aligned</span><span class="field-value">@YN(a?.AlignsWithUnSdgs)</span></div>
                    <div class="field-row"><span class="field-label">SDGs Addressed</span><span class="field-value">@Val(a?.SdgsAddressed)</span></div>
                    <div class="field-row"><span class="field-label">Reduces Env Harm</span><span class="field-value">@YN(a?.ReducesEnvironmentalHarm)</span></div>
                    <div class="field-row"><span class="field-label">Jobs Created</span><span class="field-value">@Val(a?.JobsCreated)</span></div>
                    <div class="field-row"><span class="field-label">People Impacted</span><span class="field-value">@Val(a?.PeopleImpacted)</span></div>
                    <div class="field-row"><span class="field-label">Replicability</span><span class="field-value">@Val(a?.ModelReplicability)</span></div>
                    <div class="field-row"><span class="field-label">Data Protection</span><span class="field-value">@Val(a?.DataProtectionApproach)</span></div>
                    <div class="field-row"><span class="field-label">Policy Advocacy</span><span class="field-value">@Val(a?.PolicyAdvocacy)</span></div>
                </div>
            </div>

            <!-- Team -->
            <div class="section-card">
                <div class="sc-header">
                    <div class="sc-header-icon teal"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
                    <span class="sc-title">Team Info</span>
                </div>
                <div class="sc-body">
                    <div class="field-row"><span class="field-label">No. of Founders</span><span class="field-value">@(a?.NumberOfFounders?.ToString() ?? "—")</span></div>
                    <div class="field-row"><span class="field-label">Total Employees</span><span class="field-value">@(a?.TotalEmployees?.ToString() ?? "—")</span></div>
                    <div class="field-row"><span class="field-label">Team Composition</span><span class="field-value">@Val(a?.TeamComposition)</span></div>
                </div>
            </div>

            <!-- Founders -->
            @if (a?.Founders != null && a.Founders.Any()) {
                <div class="section-card full">
                    <div class="sc-header">
                        <div class="sc-header-icon green"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
                        <span class="sc-title">Founders (@a.Founders.Count)</span>
                    </div>
                    <div class="founder-cards">
                        @foreach (var f in a.Founders.OrderBy(f => f.DisplayOrder)) {
                            <div class="founder-card">
                                <div class="fc-name">@f.FullName</div>
                                <div class="fc-field">Role: <span>@(f.Role ?? "—")</span></div>
                                <div class="fc-field">Phone: <span>@(f.PhoneNumber ?? "—")</span></div>
                                <div class="fc-field">Nationality: <span>@(f.Nationality ?? "—")</span></div>
                                <div class="fc-field" style="grid-column:1/-1">LinkedIn: <span style="color:var(--teal)">@(f.LinkedInUrl ?? "—")</span></div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Impact texts -->
            @if (!string.IsNullOrWhiteSpace(a?.ImpactDataAndStatistics)) {
                <div class="section-card full">
                    <div class="sc-header">
                        <div class="sc-header-icon lime"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
                        <span class="sc-title">Impact Data &amp; Evidence</span>
                    </div>
                    <div class="sc-body">
                        <div class="field-block"><span class="field-label">Impact Data / Statistics</span><span class="field-value">@a.ImpactDataAndStatistics</span></div>
                        @if (!string.IsNullOrWhiteSpace(a.MeasurableCommunityDifferences)) {
                            <div class="field-block" style="margin-top:.75rem"><span class="field-label">Community Differences</span><span class="field-value">@a.MeasurableCommunityDifferences</span></div>
                        }
                        @if (!string.IsNullOrWhiteSpace(a.TopImpactExamplesDetails)) {
                            <div class="field-block" style="margin-top:.75rem"><span class="field-label">Top Impact Examples</span><span class="field-value">@a.TopImpactExamplesDetails</span></div>
                        }
                    </div>
                </div>
            }

            <!-- Documents -->
            @if (a?.Documents != null && a.Documents.Any()) {
                <div class="section-card full">
                    <div class="sc-header">
                        <div class="sc-header-icon ink"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg></div>
                        <span class="sc-title">Uploaded Documents (@a.Documents.Count)</span>
                    </div>
                    <div class="doc-list">
                        @foreach (var d in a.Documents.OrderBy(d => d.UploadedAt)) {
                            var ext  = d.FileExtension.TrimStart('.').ToLower();
                            var cls  = ext == "pdf" ? "pdf" : ext is "doc" or "docx" ? "doc" : ext is "xls" or "xlsx" ? "xls" : "other";
                            var size = d.FileSizeBytes < 1024 * 1024
                                ? $"{d.FileSizeBytes / 1024}KB"
                                : $"{(d.FileSizeBytes / (1024.0 * 1024)):F1}MB";
                            <div class="doc-row">
                                @* <div class="doc-type @cls">@@ext.ToUpper().Substring(0,Math.Min(3,ext.Length))</div> *@
                                <div>
                                    <div class="doc-name">@d.OriginalFileName</div>
                                    <div class="doc-meta">@d.DocumentType &nbsp;·&nbsp; @size &nbsp;·&nbsp; @d.UploadedAt.ToString("dd MMM yyyy")</div>
                                </div>
                                <a href="/@d.StoredFilePath" target="_blank" class="doc-link">Download →</a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Additional Info -->
            @if (!string.IsNullOrWhiteSpace(a?.AdditionalInformation)) {
                <div class="section-card full">
                    <div class="sc-header">
                        <div class="sc-header-icon ink"><svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></div>
                        <span class="sc-title">Additional Information</span>
                    </div>
                    <div class="sc-body">
                        <div class="field-block"><span class="field-value">@a.AdditionalInformation</span></div>
                    </div>
                </div>
            }

        </div>
    </div>
</div>
</body>
</html>