            @if (docs.Any())
            {
                <div class="section-card">
                    <div class="section-card-header">
                        <svg viewBox="0 0 24 24">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                            <polyline points="17 8 12 3 7 8" />
                            <line x1="12" y1="3" x2="12" y2="15" />
                        </svg>
                        <span>Supporting Documents (@docs.Count())</span>
                    </div>
                    <div class="section-card-body">
                        @foreach (var doc in docs)
                        {
                            <div class="doc-item">
                                <div class="doc-icon">
                                    <svg viewBox="0 0 24 24">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                                        <polyline points="14 2 14 8 20 8" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="doc-name">@doc.OriginalFileName</div>
                                    <div class="doc-meta">@doc.DocumentType &nbsp;·&nbsp; @(Math.Round((double)doc.FileSizeBytes / 1024,
                                                                1)) KB</div>
                                    </div>
                                    <a href="@doc.PublicUrl" target="_blank" class="doc-link">Download →</a>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>